"PersonContainer" *--> "0..*" "UtflyttingFraNorge" : "utflytting"
class "Statsborgerskap" [[{Statsborgerskap registrert på ein person i Folkeregisteret.}]] {
    {field} id : uriorcurie  
    {field} landkode : string  
    {field} gyldig_fra_og_med : date  
    {field} gyldig_til_og_med : date  
}
