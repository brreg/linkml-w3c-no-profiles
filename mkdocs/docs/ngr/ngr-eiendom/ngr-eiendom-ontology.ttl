            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/er_del_av_teig> ] ;
    skos:definition "Abstrakt overklasse for alle typar matrikkeleiningar registrert i Matrikkelen. Ei matrikkelenheit er den grunnleggjande eininga for registrering av fast eigedom i Noreg." ;
    skos:exactMatch ngre:Matrikkelenhet ;
