    linkml:required true ;
    linkml:slot_uri "https://data.norge.no/linkml/ngr-eiendom/id"^^xsd:anyURI .

<https://data.norge.no/linkml/ngr-eiendom/Matrikkelenhet> a linkml:ClassDefinition ;
