            sh:order 3 ;
            sh:path ngrv:erHovednaeringskode ],
        [ sh:datatype xsd:string ;
            sh:description "NACE-kode for næringsgruppering (t.d. 62.010)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ngrv:naeringskodeKode ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
