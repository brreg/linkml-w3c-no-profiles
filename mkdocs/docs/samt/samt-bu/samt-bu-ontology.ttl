samtbuskole:Elev a owl:Class ;
    rdfs:label "Elev" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:horer_til_basisgruppe ],
        [ a owl:Restriction ;
