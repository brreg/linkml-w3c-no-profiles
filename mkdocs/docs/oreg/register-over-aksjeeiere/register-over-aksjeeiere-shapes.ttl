@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

schema1:Thing a sh:NodeShape ;
    rdfs:comment """Containerklasse for alle forretningsobjekt i modellen. Gjer det mogleg å ha fleire instansar av kvar klasse i ei datafil.
""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://data.norge.no/linkml/register-over-aksjeeiere/:Aksje> ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:aksjer> ],
        [ sh:class <https://data.norge.no/linkml/register-over-aksjeeiere/:Aksjekapital> ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:aksjekapitaler> ],
        [ sh:class <https://data.norge.no/linkml/register-over-aksjeeiere/:Aksjeoverdragelse> ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:aksjeoverdragelser> ],
        [ sh:class <https://data.norge.no/linkml/register-over-aksjeeiere/:Utdeling> ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:utdelinger> ],
        [ sh:class <https://data.norge.no/linkml/register-over-aksjeeiere/:Eierskapstransaksjon> ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:eierskapstransaksjoner> ],
        [ sh:class <https://data.norge.no/linkml/register-over-aksjeeiere/:Aksjeeierrettighet> ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:aksjeeierrettigheter> ],
        [ sh:class <https://data.norge.no/linkml/register-over-aksjeeiere/:Aksjeklasse> ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:aksjeklasser> ],
        [ sh:class <https://data.norge.no/linkml/register-over-aksjeeiere/:Eierposisjon> ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:eierposisjoner> ],
        [ sh:class <https://data.norge.no/linkml/register-over-aksjeeiere/:Aksjeinnskudd> ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:aksjeinnskudder> ],
        [ sh:class <https://data.norge.no/linkml/register-over-aksjeeiere/:Aksjeeier> ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:aksjeeiere> ],
        [ sh:class <https://data.norge.no/linkml/register-over-aksjeeiere/:Vederlag> ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:vederlager> ],
        [ sh:class <https://data.norge.no/linkml/register-over-aksjeeiere/:Aksjeselskap> ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:aksjeselskaper> ],
        [ sh:class <https://data.norge.no/linkml/register-over-aksjeeiere/:Selskapshendelse> ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:selskapshendelser> ],
        [ sh:class <https://data.norge.no/linkml/register-over-aksjeeiere/:InnbetaltOverkurs> ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:innbetalt_overkurser> ],
        [ sh:class <https://data.norge.no/linkml/register-over-aksjeeiere/:Aksjepost> ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:aksjeposter> ],
        [ sh:class <https://data.norge.no/linkml/register-over-aksjeeiere/:Utbytte> ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:utbytter> ],
        [ sh:class <https://data.norge.no/linkml/register-over-aksjeeiere/:InnbetaltAksjekapital> ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:innbetalt_aksjekapitaler> ] ;
    sh:targetClass schema1:Thing .

<https://data.norge.no/linkml/register-over-aksjeeiere/:Tidspunkt> a sh:NodeShape ;
    rdfs:comment "Tidspunkt for ei hending." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "Kalenderdato." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:dato> ] ;
    sh:targetClass <https://data.norge.no/linkml/register-over-aksjeeiere/:Tidspunkt> .

<https://data.norge.no/linkml/register-over-aksjeeiere/:Aksjeeier> a sh:NodeShape ;
    rdfs:comment "Person eller organisasjon som eig aksjar." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Global identifikator for instansen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:identifikator> ],
        [ sh:class <https://data.norge.no/linkml/register-over-aksjeeiere/:Eierposisjon> ;
            sh:description "Eierposisjon aksjeeigaren har." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:har_eierposisjon> ],
        [ sh:datatype xsd:string ;
            sh:description "Namn på instansen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:navn> ] ;
    sh:targetClass <https://data.norge.no/linkml/register-over-aksjeeiere/:Aksjeeier> .

<https://data.norge.no/linkml/register-over-aksjeeiere/:Aksjeeierrettighet> a sh:NodeShape ;
    rdfs:comment "Rettigheiter knytt til aksjar, til dømes stemmerett." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Global identifikator for instansen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
