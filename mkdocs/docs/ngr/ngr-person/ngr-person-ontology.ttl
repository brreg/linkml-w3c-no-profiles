<https://data.norge.no/linkml/ngr-person/Person> a owl:Class ;
    rdfs:label "Person" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/har_sivilstand> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-person/Sivilstand> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/har_sivilstand> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/har_bosted_paa> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-person/FamilierelasjonForelder> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/har_familierelasjon_forelder> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/har_foedsel> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-person/Folkeregisteridentifikator> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/har_folkeregisteridentifikator> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/oppholder_seg_paa> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-person/Kjoenn> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/har_kjoenn> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
