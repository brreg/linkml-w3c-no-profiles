<https://data.norge.no/linkml/ngr-person.owl.ttl> a owl:Ontology ;
    rdfs:label "ngr-person" ;
    dcterms:title "Nasjonale grunndata – Person" ;
    skos:definition "Domenemodell for persondata basert på Nasjonale grunndata (utkast). Modellerer Person med identifikasjon, familierelasjonar, adresser, eigarrettar og kontaktopplysningar frå Folkeregisteret og KRR. Basert på https://informasjonsforvaltning.github.io/nasjonale-grunndata/" .

<https://data.norge.no/linkml/ngr-person/PersonContainer> a owl:Class ;
    rdfs:label "PersonContainer" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-person/KontaktinformasjonDoedsbo> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/kontaktinformasjonDoedsbo> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-person/FamilierelasjonEktefelle> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/familierelasjonEktefelle> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/statsborgerskap> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/kontaktopplysningar> ],
        [ a owl:Restriction ;
