@prefix fint: <https://schema.fintlabs.no/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix res: <https://schema.fintlabs.no/ressurs/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://schema.fintlabs.no/ressurs/:RessursContainer> a sh:NodeShape ;
    rdfs:comment "Rotcontainer for FINT Ressurs-instansar." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class res:Lisensmodell ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path <https://schema.fintlabs.no/ressurs/:lisensmodellar> ],
        [ sh:class res:Applikasjonsressurs ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path <https://schema.fintlabs.no/ressurs/:applikasjonsressursar> ],
        [ sh:class res:Enhetstype ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path <https://schema.fintlabs.no/ressurs/:einingstypar> ],
        [ sh:class res:Enhetsgruppe ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path <https://schema.fintlabs.no/ressurs/:einingsgrupper> ],
        [ sh:class res:Plattform ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path <https://schema.fintlabs.no/ressurs/:plattformar> ],
        [ sh:class res:Enhetsgruppemedlemskap ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path <https://schema.fintlabs.no/ressurs/:einingsgruppedmedlemskap> ],
        [ sh:class res:Applikasjonsressurstilgjengelighet ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path <https://schema.fintlabs.no/ressurs/:applikasjonsressurstilgjengelegheit> ],
        [ sh:class res:Identitet ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path <https://schema.fintlabs.no/ressurs/:identitetar> ],
        [ sh:class res:Status ;
            sh:nodeKind sh:IRI ;
            sh:order 15 ;
            sh:path <https://schema.fintlabs.no/ressurs/:statusar> ],
        [ sh:class res:Produsent ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path <https://schema.fintlabs.no/ressurs/:produsentar> ],
        [ sh:class res:Applikasjonskategori ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path <https://schema.fintlabs.no/ressurs/:applikasjonskategoriar> ],
        [ sh:class res:Brukertype ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path <https://schema.fintlabs.no/ressurs/:brukertypar> ],
        [ sh:class res:Handhevingstype ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path <https://schema.fintlabs.no/ressurs/:handhaevingstypar> ],
        [ sh:class res:Applikasjon ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/ressurs/:applikasjonar> ],
        [ sh:class res:DigitalEnhet ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path <https://schema.fintlabs.no/ressurs/:digitaleEiningar> ],
        [ sh:class res:Rettighet ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path <https://schema.fintlabs.no/ressurs/:rettigheiter> ] ;
    sh:targetClass <https://schema.fintlabs.no/ressurs/:RessursContainer> .

res:Applikasjon a sh:NodeShape ;
    rdfs:comment "Ein applikasjon med tilhøyrande ressursar." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class res:Applikasjonsressurs ;
            sh:description "Ulike ressursar (lisensar) knytt til ein applikasjon." ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path res:applikasjonsressurs ],
        [ sh:class fint:Periode ;
            sh:description "Periode ressursen er gyldig for." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path fint:gyldighetsperiode ],
        [ sh:datatype xsd:string ;
            sh:description "Hovudnamn for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path fint:navn ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/:id> ],
        [ sh:datatype xsd:string ;
            sh:description "Beskriven namn eller omtale." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path fint:beskrivelse ],
        [ sh:class res:Applikasjonskategori ;
            sh:description "Kategoriar av applikasjonar." ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path res:applikasjonskategori ],
        [ sh:class res:Plattform ;
            sh:description "Plattforma ressursen er knytt til." ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path res:plattform ] ;
    sh:targetClass res:Applikasjon .

res:Applikasjonskategori a sh:NodeShape ;
    rdfs:comment "Kategori av applikasjonar." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:description "Angir at koden er passiv og ikkje kan veljast." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path fint:passiv ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/:id> ],
        [ sh:class fint:Periode ;
            sh:description "Periode ressursen er gyldig for." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path fint:gyldighetsperiode ],
        [ sh:datatype xsd:string ;
            sh:description "Verdi som identifiserer omgrepet." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path fint:kode ],
        [ sh:datatype xsd:string ;
            sh:description "Hovudnamn for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path fint:navn ] ;
    sh:targetClass res:Applikasjonskategori .

res:Applikasjonsressurstilgjengelighet a sh:NodeShape ;
    rdfs:comment "Kva organisasjonselements brukarar som har tilgang til ein ressurs." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/:id> ],
        [ sh:datatype xsd:integer ;
            sh:description "Totalt tal på lisensar." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path res:lisensantall ],
        [ sh:class res:Applikasjonsressurs ;
            sh:description "Ressursen organisasjonselementet har tilgang til." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path res:ressursRef ],
        [ sh:class fint:Periode ;
            sh:description "Periode ressursen er gyldig for." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path fint:gyldighetsperiode ],
        [ sh:description "Referanse til Organisasjonselement som har tilgang til ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path res:konsument ] ;
    sh:targetClass res:Applikasjonsressurstilgjengelighet .

res:Brukertype a sh:NodeShape ;
    rdfs:comment "Dei ulike brukartypane som kan nytte lisensen." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Hovudnamn for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path fint:navn ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/:id> ],
        [ sh:datatype xsd:string ;
            sh:description "Verdi som identifiserer omgrepet." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path fint:kode ],
        [ sh:datatype xsd:boolean ;
            sh:description "Angir at koden er passiv og ikkje kan veljast." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path fint:passiv ],
        [ sh:class fint:Periode ;
            sh:description "Periode ressursen er gyldig for." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path fint:gyldighetsperiode ] ;
    sh:targetClass res:Brukertype .

res:DigitalEnhet a sh:NodeShape ;
    rdfs:comment "Ei digital eining som t.d. PC, nettbrett eller mobil." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Referanse til Personalressurs (Administrasjon)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path res:personalressurs ],
        [ sh:class res:Enhetsgruppemedlemskap ;
            sh:description "Einingsgruppemelemskap." ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path res:enhetsgruppemedlemskap ],
        [ sh:description "Referanse til Organisasjonselement som har eigarskap." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path res:eier ],
        [ sh:class res:Status ;
            sh:description "Status på eininga i fagsystemet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path res:status ],
        [ sh:class res:Produsent ;
            sh:description "Namn på produsenten av eininga." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path res:produsent ],
        [ sh:class fint:Identifikator ;
            sh:description "Einingsens ID i datakatalogen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path res:dataobjektId ],
        [ sh:datatype xsd:string ;
            sh:description "Hovudnamn for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path fint:navn ],
        [ sh:datatype xsd:string ;
            sh:description "Unikt serienummer frå einingsprodusentens." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path res:serienummer ],
        [ sh:class res:Enhetstype ;
            sh:description "Type digital eining." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path res:enhetstype ],
        [ sh:description "Referanse til Organisasjonselement som administrerer eininga." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path res:administrator ],
        [ sh:datatype xsd:boolean ;
            sh:description "Kvifor eininga er ein- eller flerbrukarenheit." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path res:flerbrukerenhet ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/:id> ],
        [ sh:datatype xsd:boolean ;
            sh:description "Angir om eininga er eigd av organisasjonen eller privatperson." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path res:privateid ],
        [ sh:class res:Plattform ;
            sh:description "Plattforma ressursen er knytt til." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path res:plattform ],
        [ sh:class fint:Elev ;
            sh:description "Referanse til Elev (Utdanning)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path fint:elev ] ;
    sh:targetClass res:DigitalEnhet .

res:Enhetsgruppe a sh:NodeShape ;
    rdfs:comment "Ei gruppering av einsarta digitale einingar." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Hovudnamn for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
