            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/fasteEiendommer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/jordsameier> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/RettighetForAaBenytteEiendom> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/rettigheter> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/samlinger> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/Eierseksjon> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/eierseksjoner> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/Bruksenhet> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/bruksenheter> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/Jordsameie> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/jordsameier> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/HjemmelTilFesterett> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/hjemmelFesterett> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/IkkeTinglystEierforhold> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/ikkeTinglystEierforhold> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/TinglystHeftelse> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/tinglystHeftelser> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/etasjer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/Andel> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/andeler> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/HjemmelTilFramfesterett> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/hjemmelFramfesterett> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/FastEiendom> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/fasteEiendommer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/festegrunn> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/borettslagsandeler> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/borettslag> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/bruksenheter> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/Teig> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/teiger> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/Rettighetshaver> ;
