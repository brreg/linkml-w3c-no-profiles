            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/borettslagsandeler> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/hjemmelEiendomsrett> ],
        [ a owl:Restriction ;
