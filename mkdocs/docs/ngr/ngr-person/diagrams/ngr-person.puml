@startuml
skinparam nodesep 10
hide circle
hide empty members
class "Verge" [[{Ein verje (anten person eller institusjon) som er oppnemnd for å ivareta interessene til ein person. Er av type Person.}]] {
    {field} id : uriorcurie  
    {field} vergetype : VergetypeKode  
    {field} embete : string  
}
class "Person" [[{Ein fysisk person registrert i Folkeregisteret. Hovudbegrepet i domene person.}]] {
    {field} id : uriorcurie  
}
class "PersonContainer" [[{Rotklasse for NGR-person-datafiler. Held flate lister av alle instansierbare klassar; referansar mellom objekt brukar URI-lenking.}]] {

}
"Verge" --> "1" "Person" : "er_av_type_person"
"Person" --> "0..*" "Verge" : "har_verge"
"Person" --> "0..*" "Verge" : "har_verge"(i)
"PersonContainer" *--> "0..*" "Verge" : "verger"
class "UtflyttingFraNorge" [[{Registrering av utflytting frå Noreg i Folkeregisteret.}]] {
    {field} id : uriorcurie  
    {field} tilflyttingsland : string  
    {field} tilflyttingssted_i_utlandet : string  
    {field} utflyttingsdato : date  
}
