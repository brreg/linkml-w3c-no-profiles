@prefix adm: <https://schema.fintlabs.no/administrasjon/> .
@prefix fint: <https://schema.fintlabs.no/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://schema.fintlabs.no/administrasjon/:AdministrasjonContainer> a sh:NodeShape ;
    rdfs:comment "Rotcontainer for FINT Administrasjon-instansar." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class fint:Landkode ;
            sh:description "Alle landkodar i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path adm:landkodar ],
        [ sh:class adm:Prosjektart ;
            sh:description "Alle prosjektartar i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 36 ;
            sh:path adm:prosjektartar ],
        [ sh:class fint:Valuta ;
            sh:description "Alle valutaverdiar i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path adm:valuta ],
        [ sh:class adm:Ansvar ;
            sh:description "Ansvarleg for ei utgift eller inntekt." ;
            sh:nodeKind sh:IRI ;
            sh:order 21 ;
            sh:path adm:ansvar ],
        [ sh:class adm:Personalressurs ;
            sh:description "Alle personalressursar i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path adm:personalressursar ],
        [ sh:class adm:Rolle ;
            sh:description "Alle rollar i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 17 ;
            sh:path adm:rollar ],
        [ sh:class adm:Stillingskode ;
            sh:description "Alle stillingskoder i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 38 ;
            sh:path adm:stillingskoder ],
        [ sh:class fint:Fylke ;
            sh:description "Fylke." ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path fint:fylke ],
        [ sh:class fint:Kontaktperson ;
            sh:description "Alle kontaktpersonar i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path adm:kontaktpersonar ],
        [ sh:class adm:Fravaer ;
            sh:description "Fråvær knytt til ressursen." ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path adm:fravaer ],
        [ sh:class adm:Formaal ;
            sh:description "Formål viser aktivitet og tenesteproduksjon." ;
            sh:nodeKind sh:IRI ;
            sh:order 25 ;
            sh:path adm:formaal ],
        [ sh:class adm:Arbeidslokasjon ;
            sh:description "Alle arbeidslokasjoner i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path adm:arbeidslokasjoner ],
        [ sh:class adm:Aktivitet ;
            sh:description "Alle aktivitetar i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 19 ;
            sh:path adm:aktivitetar ],
        [ sh:class adm:Fasttillegg ;
            sh:description "Faste tillegg for arbeidsforholdet." ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path adm:fasttillegg ],
        [ sh:class adm:Lonsart ;
            sh:description "Alle lønnsartar i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 30 ;
            sh:path adm:lonsartar ],
        [ sh:class adm:Diverse ;
            sh:description "Spesifikasjon som ikkje kjem fram i øvrige dimensjonar." ;
            sh:nodeKind sh:IRI ;
            sh:order 24 ;
            sh:path adm:diverse ],
        [ sh:class adm:Organisasjonselement ;
            sh:description "Organisasjonselement ressursen er knytt til." ;
            sh:nodeKind sh:IRI ;
            sh:order 16 ;
            sh:path adm:organisasjonselement ],
        [ sh:class adm:Arbeidsforholdstype ;
            sh:description "Alle arbeidsforholdstypar i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 23 ;
            sh:path adm:arbeidsforholdstypar ],
        [ sh:class adm:Variabellonn ;
            sh:description "Variabel lønn for arbeidsforholdet." ;
            sh:nodeKind sh:IRI ;
            sh:order 18 ;
            sh:path adm:variabellonn ],
        [ sh:class fint:Person ;
            sh:description "Alle personar i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path adm:personar ],
        [ sh:class fint:Virksomhet ;
            sh:description "Alle verksemder i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path adm:virksomhetar ],
        [ sh:class fint:Kommune ;
            sh:description "Alle kommuneverdiar i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path adm:kommunar ],
        [ sh:class adm:Arbeidsforhold ;
            sh:description "Arbeidsforhold ressursen er knytt til." ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path adm:arbeidsforhold ],
        [ sh:class adm:Fravaersgrunn ;
            sh:description "Alle fråværsgrunnar i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 26 ;
            sh:path adm:fravaersgrunnar ],
        [ sh:class adm:Prosjekt ;
            sh:description "Prosjekt ressursen er knytt til." ;
            sh:nodeKind sh:IRI ;
            sh:order 35 ;
            sh:path adm:prosjekt ],
        [ sh:class adm:Personalressurskategori ;
            sh:description "Alle personalressurskategoriar i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 34 ;
            sh:path adm:personalressurskategoriar ],
        [ sh:class adm:Fullmakt ;
            sh:description "Alle fullmakter i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 15 ;
            sh:path adm:fullmakter ],
        [ sh:class adm:Objekt ;
            sh:description "Objekt ressursen er knytt til." ;
            sh:nodeKind sh:IRI ;
            sh:order 32 ;
            sh:path adm:objekt ],
        [ sh:class adm:Fravaerstype ;
            sh:description "Alle fråværstypar i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 27 ;
            sh:path adm:fravaerstypar ],
        [ sh:class adm:Organisasjonstype ;
            sh:description "Alle organisasjonstypar i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 33 ;
            sh:path adm:organisasjonstypar ],
        [ sh:class fint:Spraak ;
            sh:description "Alle språkverdiar i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path adm:spraak ],
        [ sh:class adm:Uketimetall ;
            sh:description "Alle uketimetallverdiar i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 39 ;
            sh:path adm:uketimetall ],
        [ sh:class adm:Fastlonn ;
            sh:description "Fastlønn for arbeidsforholdet." ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path adm:fastlonn ],
        [ sh:class fint:Kjonn ;
            sh:description "Kjønn." ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path fint:kjonn ],
        [ sh:class adm:Lopenummer ;
            sh:description "Løpenummer i ei nummerserie." ;
            sh:nodeKind sh:IRI ;
            sh:order 31 ;
            sh:path adm:lopenummer ],
        [ sh:class adm:Anlegg ;
            sh:description "Objekt som skal aktiverast eller avskrivast." ;
            sh:nodeKind sh:IRI ;
            sh:order 20 ;
            sh:path adm:anlegg ],
        [ sh:class adm:Art ;
            sh:description "Alle artar i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 22 ;
            sh:path adm:artar ],
        [ sh:class adm:Kontrakt ;
            sh:description "Alle kontrakter i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 29 ;
            sh:path adm:kontrakter ],
        [ sh:class adm:Funksjon ;
            sh:description "Alle funksjonar i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 28 ;
            sh:path adm:funksjonar ],
        [ sh:class adm:Ramme ;
            sh:description "Alle rammer i containeren." ;
            sh:nodeKind sh:IRI ;
            sh:order 37 ;
            sh:path adm:rammer ] ;
    sh:targetClass <https://schema.fintlabs.no/administrasjon/:AdministrasjonContainer> .

adm:Lonn a sh:NodeShape ;
    rdfs:comment "Informasjon om lønn for eit arbeidsforhold (abstrakt base)." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type adm:antall adm:arbeidsforhold adm:prosent adm:lonsart adm:belop ) ;
    sh:property [ sh:datatype xsd:dateTime ;
            sh:description "Tidspunkt då lønn vart kontert." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path adm:kontert ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Tidspunkt då lønn vart anvist." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path adm:anvist ],
        [ sh:class adm:Personalressurs ;
            sh:description "Personalressurs som har attestert lønsmeldinga etter fullmakt." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path adm:attestant ],
        [ sh:class fint:Periode ;
            sh:description "Periode for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path adm:periode ],
        [ sh:class fint:Periode ;
            sh:description "Periode der lønn vart opptent." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path adm:opptjent ],
        [ sh:class adm:Personalressurs ;
            sh:description "Personalressurs som har kontert lønsmeldinga etter fullmakt." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path adm:konterer ],
        [ sh:class adm:Kontostreng ;
            sh:description "Kontering av lønn." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path adm:kontostreng ],
        [ sh:class fint:Identifikator ;
            sh:description "Kjeldesystemets unike identifikator." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path adm:kildesystemId ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/:id> ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Tidspunkt då lønn vart attestert." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path adm:attestert ],
        [ sh:datatype xsd:string ;
            sh:description "Beskriven namn eller omtale." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path fint:beskrivelse ],
        [ sh:class adm:Personalressurs ;
            sh:description "Personalressurs som har anvist lønsmeldinga etter fullmakt." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path adm:anviser ] ;
    sh:targetClass adm:Lonn .

adm:Arbeidslokasjon a sh:NodeShape ;
    rdfs:comment "Fysisk lokasjon der ein tilsett har sitt arbeidsstad." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Namn på eining registrert i Einingsregisteret." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path fint:organisasjonsnavn ],
        [ sh:class fint:Identifikator ;
            sh:description "Niisifra nummer som eintydleg identifiserer einingar i Einingsregisteret." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path fint:organisasjonsnummer ],
        [ sh:class fint:Identifikator ;
            sh:description "Kode som identifiserer ein arbeidslokasjon." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path adm:lokasjonskode ],
        [ sh:datatype xsd:string ;
            sh:description "Namn som beskriv ein arbeidslokasjon." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path adm:lokasjonsnavn ],
        [ sh:class adm:Arbeidsforhold ;
            sh:description "Arbeidsforhold ressursen er knytt til." ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path adm:arbeidsforhold ],
        [ sh:class fint:Kontaktinformasjon ;
            sh:description "Den føretrekte måten å kome i kontakt med ein aktør." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path fint:kontaktinformasjon ],
        [ sh:class fint:Adresse ;
            sh:description "Informasjon om postadresse til ein aktør." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path fint:postadresse ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/:id> ],
        [ sh:class fint:Adresse ;
            sh:description "Besøksadresse til ein organisasjonseining." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path fint:forretningsadresse ] ;
    sh:targetClass adm:Arbeidslokasjon .

