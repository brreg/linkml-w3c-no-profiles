ngrv:Tilstand a sh:NodeShape ;
    rdfs:comment "Registrert tilstand (status) for ei verksemd i Enhetsregisteret, med gyldigheitsperiode for historisk sporing." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "Datoen tilstanden vart gyldig til." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ngrv:gyldigTil ],
        [ sh:description "Type tilstand (AKTIV, UNDER_KONKURS o.l.)." ;
            sh:in ( "AKTIV" "UNDER_TVANGSAVVIKLING" "UNDER_KONKURS" "AVVIKLET" "SLETTET" "OPPLØST" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path ngrv:tilstandstype ],
        [ sh:datatype xsd:date ;
            sh:description "Datoen tilstanden vart gyldig frå." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ngrv:gyldigFra ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/id> ] ;
    sh:targetClass ngrv:Tilstand .

ngrv:Varslingsadresse a sh:NodeShape ;
    rdfs:comment "Offisiell varslingsadresse for verksemda – e-post eller mobilnummer som vert brukt for offisielle meldingar frå offentlege styresmakter." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Kanaltype for varsling (EPOST eller MOBILTELEFON)." ;
            sh:in ( "EPOST" "MOBILTELEFON" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path ngrv:varslingstype ],
        [ sh:datatype xsd:string ;
            sh:description "Verdien for varslingskanalen (e-postadresse eller mobilnummer)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ngrv:varslingsverdi ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/id> ] ;
    sh:targetClass ngrv:Varslingsadresse .


