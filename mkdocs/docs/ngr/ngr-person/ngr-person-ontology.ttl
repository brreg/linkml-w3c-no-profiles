<https://data.norge.no/linkml/ngr-person/Adressebeskyttelse> a owl:Class ;
    rdfs:label "Adressebeskyttelse" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-person/:AdressebeskyttelseGradering> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/adressebeskyttelse_gradering> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/adressebeskyttelse_gradering> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/adressebeskyttelse_gradering> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/id> ] ;
    skos:definition "Gradering av adressebeskyttelse for innflyttede personar til Noreg. Tidlegare kalla kode 6 (strengt fortroleg) og kode 7 (fortroleg)." ;
    skos:exactMatch ngrp:Adressebeskyttelse ;
    skos:inScheme <https://data.norge.no/linkml/ngr-person> .

<https://data.norge.no/linkml/ngr-person/Bostedsadresse> a owl:Class ;
    rdfs:label "Bostedsadresse" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/gyldig_fra_og_med> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/gyldig_til_og_med> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/gyldig_fra_og_med> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/gyldig_til_og_med> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/gyldig_til_og_med> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/gyldig_fra_og_med> ],
        <https://data.norge.no/linkml/ngr-person/GeografiskAdresse> ;
    skos:definition "Adressa personen er registrert busett på i Folkeregisteret." ;
    skos:exactMatch ngrp:Bostedsadresse ;
    skos:inScheme <https://data.norge.no/linkml/ngr-person> .

<https://data.norge.no/linkml/ngr-person/Dodsfall> a owl:Class ;
    rdfs:label "Dodsfall" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/doedssted> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/doedsdato> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/doedssted> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/doedsdato> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/doedssted> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/doedsdato> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/id> ] ;
    skos:definition "Dødsfallsinformasjon om ein person registrert i Folkeregisteret." ;
    skos:exactMatch ngrp:Dodsfall ;
    skos:inScheme <https://data.norge.no/linkml/ngr-person> .

<https://data.norge.no/linkml/ngr-person/FalskIdentitet> a owl:Class ;
