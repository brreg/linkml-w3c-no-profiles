"Person" --> "0..1" "RettsligHandleevne" : "har_rettslig_handleevne"(i)
"PersonContainer" *--> "0..*" "RettsligHandleevne" : "rettsligHandleevne"
class "ReservasjonMotKommunikasjonPaaNett" [[{Registrering av at ein person har reservert seg mot digital kommunikasjon frå det offentlege. Forvaltast av Kontakt- og reservasjonsregisteret (KRR).}]] {
    {field} id : uriorcurie  
    {field} er_reservert : boolean  
    {field} gyldig_fra_og_med : date  
}
"Person" --> "0..1" "ReservasjonMotKommunikasjonPaaNett" : "har_reservasjon_mot_kommunikasjon"
