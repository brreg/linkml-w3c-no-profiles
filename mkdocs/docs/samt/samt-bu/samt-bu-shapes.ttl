@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix samtbuskole: <https://example.no/ontology/skole#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://www.w3.org/ns/dqv#QualityCertificate> a sh:NodeShape ;
    rdfs:comment "Eit sertifikat som stadfester kvaliteten til eit datasett." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <http://www.w3.org/ns/oa#TextualBody> ;
            sh:description "Tekstleg innhald i merknaden." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path <http://www.w3.org/ns/oa#hasBody> ],
        [ sh:class <http://www.w3.org/ns/dqv#Dimension> ;
            sh:description """Refererer til kvalitetsdimensjon(ar) som kvalitetsmerknaden gjeld.
""" ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path <http://www.w3.org/ns/dqv#inDimension> ],
        [ sh:datatype rdf:langString ;
            sh:description "Fritekstmerknad (rdfs:comment)." ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path rdfs:comment ],
        [ sh:description "Motivasjonen bak kvalitetsmerknaden (t.d. oa:assessing)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path <http://www.w3.org/ns/oa#motivatedBy> ],
        [ sh:description "Ressursen merknaden gjeld." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path <http://www.w3.org/ns/oa#hasTarget> ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ap-no/common-ap-no/id> ] ;
    sh:targetClass <http://www.w3.org/ns/dqv#QualityCertificate> .

samtbuskole:Person a sh:NodeShape ;
    rdfs:comment "Eit menneske individ" ;
    sh:closed false ;
    sh:ignoredProperties ( samtbuskole:tilknyttet_basisgruppe samtbuskole:enhetsleder_for samtbuskole:har_saerlig_ansvar_for rdf:type samtbuskole:horer_til_basisgruppe samtbuskole:jobber_paa_skole ) ;
    sh:property [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ sh:datatype xsd:string ;
            sh:description "Namn på ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path samtbuskole:navn ] ;
    sh:targetClass samtbuskole:Person .

samtbuskole:SamtBuContainer a sh:NodeShape ;
    rdfs:comment "Containerklasse for alle klasser som kan inngå i datasettet." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <http://www.w3.org/ns/oa#TextualBody> ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path samtbuskole:tekstdeler ],
        [ sh:class <http://www.w3.org/ns/dqv#QualityMeasurement> ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path samtbuskole:kvalitetsmaalinger ],
        [ sh:class <http://www.w3.org/ns/dqv#UserQualityFeedback> ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path samtbuskole:brukertilbakemeldinger ],
        [ sh:class samtbuskole:Elev ;
            sh:nodeKind sh:IRI ;
            sh:order 20 ;
            sh:path samtbuskole:elever ],
        [ sh:class samtbuskole:Skole ;
            sh:nodeKind sh:IRI ;
            sh:order 15 ;
            sh:path samtbuskole:skoler ],
        [ sh:class samtbuskole:PrivatVirksomhet ;
            sh:nodeKind sh:IRI ;
            sh:order 18 ;
            sh:path samtbuskole:private_virksomheter ],
        [ sh:class <http://www.w3.org/ns/dqv#Dimension> ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path samtbuskole:kvalitetsdimensjoner ],
        [ sh:class samtbuskole:Kommune ;
            sh:nodeKind sh:IRI ;
            sh:order 16 ;
            sh:path samtbuskole:kommuner ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path samtbuskole:id ],
        [ sh:class samtbuskole:Fylke ;
            sh:nodeKind sh:IRI ;
            sh:order 17 ;
            sh:path samtbuskole:fylker ],
        [ sh:class samtbuskole:Rektor ;
            sh:nodeKind sh:IRI ;
            sh:order 21 ;
            sh:path samtbuskole:rektorer ],
        [ sh:class dcat:Dataset ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path samtbuskole:dataset_metadata ],
        [ sh:class <http://data.europa.eu/eli/ontology#LegalResource> ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path samtbuskole:gjeldende_lovgivninger ],
        [ sh:class foaf:Agent ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path samtbuskole:organisasjoner ],
        [ sh:class dcat:Distribution ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path samtbuskole:datasettdistribusjoner ],
        [ sh:class samtbuskole:Kontaktlaerer ;
            sh:nodeKind sh:IRI ;
            sh:order 22 ;
            sh:path samtbuskole:kontaktlaerere ],
        [ sh:class foaf:Agent ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path samtbuskole:grupper ],
        [ sh:class <http://www.w3.org/2006/vcard/ns#Kind> ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path samtbuskole:kontaktpunkter ],
        [ sh:class dcterms:PeriodOfTime ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path samtbuskole:tidsromer ],
        [ sh:class dcterms:Standard ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path samtbuskole:standarder ],
        [ sh:class <http://www.w3.org/ns/dqv#QualityAnnotation> ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path samtbuskole:kvalitetsmerknader ],
        [ sh:class foaf:Agent ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path samtbuskole:utgivere ],
        [ sh:class samtbuskole:Basisgruppe ;
            sh:nodeKind sh:IRI ;
            sh:order 19 ;
            sh:path samtbuskole:basisgrupper ] ;
    sh:targetClass samtbuskole:SamtBuContainer .

<http://data.europa.eu/m8g/Cost> a sh:NodeShape ;
    rdfs:comment "Eit gebyr knytt til bruk av ein datatjeneste." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class skos:Concept ;
            sh:description "Valuta (cv:currency)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path <http://data.europa.eu/m8g/currency> ],
        [ sh:datatype rdf:langString ;
            sh:description "Fritekstbeskrivelse av ressursen (dct:description)." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcterms:description ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ sh:datatype xsd:string ;
            sh:description "Beløp for gebyret." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <http://data.europa.eu/m8g/hasValue> ],
        [ sh:description "Lenke til dokumentasjon om ressursen." ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path foaf:page ] ;
    sh:targetClass <http://data.europa.eu/m8g/Cost> .

<http://spdx.org/rdf/terms#Checksum> a sh:NodeShape ;
    rdfs:comment "Ein sjekksum for ein distribusjon." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Hash-algoritme brukt for sjekksummen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <http://spdx.org/rdf/terms#algorithm> ],
        [ sh:datatype xsd:string ;
            sh:description "Sjekksumverdi som heksadesimal streng." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <http://spdx.org/rdf/terms#checksumValue> ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ap-no/common-ap-no/id> ] ;
    sh:targetClass <http://spdx.org/rdf/terms#Checksum> .

skos:ConceptScheme a sh:NodeShape ;
    rdfs:comment "Ei SKOS-omgrepssamling (temavokabular)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ap-no/common-ap-no/id> ] ;
    sh:targetClass skos:ConceptScheme .

<http://www.w3.org/ns/adms#Identifier> a sh:NodeShape ;
    rdfs:comment "Ein alternativ identifikator for ein ressurs." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ sh:datatype xsd:string ;
            sh:description "Notasjon/kode for identifikatoren." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path skos:notation ] ;
    sh:targetClass <http://www.w3.org/ns/adms#Identifier> .

dcat:CatalogRecord a sh:NodeShape ;
    rdfs:comment "Ein katalogpost som beskriv ein ressurs i katalogen." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class dcterms:Standard ;
            sh:description "Standard ressursen er i samsvar med." ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path dcterms:conformsTo ],
        [ sh:datatype rdf:langString ;
            sh:description "Fritekstbeskrivelse av ressursen (dct:description)." ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path dcterms:description ],
        [ sh:datatype xsd:date ;
            sh:description "Dato ressursen vart første gong publisert (dct:issued)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path dcterms:issued ],
        [ sh:datatype dcterms:language ;
            sh:description "Språk brukt i ressursen (dct:language)." ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path dcterms:language ],
        [ sh:class dcat:Resource ;
            sh:description "Ressursen katalogposten primært beskriv." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path foaf:primaryTopic ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ sh:datatype rdf:langString ;
            sh:description "Namn/tittel på ressursen (dct:title)." ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path dcterms:title ],
        [ sh:description "Kjelde for katalogposten (ekstern oppføring)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path dcterms:source ],
        [ sh:datatype xsd:date ;
            sh:description "Dato for siste endring av ressursen (dct:modified)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcterms:modified ],
        [ sh:class skos:Concept ;
            sh:description "Status for ressursen frå eit kontrollert vokabular (adms:status)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path <http://www.w3.org/ns/adms#status> ] ;
    sh:targetClass dcat:CatalogRecord .

dcat:DatasetSeries a sh:NodeShape ;
    rdfs:comment "Ei serie av relaterte datasett publisert separat men med felles metadata." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <http://www.w3.org/2006/vcard/ns#Kind> ;
            sh:description "Kontaktinformasjon for hendvendelsar om ressursen." ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path dcat:contactPoint ],
        [ sh:datatype xsd:string ;
            sh:description "Oppdateringsfrekvens for datasettet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path dcterms:accrualPeriodicity ],
        [ sh:datatype xsd:string ;
            sh:description "Tema frå eit kontrollert vokabular." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcat:theme ],
        [ sh:datatype xsd:date ;
            sh:description "Dato for siste endring av ressursen (dct:modified)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path dcterms:modified ],
        [ sh:class skos:Concept ;
            sh:description "Geografisk dekningsområde (dct:spatial)." ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path dcterms:spatial ],
        [ sh:class dcterms:PeriodOfTime ;
            sh:description "Tidsperiode ressursen dekkar." ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path dcterms:temporal ],
        [ sh:class foaf:Agent ;
            sh:description "Aktøren som er ansvarleg for å tilgjengeleggjere ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path dcterms:publisher ],
        [ sh:class dcat:Dataset ;
            sh:description "Første datasett i ei datasettserie." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path dcat:first ],
        [ sh:class <http://data.europa.eu/eli/ontology#LegalResource> ;
            sh:description "Lovgjeving som gjeld for ressursen." ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path <http://data.europa.eu/r5r/applicableLegislation> ],
        [ sh:datatype rdf:langString ;
            sh:description "Fritekstbeskrivelse av ressursen (dct:description)." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path dcterms:description ],
        [ sh:class dcat:Dataset ;
            sh:description "Siste datasett i ei datasettserie." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path dcat:last ],
        [ sh:datatype rdf:langString ;
            sh:description "Namn/tittel på ressursen (dct:title)." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcterms:title ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ sh:datatype xsd:date ;
            sh:description "Dato ressursen vart første gong publisert (dct:issued)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path dcterms:issued ] ;
    sh:targetClass dcat:DatasetSeries .

dcat:Relationship a sh:NodeShape ;
    rdfs:comment "Ein kvalifisert relasjon mellom to ressursar." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Den relaterte ressursen i ein kvalifisert relasjon." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path dcterms:relation ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ sh:datatype xsd:string ;
            sh:description "Rolle ein aktør eller ressurs har i ein relasjon." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcat:hadRole ] ;
    sh:targetClass dcat:Relationship .

dcat:Resource a sh:NodeShape ;
    rdfs:comment "Basisklasse for ressursar som kan katalogiserast." ;
    sh:closed false ;
    sh:ignoredProperties ( <http://www.w3.org/ns/adms#status> dcterms:modified dcterms:source dcat:first dcterms:relation dcterms:description dcterms:spatial dcterms:rights <http://www.w3.org/ns/adms#identifier> dcterms:temporal dcat:version dcat:last dcterms:accessRights dcterms:identifier <http://www.w3.org/ns/dqv#hasQualityAnnotation> foaf:homepage dcterms:publisher dcterms:provenance dcterms:subject dcterms:format <http://www.w3.org/ns/adms#sample> dcat:inSeries dcterms:creator <http://www.w3.org/ns/adms#versionNotes> dcat:theme prov:wasGeneratedBy dcterms:accrualPeriodicity dcterms:issued dcterms:license dcat:themeTaxonomy dcat:endpointURL dcat:qualifiedRelation <http://data.europa.eu/r5r/availability> prov:qualifiedAttribution dcterms:type dcterms:language dcterms:hasPart dcat:contactPoint dcat:servesDataset <http://data.europa.eu/m8g/hasCost> dcat:record dcat:distribution dcat:keyword <http://data.europa.eu/r5r/applicableLegislation> dcterms:conformsTo <http://www.w3.org/ns/dqv#hasQualityMeasurement> dcat:endpointDescription dcat:landingPage dcat:catalog dcat:service rdf:type dcterms:title foaf:page dcat:dataset ) ;
    sh:property [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ap-no/common-ap-no/id> ] ;
    sh:targetClass dcat:Resource .

<http://www.w3.org/ns/dqv#Metric> a sh:NodeShape ;
    rdfs:comment "Eit kvalitetsmål som operasjonaliserer ein kvalitetsdeldimensjon." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Forventa XSD-datatype for verdien av ei kvalitetsmåling." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path <http://www.w3.org/ns/dqv#expectedDataType> ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ sh:datatype rdf:langString ;
            sh:description "Føretrekt term/namn for dimensjonen eller målet." ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path skos:prefLabel ],
        [ sh:datatype rdf:langString ;
            sh:description "Definisjon av dimensjonen eller målet." ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path skos:definition ],
        [ sh:class <https://data.norge.no/vocabulary/dqvno#SubDimension> ;
            sh:description "Kvalitetsdeldimensjonen dette målet operasjonaliserer." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path <https://data.norge.no/vocabulary/dqvno#inSubDimension> ] ;
    sh:targetClass <http://www.w3.org/ns/dqv#Metric> .

<http://www.w3.org/ns/dqv#UserQualityFeedback> a sh:NodeShape ;
    rdfs:comment "Tilbakemelding frå ein brukar om kvaliteten til eit datasett." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype rdf:langString ;
            sh:description "Fritekstmerknad (rdfs:comment)." ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path rdfs:comment ],
        [ sh:class <http://www.w3.org/ns/dqv#Dimension> ;
            sh:description """Refererer til kvalitetsdimensjon(ar) som kvalitetsmerknaden gjeld.
""" ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path <http://www.w3.org/ns/dqv#inDimension> ],
        [ sh:class <http://www.w3.org/ns/oa#TextualBody> ;
            sh:description "Tekstleg innhald i merknaden." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
