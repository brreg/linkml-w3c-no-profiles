<https://data.norge.no/linkml/ngr-adresse/Adresseomrade> a owl:Class ;
    rdfs:label "Adresseomrade" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/namn> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/namn> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/namn> ] ;
    skos:definition "Geografisk område eit adressenavn høyrer til, t.d. ei gate, eit veg eller eit stadnamn." ;
    skos:exactMatch ngr:Adresseomrade ;
    skos:inScheme <https://data.norge.no/linkml/ngr-adresse> .

<https://data.norge.no/linkml/ngr-adresse/Kommune> a owl:Class ;
    rdfs:label "Kommune" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/kommunenummer_kode> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/kommunenummer_kode> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/kommunenummer_kode> ],
        <https://data.norge.no/linkml/ngr-adresse/GeografiskOmrade> ;
    skos:definition "Ein norsk kommune." ;
    skos:exactMatch ngr:Kommune ;
    skos:inScheme <https://data.norge.no/linkml/ngr-adresse> .

<https://data.norge.no/linkml/ngr-adresse/Poststed> a owl:Class ;
    rdfs:label "Poststed" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/postnummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/postnummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/postnummer> ],
        <https://data.norge.no/linkml/ngr-adresse/GeografiskOmrade> ;
    skos:definition "Eit poststed identifisert med postnummer, forvalta av Postnummerregisteret." ;
    skos:exactMatch ngr:Poststed ;
    skos:inScheme <https://data.norge.no/linkml/ngr-adresse> .

<https://data.norge.no/linkml/ngr-adresse/Adressekode> a owl:Class ;
    rdfs:label "Adressekode" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/kode> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/kode> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adresseomrade_ref> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Adresseomrade> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adresseomrade_ref> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adresseomrade_ref> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/kode> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/id> ] ;
    skos:definition "Firesifra kommunal kode som identifiserer eit adressenavn." ;
    skos:exactMatch ngr:Adressekode ;
    skos:inScheme <https://data.norge.no/linkml/ngr-adresse> .

<https://data.norge.no/linkml/ngr-adresse/adresseomrade_ref> a owl:ObjectProperty ;
    rdfs:label "adresseomrade_ref" ;
    rdfs:range <https://data.norge.no/linkml/ngr-adresse/Adresseomrade> ;
    skos:definition "Adresseområdet dette adressenamnet eller adressekoden høyrer til." ;
    skos:inScheme <https://data.norge.no/linkml/ngr-adresse> .

<https://data.norge.no/linkml/ngr-adresse/namn> a owl:DatatypeProperty ;
    rdfs:label "namn" ;
    rdfs:range xsd:string ;
    skos:definition "Namn på det geografiske området eller adressekomponenten." ;
    skos:inScheme <https://data.norge.no/linkml/ngr-adresse> .

<https://data.norge.no/linkml/ngr-adresse/:Etasjeplan> a owl:Class ;
    rdfs:label "Etasjeplan" ;
    owl:unionOf ( <https://data.norge.no/linkml/ngr-adresse/:Etasjeplan#H> <https://data.norge.no/linkml/ngr-adresse/:Etasjeplan#U> <https://data.norge.no/linkml/ngr-adresse/:Etasjeplan#K> <https://data.norge.no/linkml/ngr-adresse/:Etasjeplan#L> <https://data.norge.no/linkml/ngr-adresse/:Etasjeplan#M> ) ;
    skos:definition "Kode for kva del av bygningen eit bruksenhetsnummer refererer til." ;
    skos:inScheme <https://data.norge.no/linkml/ngr-adresse> ;
    linkml:permissible_values <https://data.norge.no/linkml/ngr-adresse/:Etasjeplan#H>,
        <https://data.norge.no/linkml/ngr-adresse/:Etasjeplan#K>,
        <https://data.norge.no/linkml/ngr-adresse/:Etasjeplan#L>,
        <https://data.norge.no/linkml/ngr-adresse/:Etasjeplan#M>,
        <https://data.norge.no/linkml/ngr-adresse/:Etasjeplan#U> .

<https://data.norge.no/linkml/ngr-adresse/GeografiskOmrade> a owl:Class ;
    rdfs:label "GeografiskOmrade" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/namn> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/namn> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/id> ],
        [ owl:unionOf ( <https://data.norge.no/linkml/ngr-adresse/Fylke> <https://data.norge.no/linkml/ngr-adresse/Grunnkrets> <https://data.norge.no/linkml/ngr-adresse/Kirkesokn> <https://data.norge.no/linkml/ngr-adresse/KommunalKrets> <https://data.norge.no/linkml/ngr-adresse/Kommune> <https://data.norge.no/linkml/ngr-adresse/Poststed> <https://data.norge.no/linkml/ngr-adresse/Stemmekrets> <https://data.norge.no/linkml/ngr-adresse/Svalbard> <https://data.norge.no/linkml/ngr-adresse/Tettsted> ) ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/namn> ] ;
    skos:definition "Abstrakt klasse for geografiske inndelingar som offisielle adressar refererer til." ;
    skos:exactMatch ngr:GeografiskOmrade ;
    skos:inScheme <https://data.norge.no/linkml/ngr-adresse> .

<https://data.norge.no/linkml/ngr-adresse/id> a owl:DatatypeProperty ;
    rdfs:label "id" ;
    rdfs:range xsd:anyURI ;
    skos:definition "URI-identifikator for ressursen." ;
    skos:inScheme <https://data.norge.no/linkml/ngr-adresse> .


