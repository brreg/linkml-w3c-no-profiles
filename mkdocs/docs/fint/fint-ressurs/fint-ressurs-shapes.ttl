res:Applikasjonsressurs a sh:NodeShape ;
    rdfs:comment "Informasjon om kor ein applikasjon kan nyttast (lisensressurs)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class res:Handhevingstype ;
            sh:description "Korleis lisensmodellen skal handhevast." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path res:handhevingstype ],
        [ sh:class fint:Periode ;
            sh:description "Periode ressursen er gyldig for." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path fint:gyldighetsperiode ],
        [ sh:datatype xsd:integer ;
            sh:description "Totalt tal på lisensar." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path res:lisensantall ],
        [ sh:class res:Brukertype ;
            sh:description "For kva brukertypar lisensen er gyldig." ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path res:brukertype ],
        [ sh:class res:Applikasjonsressurstilgjengelighet ;
            sh:description "Angir kva organisasjonseining og kor mange ressursar som skal tilordnast." ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path res:ressurstilgjengelighet ],
        [ sh:datatype xsd:boolean ;
            sh:description "True dersom tildeling av ressursen krev godkjenning." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path res:kreverGodkjenning ],
        [ sh:datatype xsd:string ;
            sh:description "Beskriven namn eller omtale." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path fint:beskrivelse ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/:id> ],
        [ sh:description "Referanse til Organisasjonselement som har eigarskap." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path res:eier ],
        [ sh:class res:Lisensmodell ;
            sh:description "Lisensmodellen applikasjonsressursen har." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path res:lisensmodell ],
        [ sh:datatype xsd:string ;
            sh:description "Hovudnamn for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path fint:navn ],
        [ sh:class res:Applikasjon ;
            sh:description "Applikasjonen ressursen (lisensen) er knytt til." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path res:applikasjon ],
        [ sh:datatype xsd:integer ;
            sh:description "Kostnad per ressurs." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path res:enhetskostnad ] ;
    sh:targetClass res:Applikasjonsressurs .

res:Enhetsgruppemedlemskap a sh:NodeShape ;
