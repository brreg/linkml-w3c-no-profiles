<https://data.norge.no/fair-metadata> a linkml:SchemaDefinition ;
    dcterms:license "https://creativecommons.org/publicdomain/zero/1.0/" ;
    dcterms:title "FAIR Metadata Overbygning" ;
    pav:version "1.0.0" ;
    sh:declare [ sh:namespace "https://w3id.org/linkml/"^^xsd:anyURI ;
            sh:prefix "linkml" ],
        [ sh:namespace "http://www.w3.org/ns/dcat#"^^xsd:anyURI ;
            sh:prefix "dcat" ],
        [ sh:namespace "https://data.norge.no/fair#"^^xsd:anyURI ;
            sh:prefix "fair" ],
        [ sh:namespace "http://www.w3.org/ns/prov#"^^xsd:anyURI ;
            sh:prefix "prov" ],
        [ sh:namespace "http://purl.org/dc/terms/"^^xsd:anyURI ;
            sh:prefix "dct" ] ;
    linkml:classes <https://data.norge.no/FAIRMetadata>,
        <https://data.norge.no/Gjenbruksmetadata>,
        <https://data.norge.no/Katalogregistrering>,
        <https://data.norge.no/Proveniensmetadata>,
        <https://data.norge.no/Tilgangsmetadata> ;
    linkml:default_prefix "https://data.norge.no/fair#" ;
    linkml:default_range <https://data.norge.no/string> ;
    linkml:description """FAIR metadata-overbygning som utfyllar norske applikasjonsprofilar for å sikre maskin-aksjonerbar FAIR-konformitet i tråd med FAIR-prinsippa (Findable, Accessible, Interoperable, Reusable).
""" ;
