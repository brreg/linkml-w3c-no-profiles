            owl:allValuesFrom <https://data.norge.no/linkml/ngr-virksomhet/Naeringskode> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-virksomhet/er_klassifisert_i_naeringskode> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-virksomhet/er_klassifisert_som_organisasjonsform> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-virksomhet/er_klassifisert_som_organisasjonsform> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-virksomhet/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-virksomhet/navn> ],
        [ a owl:Restriction ;
