<https://schema.fintlabs.no/arkiv/:Merknad> a owl:Class ;
    rdfs:label "Merknad" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/arkiv/:Merknadstype> ;
            owl:onProperty <https://schema.fintlabs.no/arkiv/:merknadstype> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/arkiv/:merknadstekst> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/arkiv/:merknadstype> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://schema.fintlabs.no/arkiv/:merknadsdato> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/arkiv/:merknadsdato> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/arkiv/:merknadstype> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/arkiv/:Arkivressurs> ;
            owl:onProperty <https://schema.fintlabs.no/arkiv/:merknadRegistrertAv> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/arkiv/:merknadstekst> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/arkiv/:merknadsdato> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/arkiv/:merknadRegistrertAv> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/arkiv/:merknadstekst> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/arkiv/:merknadRegistrertAv> ] ;
    skos:definition "Merknad knytt til mappe, registrering eller dokumentbeskrivelse." ;
    skos:exactMatch ark:Merknad ;
    skos:inScheme <https://data.norge.no/linkml/fint-arkiv> .

