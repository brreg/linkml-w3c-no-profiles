            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/anleggseiendommer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/Borettslag> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/borettslag> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/ytreInnganger> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/AnnenMatrikkelenhet> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/andreMatrikkelenheter> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/bygninger> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/teiger> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/Grunneiendom> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/grunneiendommer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/HjemmelTilEiendomsrett> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/hjemmelEiendomsrett> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/eierseksjoner> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/andeler> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/Matrikkelnummer> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/matrikkelnumre> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/Anleggseiendom> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/anleggseiendommer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/matrikkelnumre> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/hjemmelFesterett> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/Representasjonspunkt> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/representasjonspunkt> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/Bygning> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/bygninger> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/andreMatrikkelenheter> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/tinglystHeftelser> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/Festegrunn> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/festegrunn> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/grunneiendommer> ] ;
    skos:definition "Rotklasse for NGR-eiendom-datafiler. Held flate lister av alle instansierbare klassar; referansar mellom objekt brukar URI-lenking." ;
    skos:inScheme <https://data.norge.no/ngr/ngr-eiendom> .

<https://data.norge.no/ngr/ngr-eiendom/SamletFastEiendom> a owl:Class ;
    rdfs:label "SamletFastEiendom" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 2 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/bestar_av_fast_eiendom> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/FastEiendom> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/bestar_av_fast_eiendom> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/id> ] ;
    skos:definition "Samling av to eller fleire faste eigedommar som er organiserte saman. Lite brukt i praksis i dag." ;
    skos:exactMatch ngre:SamletFastEiendom ;
    skos:inScheme <https://data.norge.no/ngr/ngr-eiendom> .

<https://data.norge.no/ngr/ngr-eiendom/:Etasjeplan#H> a owl:Class ;
    rdfs:label "H" ;
    rdfs:subClassOf <https://data.norge.no/ngr/ngr-eiendom/:Etasjeplan> ;
    skos:definition "Høgde (over bakkenivå)" .

<https://data.norge.no/ngr/ngr-eiendom/:Etasjeplan#K> a owl:Class ;
    rdfs:label "K" ;
    rdfs:subClassOf <https://data.norge.no/ngr/ngr-eiendom/:Etasjeplan> ;
    skos:definition "Kjellar" .

<https://data.norge.no/ngr/ngr-eiendom/:Etasjeplan#L> a owl:Class ;
    rdfs:label "L" ;
    rdfs:subClassOf <https://data.norge.no/ngr/ngr-eiendom/:Etasjeplan> ;
    skos:definition "Loft" .

<https://data.norge.no/ngr/ngr-eiendom/:Etasjeplan#M> a owl:Class ;
    rdfs:label "M" ;
    rdfs:subClassOf <https://data.norge.no/ngr/ngr-eiendom/:Etasjeplan> ;
    skos:definition "Mesanin" .

<https://data.norge.no/ngr/ngr-eiendom/:Etasjeplan#U> a owl:Class ;
    rdfs:label "U" ;
    rdfs:subClassOf <https://data.norge.no/ngr/ngr-eiendom/:Etasjeplan> ;
    skos:definition "Under bakkenivå" .

<https://data.norge.no/ngr/ngr-eiendom/Anleggseiendom> a owl:Class ;
    rdfs:label "Anleggseiendom" ;
    rdfs:subClassOf <https://data.norge.no/ngr/ngr-eiendom/Matrikkelenhet> ;
    skos:definition "Eit volum – ein bygning eller konstruksjon – oppretta frå ei eller fleire grunneigedommar eller anleggseigedommar. Strekkjer seg over og/eller under andre matrikkeleiningar. Kan også opprettast ved okkupasjon frå eierløs undergrunn eller sjøgrunn." ;
    skos:exactMatch ngre:Anleggseiendom ;
    skos:inScheme <https://data.norge.no/ngr/ngr-eiendom> .

<https://data.norge.no/ngr/ngr-eiendom/Anleggsprojeksjonsflate> a owl:Class ;
    rdfs:label "Anleggsprojeksjonsflate" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/id> ] ;
    skos:definition "Fotavtrykk av 3D-eigedommar (anleggseigedommar). Manglar volumet og må supplerast på oppdrag." ;
    skos:exactMatch ngre:Anleggsprojeksjonsflate ;
    skos:inScheme <https://data.norge.no/ngr/ngr-eiendom> .

<https://data.norge.no/ngr/ngr-eiendom/AnnenMatrikkelenhet> a owl:Class ;
    rdfs:label "AnnenMatrikkelenhet" ;
    rdfs:subClassOf <https://data.norge.no/ngr/ngr-eiendom/Matrikkelenhet> ;
    skos:definition "Matrikkelenheit som ikkje fell inn under dei andre underklassane." ;
    skos:exactMatch ngre:AnnenMatrikkelenhet ;
    skos:inScheme <https://data.norge.no/ngr/ngr-eiendom> .

<https://data.norge.no/ngr/ngr-eiendom/Bruksenhetsnummer> a owl:Class ;
    rdfs:label "Bruksenhetsnummer" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/:Etasjeplan> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/etasjeplan> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/nummerering_i_etasjen> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/etasjeplan> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/etasjenummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/nummerering_i_etasjen> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/etasjeplan> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/etasjenummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/nummerering_i_etasjen> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/etasjenummer> ] ;
    skos:definition "Identifikator for ei brukseining innanfor ein bygning, t.d. H0201 = 2. etasje, eining 1 (etasjeplan + etasjenummer + nummerering)." ;
    skos:exactMatch ngre:Bruksenhetsnummer ;
    skos:inScheme <https://data.norge.no/ngr/ngr-eiendom> .

<https://data.norge.no/ngr/ngr-eiendom/Bruksnummer> a owl:Class ;
    rdfs:label "Bruksnummer" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/bruksnummer_verdi> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/bruksnummer_verdi> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/bruksnummer_verdi> ] ;
    skos:definition "Bruksnummer innanfor gardsnamnet." ;
    skos:exactMatch ngre:Bruksnummer ;
    skos:inScheme <https://data.norge.no/ngr/ngr-eiendom> .

<https://data.norge.no/ngr/ngr-eiendom/Bygningsnummer> a owl:Class ;
    rdfs:label "Bygningsnummer" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/bygningsnummer_verdi> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/bygningsnummer_verdi> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/bygningsnummer_verdi> ] ;
    skos:definition "Offisiell identifikator for ein bygning i Matrikkelen." ;
    skos:exactMatch ngre:Bygningsnummer ;
    skos:inScheme <https://data.norge.no/ngr/ngr-eiendom> .

<https://data.norge.no/ngr/ngr-eiendom/Eierseksjon> a owl:Class ;
    rdfs:label "Eierseksjon" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/kan_vaere_pa> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/kan_vaere_pa> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/Matrikkelenhet> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/kan_vaere_pa> ],
        <https://data.norge.no/ngr/ngr-eiendom/Matrikkelenhet> ;
    skos:definition "Ein eigarseksjon er ein eigarandel i ein seksjonert eigedom. Eigaren har einerett til å bruke ein bestemt del av eigedommen, medan heile eigedommen er i sameige med dei andre seksjonseigarane. Eigedommen som er seksjonert kan vere grunneigendom, festegrunn eller anleggseigendom." ;
    skos:exactMatch ngre:Eierseksjon ;
    skos:inScheme <https://data.norge.no/ngr/ngr-eiendom> .

<https://data.norge.no/ngr/ngr-eiendom/Festegrunn> a owl:Class ;
    rdfs:label "Festegrunn" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ngr/ngr-eiendom/Matrikkelenhet> ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/kan_vaere_pa> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/kan_vaere_pa> ],
