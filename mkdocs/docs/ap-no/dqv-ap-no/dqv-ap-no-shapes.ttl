            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/common-ap-no/id> ] ;
    sh:targetClass dcat:Relationship .

dcat:Resource a sh:NodeShape ;
    rdfs:comment "Basisklasse for ressursar som kan katalogiserast." ;
    sh:closed false ;
    sh:ignoredProperties ( <http://data.europa.eu/m8g/hasCost> <http://www.w3.org/ns/adms#identifier> dcat:version dcat:service dcat:contactPoint dcat:qualifiedRelation dct:type dct:provenance prov:wasGeneratedBy dct:accrualPeriodicity dcat:servesDataset dct:title dcat:last dct:language foaf:homepage foaf:page dqv:hasQualityMeasurement dct:relation <http://data.europa.eu/r5r/applicableLegislation> dct:spatial dct:source dct:modified dcat:inSeries dcat:dataset dcat:record dct:description <http://data.europa.eu/r5r/availability> dct:identifier dct:publisher dcat:theme <http://www.w3.org/ns/adms#versionNotes> dct:rights prov:qualifiedAttribution dct:format dct:subject dct:accessRights <http://www.w3.org/ns/adms#status> dct:hasPart dcat:first dct:creator dct:conformsTo dqv:hasQualityAnnotation dcat:distribution dct:temporal dcat:landingPage rdf:type dcat:endpointURL dct:issued dcat:endpointDescription dct:license <http://www.w3.org/ns/adms#sample> dcat:themeTaxonomy dcat:catalog dcat:keyword ) ;
    sh:property [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/common-ap-no/id> ] ;
    sh:targetClass dcat:Resource .

dqv:Metric a sh:NodeShape ;
    rdfs:comment "Eit kvalitetsmål som operasjonaliserer ein kvalitetsdeldimensjon." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
