<https://data.norge.no/linkml/ngr-person/identifikatornummer> a owl:DatatypeProperty ;
    rdfs:label "identifikatornummer" ;
    rdfs:range xsd:string ;
    skos:definition "Sjølve identifikatoren som tekststreng (11 siffer for fødselsnummer/D-nummer)." ;
    skos:inScheme <https://data.norge.no/linkml/ngr-person> .

<https://data.norge.no/linkml/ngr-person/gyldig_til_og_med> a owl:DatatypeProperty ;
    rdfs:label "gyldig_til_og_med" ;
    rdfs:range xsd:date ;
    skos:definition "Dato opplysinga er gyldig til og med." ;
    skos:inScheme <https://data.norge.no/linkml/ngr-person> .

<https://data.norge.no/linkml/ngr-person/er_av_type_person> a owl:ObjectProperty ;
    rdfs:label "er_av_type_person" ;
    rdfs:range <https://data.norge.no/linkml/ngr-person/Person> ;
    skos:definition "Personen som denne relasjonen peikar til." ;
    skos:inScheme <https://data.norge.no/linkml/ngr-person> .

<https://data.norge.no/linkml/ngr-person/gyldig_fra_og_med> a owl:DatatypeProperty ;
    rdfs:label "gyldig_fra_og_med" ;
    rdfs:range xsd:date ;
    skos:definition "Dato opplysinga er gyldig frå og med." ;
    skos:inScheme <https://data.norge.no/linkml/ngr-person> .

<https://data.norge.no/linkml/ngr-person/id> a owl:DatatypeProperty ;
    rdfs:label "id" ;
    rdfs:range xsd:anyURI ;
    skos:definition "URI-identifikator for ressursen." ;
    skos:inScheme <https://data.norge.no/linkml/ngr-person> .


