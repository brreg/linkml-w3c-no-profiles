    skos:exactMatch fint:Periode ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/arkiv/:tittel> a owl:DatatypeProperty ;
    rdfs:label "tittel" ;
    rdfs:range xsd:string ;
    skos:definition "Tittel eller namn på arkivenheten." ;
    skos:inScheme <https://data.norge.no/linkml/fint-arkiv> .

<https://schema.fintlabs.no/arkiv/:Arkivressurs> a owl:Class ;
    rdfs:label "Arkivressurs" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/arkiv/:Tilgang> ;
            owl:onProperty <https://schema.fintlabs.no/arkiv/:tilgang> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/arkiv/:tilgang> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://schema.fintlabs.no/arkiv/:personalressurs> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Identifikator> ;
            owl:onProperty <https://schema.fintlabs.no/arkiv/:kildesystemId> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/arkiv/:kildesystemId> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/arkiv/:personalressurs> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/arkiv/:Autorisasjon> ;
            owl:onProperty <https://schema.fintlabs.no/arkiv/:autorisasjon> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/arkiv/:kildesystemId> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/arkiv/:personalressurs> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/arkiv/:autorisasjon> ] ;
    skos:definition "Ansatt med rolle og rettar innanfor arkiv." ;
    skos:exactMatch ark:Arkivressurs ;
    skos:inScheme <https://data.norge.no/linkml/fint-arkiv> .

<https://schema.fintlabs.no/:kode> a owl:DatatypeProperty ;
    rdfs:label "kode" ;
    rdfs:range xsd:string ;
    skos:definition "Verdi som identifiserer omgrepet." ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:passiv> a owl:DatatypeProperty ;
    rdfs:label "passiv" ;
    rdfs:range xsd:boolean ;
    skos:definition "Angir at koden er passiv og ikkje kan veljast." ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:navn> a owl:DatatypeProperty ;
    rdfs:label "navn" ;
    rdfs:range xsd:string ;
    skos:definition "Hovudnamn for ressursen." ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:gyldighetsperiode> a owl:ObjectProperty ;
    rdfs:label "gyldighetsperiode" ;
    rdfs:range <https://schema.fintlabs.no/:Periode> ;
    skos:definition "Periode ressursen er gyldig for." ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:id> a owl:DatatypeProperty ;
    rdfs:label "id" ;
    rdfs:range xsd:anyURI ;
    skos:definition "URI-identifikator for ressursen." ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .


