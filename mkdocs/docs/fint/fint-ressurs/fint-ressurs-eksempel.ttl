@prefix fint: <https://schema.fintlabs.no/> .
@prefix res: <https://schema.fintlabs.no/ressurs/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.no/fint/applikasjon/teams> a res:Applikasjon ;
    fint:beskrivelse "Kommunikasjons- og samarbeidsplattform" ;
    fint:gyldighetsperiode [ a fint:Periode ;
            fint:start "2020-03-01T00:00:00+00:00"^^xsd:dateTime ] ;
    fint:navn "Microsoft Teams" .

<https://example.no/fint/applikasjonsressurs/hr-portal-ansatt> a res:Applikasjonsressurs ;
    fint:gyldighetsperiode [ a fint:Periode ;
            fint:start "2022-01-01T00:00:00+00:00"^^xsd:dateTime ] ;
    fint:navn "HR-portal – ansatttilgang" ;
    res:applikasjon <https://example.no/fint/applikasjon/hr-portal> ;
    res:brukertype <https://example.no/fint/brukertype/ansatt> ;
    res:eier "finta:organisasjonselement/it-avdeling"^^xsd:anyURI .

<https://example.no/fint/brukertype/elev> a res:Brukertype ;
    fint:gyldighetsperiode [ a fint:Periode ;
            fint:start "2020-01-01T00:00:00+00:00"^^xsd:dateTime ] ;
    fint:kode "ELEV" ;
    fint:navn "Elev" .

<https://example.no/fint/identitet/id-p12345> a res:Identitet ;
    res:personalressurs "finta:personalressurs/p12345"^^xsd:anyURI ;
    res:rettighet <https://example.no/fint/rettighet/les-ansattdata>,
        <https://example.no/fint/rettighet/teams-bruker> .

<https://example.no/fint/identitet/id-p23456> a res:Identitet ;
    res:personalressurs "finta:personalressurs/p23456"^^xsd:anyURI ;
    res:rettighet <https://example.no/fint/rettighet/les-ansattdata>,
        <https://example.no/fint/rettighet/teams-bruker> .

<https://example.no/fint/applikasjon/hr-portal> a res:Applikasjon ;
    fint:beskrivelse "Sjølvbeteningsportal for HR-tenester" ;
    fint:gyldighetsperiode [ a fint:Periode ;
            fint:start "2022-01-01T00:00:00+00:00"^^xsd:dateTime ] ;
    fint:navn "HR-portalen" .

<https://example.no/fint/brukertype/ansatt> a res:Brukertype ;
    fint:gyldighetsperiode [ a fint:Periode ;
            fint:start "2020-01-01T00:00:00+00:00"^^xsd:dateTime ] ;
    fint:kode "ANSATT" ;
    fint:navn "Ansatt" .

<https://example.no/fint/rettighet/les-ansattdata> a res:Rettighet ;
    fint:beskrivelse "Tilgang til å lese eigne personalopplysningar i HR-portalen" ;
    fint:kode "HR_READ" ;
    fint:navn "Les ansattdata" .

<https://example.no/fint/rettighet/teams-bruker> a res:Rettighet ;
    fint:beskrivelse "Rett til å bruke Microsoft Teams som kommunikasjonsplattform" ;
    fint:kode "TEAMS_USER" ;
    fint:navn "Teams-bruker" .

[] a <https://schema.fintlabs.no/ressurs/:RessursContainer> ;
    res:applikasjonar <https://example.no/fint/applikasjon/hr-portal>,
        <https://example.no/fint/applikasjon/teams> ;
    res:applikasjonsressursar <https://example.no/fint/applikasjonsressurs/hr-portal-ansatt> ;
    res:brukertypar <https://example.no/fint/brukertype/ansatt>,
        <https://example.no/fint/brukertype/elev> ;
    res:identitetar <https://example.no/fint/identitet/id-p12345>,
        <https://example.no/fint/identitet/id-p23456> ;
    res:rettigheiter <https://example.no/fint/rettighet/les-ansattdata>,
        <https://example.no/fint/rettighet/teams-bruker> .

