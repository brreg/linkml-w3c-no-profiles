    skos:definition "Algoritme nytta for å berekne sjekksummen." ;
    skos:inScheme <https://data.norge.no/linkml/fint-arkiv> .

<https://schema.fintlabs.no/arkiv/:skjermingshjemmel> a owl:ObjectProperty ;
