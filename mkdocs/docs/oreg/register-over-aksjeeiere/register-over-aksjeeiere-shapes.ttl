@prefix aksje: <https://example.no/ontology/aksje#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

schema1:Thing a sh:NodeShape ;
    rdfs:comment """Containerklasse for alle forretningsobjekt i modellen. Gjer det mogleg å ha fleire instansar av kvar klasse i ei datafil.
""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class aksje:Eierposisjon ;
            sh:description "Samling av eigarposisjonar." ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path aksje:eierposisjoner ],
        [ sh:class aksje:Aksjepost ;
            sh:description "Samling av aksjepostar." ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path aksje:aksjeposter ],
        [ sh:class aksje:InnbetaltAksjekapital ;
            sh:description "Samling av innbetalt aksjekapital." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path aksje:innbetalt_aksjekapitaler ],
        [ sh:class aksje:Aksjeoverdragelse ;
            sh:description "Samling av aksjeoverdragingar." ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path aksje:aksjeoverdragelser ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Global identifikator for instansen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path aksje:identifikator ],
        [ sh:class aksje:InnbetaltOverkurs ;
            sh:description "Samling av innbetalt overkurs." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path aksje:innbetalt_overkurser ],
        [ sh:class aksje:Utdeling ;
            sh:description "Samling av utdelingar." ;
            sh:nodeKind sh:IRI ;
            sh:order 15 ;
            sh:path aksje:utdelinger ],
        [ sh:class aksje:Vederlag ;
            sh:description "Samling av vederlag." ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path aksje:vederlager ],
        [ sh:class aksje:Aksjeeier ;
            sh:description "Samling av aksjeeigarar." ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path aksje:aksjeeiere ],
        [ sh:class aksje:Aksjeselskap ;
            sh:description "Samling av aksjeselskap." ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path aksje:aksjeselskaper ],
        [ sh:class aksje:Aksjekapital ;
            sh:description "Samling av aksjekapitalar." ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path aksje:aksjekapitaler ],
        [ sh:class aksje:Aksje ;
            sh:description "Samling av aksjar." ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path aksje:aksjer ],
        [ sh:class aksje:Eierskapstransaksjon ;
            sh:description "Samling av eigarskapstransaksjonar." ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path aksje:eierskapstransaksjoner ],
        [ sh:class aksje:Utbytte ;
            sh:description "Samling av utbytte." ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path aksje:utbytter ],
        [ sh:class aksje:Aksjeklasse ;
            sh:description "Samling av aksjeklasser." ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path aksje:aksjeklasser ],
        [ sh:class aksje:Selskapshendelse ;
            sh:description "Samling av selskapshendingar." ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path aksje:selskapshendelser ],
        [ sh:class aksje:Aksjeinnskudd ;
            sh:description "Samling av aksjeinnskot." ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path aksje:aksjeinnskudder ],
        [ sh:class aksje:Aksjeeierrettighet ;
            sh:description "Samling av aksjeeierrettigheiter." ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path aksje:aksjeeierrettigheter ] ;
    sh:targetClass schema1:Thing .

aksje:Tidspunkt a sh:NodeShape ;
    rdfs:comment "Tidspunkt for ei hending." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:date ;
            sh:description "Kalenderdato." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path aksje:dato ] ;
    sh:targetClass aksje:Tidspunkt .

aksje:Aksjeeier a sh:NodeShape ;
    rdfs:comment "Person eller organisasjon som eig aksjar." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class aksje:Eierposisjon ;
            sh:description "Eierposisjon aksjeeigaren har." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path aksje:har_eierposisjon ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Global identifikator for instansen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path aksje:identifikator ],
        [ sh:datatype xsd:string ;
            sh:description "Namn på instansen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path aksje:navn ] ;
    sh:targetClass aksje:Aksjeeier .

aksje:Aksjeeierrettighet a sh:NodeShape ;
    rdfs:comment "Rettigheiter knytt til aksjar, til dømes stemmerett." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "Global identifikator for instansen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path aksje:identifikator ],
        [ sh:class aksje:Aksjeklasse ;
            sh:description "Rettigheiter knytt til aksjeklassen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path aksje:gjelder_aksjer_i_aksjeklasse ],
        [ sh:datatype xsd:string ;
            sh:description "Tekstleg forklaring av instansen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path aksje:beskrivelse ] ;
    sh:targetClass aksje:Aksjeeierrettighet .

aksje:Aksjeselskap a sh:NodeShape ;
    rdfs:comment "Selskap som utsteder aksjar og har aksjekapital." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "Global identifikator for instansen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path aksje:identifikator ],
        [ sh:datatype xsd:string ;
            sh:description "Namn på instansen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path aksje:navn ],
        [ sh:class aksje:Aksjekapital ;
            sh:description "Aksjekapital som høyrer til selskapet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path aksje:har_aksjekapital ],
        [ sh:class aksje:Aksje ;
            sh:description "Aksje utstedt av selskapet" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path aksje:utsteder_aksje ] ;
    sh:targetClass aksje:Aksjeselskap .

aksje:Eierskapstransaksjon a sh:NodeShape ;
    rdfs:comment "Transaksjon som påverkar eigarskap i selskapet." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class aksje:Selskapshendelse ;
            sh:description "Selskapshendelse i transaksjonen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path aksje:kan_vaere_selskapshendelse ],
        [ sh:datatype xsd:date ;
            sh:description "Tidspunkt for utbytte/eierskapstransaksjon." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path aksje:tidspunkt ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Global identifikator for instansen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path aksje:identifikator ],
        [ sh:class aksje:Aksjeoverdragelse ;
            sh:description "Aksjeoverdraging i transaksjonen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path aksje:kan_vaere_aksjeoverdragelse ],
        [ sh:class aksje:Eierposisjon ;
            sh:description "Eierskapstransaksjon knytt til eigarposisjonen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path aksje:paavirker_eierposisjon ] ;
    sh:targetClass aksje:Eierskapstransaksjon .

aksje:InnbetaltAksjekapital a sh:NodeShape ;
    rdfs:comment "Innbetalt aksjekapital." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "Monetært beløp." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path aksje:belop ] ;
    sh:targetClass aksje:InnbetaltAksjekapital .

aksje:InnbetaltOverkurs a sh:NodeShape ;
    rdfs:comment "Innbetalt overkurs utover pålydande." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "Monetært beløp." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path aksje:belop ] ;
    sh:targetClass aksje:InnbetaltOverkurs .

aksje:Utbytte a sh:NodeShape ;
    rdfs:comment "Utbytte knytt til ein eigarposisjon." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class aksje:Eierposisjon ;
            sh:description "Utbytte knytt til eigarposisjonen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path aksje:er_basert_paa_eierposisjon ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Global identifikator for instansen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path aksje:identifikator ],
        [ sh:datatype xsd:date ;
            sh:description "Tidspunkt for utbytte/eierskapstransaksjon." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path aksje:tidspunkt ],
        [ sh:class aksje:Utdeling ;
            sh:description "Utdeling knytt til utbyttet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path aksje:har_utdeling ] ;
    sh:targetClass aksje:Utbytte .

aksje:Aksje a sh:NodeShape ;
    rdfs:comment "Ei enkelt aksje utstedt av eit aksjeselskap." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class aksje:Aksjeklasse ;
            sh:description "Klassen aksja høyrer til." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path aksje:tilhorer_aksjeklasse ],
        [ sh:datatype xsd:decimal ;
            sh:description "Pålydande verdi for aksja." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path aksje:har_palydende_belop ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Global identifikator for instansen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path aksje:identifikator ] ;
    sh:targetClass aksje:Aksje .

aksje:Aksjeinnskudd a sh:NodeShape ;
    rdfs:comment "Innskot knytt til aksjar i samband med selskapshending." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "Innbetalt overkurs." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path aksje:gjelder_innbetalt_overkurs ],
        [ sh:datatype xsd:decimal ;
            sh:description "Innbetalt aksjekapital." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path aksje:gjelder_innbetalt_aksjekapital ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Global identifikator for instansen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path aksje:identifikator ] ;
    sh:targetClass aksje:Aksjeinnskudd .

aksje:Aksjekapital a sh:NodeShape ;
    rdfs:comment "Den registrerte aksjekapitalen i eit aksjeselskap." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "Tal aksjar." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path aksje:har_antall_aksjer ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Global identifikator for instansen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path aksje:identifikator ] ;
    sh:targetClass aksje:Aksjekapital .

aksje:Aksjeoverdragelse a sh:NodeShape ;
    rdfs:comment "Overdraging av aksjar mellom partar." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "Global identifikator for instansen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path aksje:identifikator ],
        [ sh:class aksje:Vederlag ;
            sh:description "Vederlag for aksjeoverdraging." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path aksje:kan_ha_vederlag ] ;
    sh:targetClass aksje:Aksjeoverdragelse .

aksje:Aksjepost a sh:NodeShape ;
    rdfs:comment "Samling aksjar eigd av ein aksjeeigar." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:description "Tal aksjar." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path aksje:har_antall_aksjer ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Global identifikator for instansen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path aksje:identifikator ],
        [ sh:class aksje:Aksjeklasse ;
            sh:description "Rettigheiter knytt til aksjeklassen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path aksje:gjelder_aksjer_i_aksjeklasse ] ;
    sh:targetClass aksje:Aksjepost .

aksje:Selskapshendelse a sh:NodeShape ;
    rdfs:comment "Hending som påverkar selskapet sitt eigarskap eller kapital." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class aksje:Aksjeinnskudd ;
            sh:description "Aksjeinnskot i selskapshending." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path aksje:kan_ha_aksjeinnskudd ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Global identifikator for instansen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path aksje:identifikator ] ;
    sh:targetClass aksje:Selskapshendelse .

aksje:Utdeling a sh:NodeShape ;
    rdfs:comment "Konkret utdeling av verdiar til aksjeeigarar." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "Global identifikator for instansen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path aksje:identifikator ],
        [ sh:datatype xsd:decimal ;
            sh:description "Monetært beløp." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path aksje:belop ] ;
    sh:targetClass aksje:Utdeling .

aksje:Vederlag a sh:NodeShape ;
    rdfs:comment "Vederlag knytt til ei aksjeoverdraging." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:decimal ;
            sh:description "Monetært beløp." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path aksje:belop ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Global identifikator for instansen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path aksje:identifikator ] ;
    sh:targetClass aksje:Vederlag .

aksje:Aksjeklasse a sh:NodeShape ;
    rdfs:comment "Klasse aksjar høyrer til, med eigne rettigheiter." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Namn på instansen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path aksje:navn ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Global identifikator for instansen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path aksje:identifikator ] ;
    sh:targetClass aksje:Aksjeklasse .

aksje:Eierposisjon a sh:NodeShape ;
    rdfs:comment "Eierens samla posisjon i eit selskap." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class aksje:Aksjepost ;
            sh:description "Aksjepost som inngår i eigarposisjonen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path aksje:gjelder_aksjepost ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Global identifikator for instansen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path aksje:identifikator ] ;
    sh:targetClass aksje:Eierposisjon .


