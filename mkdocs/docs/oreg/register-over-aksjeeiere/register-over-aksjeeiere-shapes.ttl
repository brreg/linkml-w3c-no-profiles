            sh:description "Eierskapstransaksjon knytt til eigarposisjonen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:paavirker_eierposisjon> ] ;
    sh:targetClass <https://data.norge.no/linkml/register-over-aksjeeiere/:Eierskapstransaksjon> .

<https://data.norge.no/linkml/register-over-aksjeeiere/:InnbetaltAksjekapital> a sh:NodeShape ;
