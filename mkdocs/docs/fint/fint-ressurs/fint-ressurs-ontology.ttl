            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:bostedsadresse> ],
        <https://schema.fintlabs.no/:Aktoer> ;
    skos:definition "Fysiske private personar." ;
    skos:exactMatch fint:Person ;
    skos:inScheme <https://data.norge.no/fint/fint-common> .

<https://schema.fintlabs.no/:beskrivelse> a owl:DatatypeProperty ;
    rdfs:label "beskrivelse" ;
    rdfs:range xsd:string ;
    skos:definition "Beskriven namn eller omtale." ;
    skos:inScheme <https://data.norge.no/fint/fint-common> .

<https://schema.fintlabs.no/:Identifikator> a owl:Class ;
    rdfs:label "Identifikator" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:identifikatorverdi> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Periode> ;
            owl:onProperty <https://schema.fintlabs.no/:gyldighetsperiode> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:identifikatorverdi> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:gyldighetsperiode> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:identifikatorverdi> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:gyldighetsperiode> ] ;
    skos:definition "Unik identifikasjon til eit objekt." ;
    skos:exactMatch fint:Identifikator ;
    skos:inScheme <https://data.norge.no/fint/fint-common> .

<https://schema.fintlabs.no/:Periode> a owl:Class ;
    rdfs:label "Periode" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:slutt> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:beskrivelse> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://schema.fintlabs.no/:start> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:slutt> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty <https://schema.fintlabs.no/:slutt> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:beskrivelse> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:start> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:start> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:beskrivelse> ] ;
    skos:definition "Tidsperiode med obligatorisk start og valfri slutt." ;
    skos:exactMatch fint:Periode ;
    skos:inScheme <https://data.norge.no/fint/fint-common> .

<https://schema.fintlabs.no/:kode> a owl:DatatypeProperty ;
    rdfs:label "kode" ;
    rdfs:range xsd:string ;
    skos:definition "Verdi som identifiserer omgrepet." ;
    skos:inScheme <https://data.norge.no/fint/fint-common> .

<https://schema.fintlabs.no/:passiv> a owl:DatatypeProperty ;
    rdfs:label "passiv" ;
    rdfs:range xsd:boolean ;
    skos:definition "Angir at koden er passiv og ikkje kan veljast." ;
    skos:inScheme <https://data.norge.no/fint/fint-common> .

<https://schema.fintlabs.no/:gyldighetsperiode> a owl:ObjectProperty ;
    rdfs:label "gyldighetsperiode" ;
    rdfs:range <https://schema.fintlabs.no/:Periode> ;
    skos:definition "Periode ressursen er gyldig for." ;
    skos:inScheme <https://data.norge.no/fint/fint-common> .

<https://schema.fintlabs.no/:navn> a owl:DatatypeProperty ;
    rdfs:label "navn" ;
    rdfs:range xsd:string ;
    skos:definition "Hovudnamn for ressursen." ;
    skos:inScheme <https://data.norge.no/fint/fint-common> .

<https://schema.fintlabs.no/:id> a owl:DatatypeProperty ;
    rdfs:label "id" ;
    rdfs:range xsd:anyURI ;
    skos:definition "URI-identifikator for ressursen." ;
    skos:inScheme <https://data.norge.no/fint/fint-common> .


