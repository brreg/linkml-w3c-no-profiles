@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix fint: <https://schema.fintlabs.no/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pav: <http://purl.org/pav/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix res: <https://schema.fintlabs.no/ressurs/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://data.norge.no/fint/fint-ressurs.owl.ttl> a owl:Ontology ;
    rdfs:label "fint-ressurs" ;
    dcterms:title "FINT Ressurs" ;
    pav:version "4.0.20" ;
    skos:definition """FINT-domenemodell for ressursstyring. Dekkjer tre sub-pakkar: ressurs.eiendel (applikasjonar og lisensressursar), ressurs.datautstyr (digitale einingar og einingsgrupper) og ressurs.tilgang (identitetar og rettigheiter).
""" .

<https://schema.fintlabs.no/:Matrikkelnummer> a owl:Class ;
    rdfs:label "Matrikkelnummer" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:festenummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:festenummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:gaardsnummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:adresse> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:seksjonsnummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:seksjonsnummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:bruksnummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:kommunenummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:adresse> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:bruksnummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:seksjonsnummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Kommune> ;
            owl:onProperty <https://schema.fintlabs.no/:kommunenummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:kommunenummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:bruksnummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:gaardsnummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Adresse> ;
            owl:onProperty <https://schema.fintlabs.no/:adresse> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:festenummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:gaardsnummer> ] ;
    skos:definition "Eintydleg identifisering av matrikkeleining innanfor kommune." ;
    skos:exactMatch fint:Matrikkelnummer ;
    skos:inScheme <https://data.norge.no/fint/fint-common> .

<https://schema.fintlabs.no/:Valuta> a owl:Class ;
    rdfs:label "Valuta" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:nummerkode> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:bokstavkode> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Identifikator> ;
            owl:onProperty <https://schema.fintlabs.no/:bokstavkode> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:valuta_navn> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:bokstavkode> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:nummerkode> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:valuta_navn> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:valuta_navn> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Identifikator> ;
            owl:onProperty <https://schema.fintlabs.no/:nummerkode> ] ;
    skos:definition "Valutakodar for offisielle valutaer." ;
    skos:exactMatch fint:Valuta ;
    skos:inScheme <https://data.norge.no/fint/fint-common> .

<https://schema.fintlabs.no/ressurs/:RessursContainer> a owl:Class ;
    rdfs:label "RessursContainer" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:produsentar> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/ressurs/:Rettighet> ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:rettigheiter> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/ressurs/:Identitet> ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:identitetar> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/ressurs/:Enhetstype> ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:einingstypar> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/ressurs/:DigitalEnhet> ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:digitaleEiningar> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/ressurs/:Applikasjonskategori> ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:applikasjonskategoriar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:applikasjonskategoriar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:handhaevingstypar> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/ressurs/:Applikasjonsressurstilgjengelighet> ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:applikasjonsressurstilgjengelegheit> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/ressurs/:Applikasjon> ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:applikasjonar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:identitetar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:einingsgruppedmedlemskap> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:applikasjonar> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/ressurs/:Brukertype> ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:brukertypar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:einingstypar> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/ressurs/:Produsent> ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:produsentar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:lisensmodellar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:rettigheiter> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:einingsgrupper> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:digitaleEiningar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:brukertypar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:plattformar> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/ressurs/:Lisensmodell> ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:lisensmodellar> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/ressurs/:Plattform> ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:plattformar> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/ressurs/:Applikasjonsressurs> ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:applikasjonsressursar> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/ressurs/:Handhevingstype> ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:handhaevingstypar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:statusar> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/ressurs/:Status> ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:statusar> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/ressurs/:Enhetsgruppemedlemskap> ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:einingsgruppedmedlemskap> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:applikasjonsressursar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:applikasjonsressurstilgjengelegheit> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/ressurs/:Enhetsgruppe> ;
            owl:onProperty <https://schema.fintlabs.no/ressurs/:einingsgrupper> ] ;
    skos:definition "Rotcontainer for FINT Ressurs-instansar." ;
    skos:inScheme <https://data.norge.no/fint/fint-ressurs> .

<https://schema.fintlabs.no/:Virksomhet> a owl:Class ;
    rdfs:label "Virksomhet" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:virksomhetsId> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:laerling> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Identifikator> ;
            owl:onProperty <https://schema.fintlabs.no/:virksomhetsId> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:virksomhetsId> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://schema.fintlabs.no/:laerling> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        <https://schema.fintlabs.no/:Enhet> ;
    skos:definition "Ein juridisk organisasjon som produserer varer eller tenester." ;
    skos:exactMatch fint:Virksomhet ;
    skos:inScheme <https://data.norge.no/fint/fint-common> .

<https://schema.fintlabs.no/:Aktoer> a owl:Class ;
    rdfs:label "Aktoer" ;
    rdfs:subClassOf [ owl:unionOf ( <https://schema.fintlabs.no/:Enhet> <https://schema.fintlabs.no/:Person> ) ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:kontaktinformasjon> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Kontaktinformasjon> ;
            owl:onProperty <https://schema.fintlabs.no/:kontaktinformasjon> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Adresse> ;
            owl:onProperty <https://schema.fintlabs.no/:postadresse> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:postadresse> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:postadresse> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:kontaktinformasjon> ] ;
    skos:definition "Abstrakt base for person eller eining vi samhandlar med." ;
    skos:exactMatch fint:Aktoer ;
    skos:inScheme <https://data.norge.no/fint/fint-common> .

<https://schema.fintlabs.no/:Enhet> a owl:Class ;
    rdfs:label "Enhet" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:organisasjonsnavn> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:organisasjonsnavn> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Adresse> ;
            owl:onProperty <https://schema.fintlabs.no/:forretningsadresse> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:forretningsadresse> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:forretningsadresse> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:organisasjonsnummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:organisasjonsnummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Identifikator> ;
            owl:onProperty <https://schema.fintlabs.no/:organisasjonsnummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:organisasjonsnavn> ],
        <https://schema.fintlabs.no/:Aktoer>,
        <https://schema.fintlabs.no/:Virksomhet> ;
    skos:definition "Abstrakt base for alle hovudeiningar, undereiningar og organisasjonsledd identifisert med organisasjonsnummer." ;
    skos:exactMatch fint:Enhet ;
    skos:inScheme <https://data.norge.no/fint/fint-common> .

<https://schema.fintlabs.no/:Kontaktperson> a owl:Class ;
    rdfs:label "Kontaktperson" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:type> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Person> ;
            owl:onProperty <https://schema.fintlabs.no/:kontaktperson> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:kontaktinformasjon> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:type> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Kontaktinformasjon> ;
            owl:onProperty <https://schema.fintlabs.no/:kontaktinformasjon> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:kontaktperson_navn> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:kontaktperson_navn> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:type> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:kontaktinformasjon> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Personnavn> ;
            owl:onProperty <https://schema.fintlabs.no/:kontaktperson_navn> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:kontaktperson> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:id> ] ;
    skos:definition "Kontaktperson (pårørande) til ein person." ;
    skos:exactMatch fint:Kontaktperson ;
    skos:inScheme <https://data.norge.no/fint/fint-common> .

<https://schema.fintlabs.no/:adresselinje> a owl:DatatypeProperty ;
    rdfs:label "adresselinje" ;
    rdfs:range xsd:string ;
    skos:definition "Adresseinformasjon." ;
    skos:inScheme <https://data.norge.no/fint/fint-common> .

<https://schema.fintlabs.no/:foreldre> a owl:ObjectProperty ;
    rdfs:label "foreldre" ;
    rdfs:range <https://schema.fintlabs.no/:Person> ;
    skos:definition "Den/dei som har foreldreansvar til personen." ;
    skos:inScheme <https://data.norge.no/fint/fint-common> .

<https://schema.fintlabs.no/:foreldreansvar> a owl:ObjectProperty ;
    rdfs:label "foreldreansvar" ;
    rdfs:range <https://schema.fintlabs.no/:Person> ;
    skos:definition "Personar denne personen har foreldreansvar for." ;
    skos:inScheme <https://data.norge.no/fint/fint-common> .

<https://schema.fintlabs.no/:kontaktperson> a owl:ObjectProperty ;
    rdfs:label "kontaktperson" ;
    rdfs:range <https://schema.fintlabs.no/:Person> ;
    skos:definition "Personar kontaktpersonen er pårørande for." ;
    skos:inScheme <https://data.norge.no/fint/fint-common> .

<https://schema.fintlabs.no/:parorende> a owl:ObjectProperty ;
    rdfs:label "parorende" ;
    rdfs:range <https://schema.fintlabs.no/:Kontaktperson> ;
    skos:definition "Pårørande kontaktperson til personen." ;
    skos:inScheme <https://data.norge.no/fint/fint-common> .

<https://schema.fintlabs.no/:statsborgerskap> a owl:ObjectProperty ;
    rdfs:label "statsborgerskap" ;
    rdfs:range <https://schema.fintlabs.no/:Landkode> ;
    skos:definition "Alle statsborgarskap personen har." ;
    skos:inScheme <https://data.norge.no/fint/fint-common> .

<https://schema.fintlabs.no/ressurs/:applikasjonar> a owl:ObjectProperty ;
    rdfs:label "applikasjonar" ;
    skos:inScheme <https://data.norge.no/fint/fint-ressurs> .

<https://schema.fintlabs.no/ressurs/:applikasjonskategori> a owl:ObjectProperty ;
    rdfs:label "applikasjonskategori" ;
    rdfs:range <https://schema.fintlabs.no/ressurs/:Applikasjonskategori> ;
    skos:definition "Kategoriar av applikasjonar." ;
    skos:inScheme <https://data.norge.no/fint/fint-ressurs> .

<https://schema.fintlabs.no/ressurs/:applikasjonskategoriar> a owl:ObjectProperty ;
    rdfs:label "applikasjonskategoriar" ;
    skos:inScheme <https://data.norge.no/fint/fint-ressurs> .

<https://schema.fintlabs.no/ressurs/:applikasjonsressurs> a owl:ObjectProperty ;
    rdfs:label "applikasjonsressurs" ;
    rdfs:range <https://schema.fintlabs.no/ressurs/:Applikasjonsressurs> ;
    skos:definition "Ulike ressursar (lisensar) knytt til ein applikasjon." ;
    skos:inScheme <https://data.norge.no/fint/fint-ressurs> .

<https://schema.fintlabs.no/ressurs/:applikasjonsressursar> a owl:ObjectProperty ;
    rdfs:label "applikasjonsressursar" ;
    skos:inScheme <https://data.norge.no/fint/fint-ressurs> .

<https://schema.fintlabs.no/ressurs/:applikasjonsressurstilgjengelegheit> a owl:ObjectProperty ;
    rdfs:label "applikasjonsressurstilgjengelegheit" ;
    skos:inScheme <https://data.norge.no/fint/fint-ressurs> .

<https://schema.fintlabs.no/ressurs/:brukertypar> a owl:ObjectProperty ;
    rdfs:label "brukertypar" ;
    skos:inScheme <https://data.norge.no/fint/fint-ressurs> .

<https://schema.fintlabs.no/ressurs/:brukertype> a owl:ObjectProperty ;
    rdfs:label "brukertype" ;
    rdfs:range <https://schema.fintlabs.no/ressurs/:Brukertype> ;
