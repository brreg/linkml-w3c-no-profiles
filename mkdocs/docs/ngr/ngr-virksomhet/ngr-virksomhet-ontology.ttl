    rdfs:range xsd:date ;
    skos:definition "Datoen hovudeininga vart stifta." ;
    skos:inScheme <https://data.norge.no/linkml/ngr-virksomhet> .

<https://data.norge.no/linkml/ngr-virksomhet/telefonnummer> a owl:DatatypeProperty ;
    rdfs:label "telefonnummer" ;
    rdfs:range xsd:string ;
    skos:definition "Telefonnummer for verksemda." ;
    skos:inScheme <https://data.norge.no/linkml/ngr-virksomhet> .

<https://data.norge.no/linkml/ngr-virksomhet/tilstandstype> a owl:ObjectProperty ;
    rdfs:label "tilstandstype" ;
    rdfs:range <https://data.norge.no/linkml/ngr-virksomhet/:TilstandType> ;
    skos:definition "Type tilstand (AKTIV, UNDER_KONKURS o.l.)." ;
    skos:inScheme <https://data.norge.no/linkml/ngr-virksomhet> .

<https://data.norge.no/linkml/ngr-virksomhet/utoevar_aktivitet> a owl:ObjectProperty ;
    rdfs:label "utoevar_aktivitet" ;
    rdfs:range <https://data.norge.no/linkml/ngr-virksomhet/Aktivitet> ;
    skos:definition "Aktiviteten hovudeininga utøver." ;
    skos:inScheme <https://data.norge.no/linkml/ngr-virksomhet> .

<https://data.norge.no/linkml/ngr-virksomhet/varslingstype> a owl:ObjectProperty ;
    rdfs:label "varslingstype" ;
    rdfs:range <https://data.norge.no/linkml/ngr-virksomhet/:VarslingType> ;
    skos:definition "Kanaltype for varsling (EPOST eller MOBILTELEFON)." ;
    skos:inScheme <https://data.norge.no/linkml/ngr-virksomhet> .

<https://data.norge.no/linkml/ngr-virksomhet/varslingsverdi> a owl:DatatypeProperty ;
    rdfs:label "varslingsverdi" ;
    rdfs:range xsd:string ;
    skos:definition "Verdien for varslingskanalen (e-postadresse eller mobilnummer)." ;
    skos:inScheme <https://data.norge.no/linkml/ngr-virksomhet> .

<https://data.norge.no/linkml/ngr-virksomhet/:VarslingType> a owl:Class ;
    rdfs:label "VarslingType" ;
    owl:unionOf ( <https://data.norge.no/linkml/ngr-virksomhet/:VarslingType#EPOST> <https://data.norge.no/linkml/ngr-virksomhet/:VarslingType#MOBILTELEFON> ) ;
    skos:definition "Kanaltype for varsling til verksemda." ;
    skos:inScheme <https://data.norge.no/linkml/ngr-virksomhet> ;
    linkml:permissible_values <https://data.norge.no/linkml/ngr-virksomhet/:VarslingType#EPOST>,
        <https://data.norge.no/linkml/ngr-virksomhet/:VarslingType#MOBILTELEFON> .

<https://data.norge.no/linkml/ngr-virksomhet/:TilstandType> a owl:Class ;
    rdfs:label "TilstandType" ;
    owl:unionOf ( <https://data.norge.no/linkml/ngr-virksomhet/:TilstandType#AKTIV> <https://data.norge.no/linkml/ngr-virksomhet/:TilstandType#UNDER_TVANGSAVVIKLING> <https://data.norge.no/linkml/ngr-virksomhet/:TilstandType#UNDER_KONKURS> <https://data.norge.no/linkml/ngr-virksomhet/:TilstandType#AVVIKLET> <https://data.norge.no/linkml/ngr-virksomhet/:TilstandType#SLETTET> <https://data.norge.no/linkml/ngr-virksomhet/:TilstandType#OPPL%C3%98ST> ) ;
    skos:definition "Status for ei verksemd registrert i Enhetsregisteret." ;
    skos:inScheme <https://data.norge.no/linkml/ngr-virksomhet> ;
    linkml:permissible_values <https://data.norge.no/linkml/ngr-virksomhet/:TilstandType#AKTIV>,
        <https://data.norge.no/linkml/ngr-virksomhet/:TilstandType#AVVIKLET>,
        <https://data.norge.no/linkml/ngr-virksomhet/:TilstandType#OPPL%C3%98ST>,
        <https://data.norge.no/linkml/ngr-virksomhet/:TilstandType#SLETTET>,
        <https://data.norge.no/linkml/ngr-virksomhet/:TilstandType#UNDER_KONKURS>,
        <https://data.norge.no/linkml/ngr-virksomhet/:TilstandType#UNDER_TVANGSAVVIKLING> .

<https://data.norge.no/linkml/ngr-virksomhet/:RolleType> a owl:Class ;
    rdfs:label "RolleType" ;
    owl:unionOf ( <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#DAGLIG_LEDER> <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#STYRELEDER> <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#STYREMEDLEM> <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#VARAMEDLEM> <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#KONTAKTPERSON> <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#KOMPLEMENTAR> <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#DELTAKER> <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#BESTYRENDE_REDAKTOR> <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#FORRETNINGSFORER> <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#REVISOR> <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#REGNSKAPSFORER> <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#NORSK_REPRESENTANT> ) ;
    skos:definition "Type rolle ein person eller eining kan ha i ei verksemd." ;
    skos:inScheme <https://data.norge.no/linkml/ngr-virksomhet> ;
    linkml:permissible_values <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#BESTYRENDE_REDAKTOR>,
        <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#DAGLIG_LEDER>,
        <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#DELTAKER>,
        <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#FORRETNINGSFORER>,
        <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#KOMPLEMENTAR>,
        <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#KONTAKTPERSON>,
        <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#NORSK_REPRESENTANT>,
        <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#REGNSKAPSFORER>,
        <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#REVISOR>,
        <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#STYRELEDER>,
        <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#STYREMEDLEM>,
        <https://data.norge.no/linkml/ngr-virksomhet/:RolleType#VARAMEDLEM> .

<https://data.norge.no/linkml/ngr-virksomhet/id> a owl:DatatypeProperty ;
    rdfs:label "id" ;
    rdfs:range xsd:anyURI ;
    skos:definition "URI-identifikator for ressursen." ;
    skos:inScheme <https://data.norge.no/linkml/ngr-virksomhet> .


