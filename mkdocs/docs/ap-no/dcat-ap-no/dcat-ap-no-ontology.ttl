@prefix adms: <http://www.w3.org/ns/adms#> .
@prefix cv: <http://data.europa.eu/m8g/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix eli: <http://data.europa.eu/eli/ontology#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ns1: <https://data.norge.no/ap-no/dcat-ap-no/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pav: <http://purl.org/pav/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix spdx: <http://spdx.org/rdf/terms#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://data.norge.no/ap-no/common-ap-no/anbefalt_term> a owl:DatatypeProperty ;
    rdfs:label "anbefalt_term" ;
    rdfs:range rdf:langString ;
    skos:definition "Føretrukke term/namn for ressursen (skos:prefLabel)." ;
    skos:inScheme <https://data.norge.no/ap-no/common-ap-no> .

<https://data.norge.no/ap-no/dcat-ap-no.owl.ttl> a owl:Ontology ;
    rdfs:label "dcat-ap-no" ;
    dct:title "DCAT-AP-NO" ;
    pav:version "2.0" ;
    skos:definition "Norsk applikasjonsprofil av DCAT-AP, modellert i LinkML med lenking framfor inlining. Basert på https://informasjonsforvaltning.github.io/dcat-ap-no/" .

ns1:referanse a owl:DatatypeProperty ;
    rdfs:label "referanse" ;
    rdfs:range xsd:anyURI ;
    skos:definition "Referanse til ekstern ressurs." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:tittel_literal a owl:DatatypeProperty ;
    rdfs:label "tittel_literal" ;
    rdfs:range xsd:string ;
    skos:definition "Namn/tittel utan språktag." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

<https://data.norge.no/ap-no/dqv-ap-no/Brukartilbakemelding> a owl:Class ;
    rdfs:label "Brukartilbakemelding" ;
    rdfs:subClassOf <https://data.norge.no/ap-no/dqv-ap-no/Kvalitetsmerknad> ;
    skos:definition "Tilbakemelding frå ein brukar om kvaliteten til eit datasett." ;
    skos:exactMatch <http://www.w3.org/ns/dqv#UserQualityFeedback> ;
    skos:inScheme <https://data.norge.no/ap-no/dqv-ap-no> .

<https://data.norge.no/ap-no/dqv-ap-no/Kvalitetssertifikat> a owl:Class ;
    rdfs:label "Kvalitetssertifikat" ;
    rdfs:subClassOf <https://data.norge.no/ap-no/dqv-ap-no/Kvalitetsmerknad> ;
    skos:definition "Eit sertifikat som stadfester kvaliteten til eit datasett." ;
    skos:exactMatch <http://www.w3.org/ns/dqv#QualityCertificate> ;
    skos:inScheme <https://data.norge.no/ap-no/dqv-ap-no> .

xsd:duration a rdfs:Datatype .

xsd:gYear a rdfs:Datatype .

xsd:nonNegativeInteger a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:onDatatype xsd:integer ;
            owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] .

<https://data.norge.no/ap-no/common-ap-no/Begrepssamling> a owl:Class ;
    rdfs:label "Begrepssamling" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ] ;
    skos:definition "Ei SKOS-omgrepssamling (temavokabular)." ;
    skos:exactMatch skos:ConceptScheme ;
    skos:inScheme <https://data.norge.no/ap-no/common-ap-no> .

<https://data.norge.no/ap-no/common-ap-no/heimeside> a owl:DatatypeProperty ;
    rdfs:label "heimeside" ;
    rdfs:range xsd:anyURI ;
    skos:definition "Heimeside for ressursen eller organisasjonen (foaf:homepage)." ;
    skos:inScheme <https://data.norge.no/ap-no/common-ap-no> .

ns1:Gebyr a owl:Class ;
    rdfs:label "Gebyr" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ap-no/common-ap-no/Konsept> ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/valuta> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/valuta> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ns1:belop ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ns1:belop ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ns1:dokumentasjon ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty ns1:dokumentasjon ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/beskrivelse> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ns1:belop ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdf:langString ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/beskrivelse> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/valuta> ] ;
    skos:definition "Eit gebyr knytt til bruk av ein datatjeneste." ;
    skos:exactMatch cv:Cost ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:Identifikator a owl:Class ;
    rdfs:label "Identifikator" ;
    rdfs:seeAlso <https://data.norge.no/concepts/806b0e3a-38ab-3a3a-88d6-ddc7f8669f4a> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ns1:notasjon ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ns1:notasjon ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ns1:notasjon ] ;
    skos:definition "Ein alternativ identifikator for ein ressurs." ;
    skos:exactMatch adms:Identifier ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:Katalogpost a owl:Class ;
    rdfs:label "Katalogpost" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom dct:language ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/spraak> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/utgivelsesdato> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ns1:primaertema ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/status> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ns1:kilde_post ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/spraak> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ap-no/common-ap-no/Konsept> ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/status> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/endringsdato> ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdf:langString ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/tittel> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ns1:kilde_post ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ns1:primaertema ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/utgivelsesdato> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/endringsdato> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/tittel> ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdf:langString ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/beskrivelse> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty ns1:i_samsvar_med ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/beskrivelse> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/status> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ap-no/dqv-ap-no/Standard> ;
            owl:onProperty ns1:i_samsvar_med ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty ns1:kilde_post ],
        [ a owl:Restriction ;
            owl:allValuesFrom ns1:KatalogisertRessurs ;
            owl:onProperty ns1:primaertema ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/utgivelsesdato> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/endringsdato> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ] ;
    skos:definition "Ein katalogpost som beskriv ein ressurs i katalogen." ;
    skos:exactMatch dcat:CatalogRecord ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:Relasjon a owl:Class ;
    rdfs:label "Relasjon" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ns1:har_rolle ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ns1:relasjon_til ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty ns1:relasjon_til ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ns1:har_rolle ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ns1:relasjon_til ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ns1:har_rolle ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ] ;
    skos:definition "Ein kvalifisert relasjon mellom to ressursar." ;
    skos:exactMatch dcat:Relationship ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:Sjekksum a owl:Class ;
    rdfs:label "Sjekksum" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ns1:algoritme ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ns1:sjekksumverdi ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ns1:algoritme ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty ns1:algoritme ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty ns1:sjekksumverdi ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty ns1:sjekksumverdi ] ;
    skos:definition "Ein sjekksum for ein distribusjon." ;
    skos:exactMatch spdx:Checksum ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:annen_ansvarlig_aktor a owl:DatatypeProperty ;
    rdfs:label "annen_ansvarlig_aktor" ;
    rdfs:range xsd:string ;
    skos:definition "Kvalifisert attributering til ansvarleg aktør." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> ;
    ns1:gyldige_verdier "prov:Attribution" .

ns1:annen_identifikator a owl:ObjectProperty ;
    rdfs:label "annen_identifikator" ;
    rdfs:range ns1:Identifikator ;
    skos:definition "Alternativ identifikator frå eit anna system." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:annen_spesifikk_relasjon a owl:ObjectProperty ;
    rdfs:label "annen_spesifikk_relasjon" ;
    rdfs:range ns1:Relasjon ;
    skos:definition "Kvalifisert relasjon til ein annan ressurs." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:begrep a owl:DatatypeProperty ;
    rdfs:label "begrep" ;
    rdfs:range xsd:string ;
    skos:definition "Fagomgrep som datasettet handlar om." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:ble_generert_ved a owl:DatatypeProperty ;
    rdfs:label "ble_generert_ved" ;
    rdfs:domain ns1:Datasett ;
    rdfs:range xsd:anyURI ;
    skos:definition "Brukes til å referere til en aktivitet som genererte datasettet, eller som gir forretningskontekst for oppretting av det." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> ;
    ns1:gyldige_verdier "URI til prov:Activity" .

ns1:datasett a owl:ObjectProperty ;
    rdfs:label "datasett" ;
    rdfs:range ns1:Datasett ;
    skos:definition "Datasett som er del av katalogen." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:datasettdistribusjon a owl:ObjectProperty ;
    rdfs:label "datasettdistribusjon" ;
    rdfs:range ns1:Distribusjon ;
    skos:definition "Tilgjengelege distribusjonar av datasettet." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:datatjeneste a owl:ObjectProperty ;
    rdfs:label "datatjeneste" ;
    rdfs:range ns1:Datatjeneste ;
    skos:definition "Datatjeneste som er del av katalogen." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:eierskapshistorikk a owl:DatatypeProperty ;
    rdfs:label "eierskapshistorikk" ;
    rdfs:range xsd:string ;
    skos:definition "Opphav og eigarskapshistorikk for ressursen." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> ;
    ns1:gyldige_verdier "dct:ProvenanceStatement" .

ns1:eksempeldata a owl:ObjectProperty ;
    rdfs:label "eksempeldata" ;
    rdfs:range ns1:Distribusjon ;
    skos:definition "Eksempeldata som distribusjon." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:endepunkts_url a owl:DatatypeProperty ;
    rdfs:label "endepunkts_url" ;
    rdfs:range xsd:anyURI ;
    skos:definition "URL til datatjenestens endepunkt." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:endepunktsbeskrivelse a owl:DatatypeProperty ;
    rdfs:label "endepunktsbeskrivelse" ;
    rdfs:range xsd:anyURI ;
    skos:definition "URL til beskriving av endepunktet (t.d. OpenAPI-dokument)." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:har_del a owl:ObjectProperty ;
    rdfs:label "har_del" ;
    rdfs:range ns1:Katalog ;
    skos:definition "Delkatalog inkludert i denne katalogen." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:har_gebyr a owl:ObjectProperty ;
    rdfs:label "har_gebyr" ;
    rdfs:range ns1:Gebyr ;
    skos:definition "Gebyr knytt til bruk av datatjenesten." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:har_kvalitetsmerknad a owl:ObjectProperty ;
    rdfs:label "har_kvalitetsmerknad" ;
    rdfs:range <https://data.norge.no/ap-no/dqv-ap-no/Kvalitetsmerknad> ;
    skos:definition "Kvalitetsmerknad knytt til datasettet." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:i_serie a owl:ObjectProperty ;
    rdfs:label "i_serie" ;
    rdfs:range ns1:Datasettserie ;
    skos:definition "Datasettserie dette datasettet er ein del av." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:katalogpost a owl:ObjectProperty ;
    rdfs:label "katalogpost" ;
    rdfs:range ns1:Katalogpost ;
    skos:definition "Katalogpostar i katalogen." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:kilde_datasett a owl:ObjectProperty ;
    rdfs:label "kilde_datasett" ;
    rdfs:range ns1:Datasett ;
    skos:definition "Datasett dette datasettet er avleidd frå." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:navn_aktor a owl:DatatypeProperty ;
    rdfs:label "navn_aktor" ;
    rdfs:range rdf:langString ;
    skos:definition "Namn på aktøren." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:navn_vcard a owl:DatatypeProperty ;
    rdfs:label "navn_vcard" ;
    rdfs:range rdf:langString ;
    skos:definition "Formatert namn (vCard)." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:nedlastningslenke a owl:DatatypeProperty ;
    rdfs:label "nedlastningslenke" ;
    rdfs:range xsd:anyURI ;
    skos:definition "Direkte nedlastingslenke for distribusjonsfila." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:relatert_regulativ_ressurs a owl:ObjectProperty ;
    rdfs:label "relatert_regulativ_ressurs" ;
    rdfs:range ns1:RegulativRessurs ;
    skos:definition "Relatert regulativ ressurs." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:relatert_ressurs a owl:DatatypeProperty ;
    rdfs:label "relatert_ressurs" ;
    rdfs:range xsd:anyURI ;
    skos:definition "Generisk relasjon til ein annan ressurs." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:temaer a owl:ObjectProperty ;
    rdfs:label "temaer" ;
    rdfs:range <https://data.norge.no/ap-no/common-ap-no/Begrepssamling> ;
    skos:definition "Temavokabular som vert brukt i katalogen." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:tilgangs_url a owl:DatatypeProperty ;
    rdfs:label "tilgangs_url" ;
    rdfs:range xsd:anyURI ;
    skos:definition "URL for tilgang til distribusjonen." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:tilgangstjeneste a owl:ObjectProperty ;
    rdfs:label "tilgangstjeneste" ;
    rdfs:range ns1:Datatjeneste ;
    skos:definition "Datatjeneste som gjev tilgang til distribusjonen." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:tilgjengeliggjor_datasett a owl:ObjectProperty ;
    rdfs:label "tilgjengeliggjor_datasett" ;
    rdfs:range ns1:Datasett ;
    skos:definition "Datasett som datatjenesten tilgjengeleggjer." ;
    skos:inScheme <https://data.norge.no/ap-no/dcat-ap-no> .

ns1:underkatalog a owl:ObjectProperty ;
