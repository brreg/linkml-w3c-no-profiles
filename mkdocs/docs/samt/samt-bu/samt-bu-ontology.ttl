            owl:maxCardinality 1 ;
            owl:onProperty samtbuskole:organisasjonsnummer ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty samtbuskole:organisasjonsnummer ],
        samtbuskole:Skoleeier ;
    skos:definition "Virksomhet, eller foretak, er betegnelser for en juridisk person eller en organisasjon som produserer varer eller tjenester." ;
    skos:exactMatch <http://schema.org/Organization>,
        org:Organization ;
    skos:inScheme <https://example.no/ontology/samt-bu-skole> .

