@prefix cpsv: <http://purl.org/vocab/cpsv#> .
@prefix cpsvno: <https://data.norge.no/vocabulary/cpsvno#> .
@prefix cv: <http://data.europa.eu/m8g/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcatno: <https://data.norge.no/vocabulary/dcatno#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix eli: <http://data.europa.eu/eli/ontology#> .
@prefix ns1: <https://data.norge.no/linkml/cpsv-ap-no-fixture/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.org/katalogar/nav-tenestekatalog> a dcat:Catalog ;
    cv:contactPoint <https://example.org/kontaktpunkt/nav-hovud> ;
    dct:description "Oversikt over NAV sine offentlege tenester."^^rdf:langString ;
    dct:identifier "nav-tenestekatalog-2024" ;
    dct:publisher <https://example.org/organisasjonar/nav> ;
    dct:title "NAV Tenestekatalog"^^rdf:langString ;
    dcatno:containsService <https://example.org/tenestar/dagpenger> .

<https://example.org/regelverk/folketrygdlova-kap4> a eli:LegalResource ;
    dct:identifier "LOV-1997-02-28-19-K4" ;
    dct:title "Folketrygdlova kapittel 4 – Dagpengar ved arbeidsløyse"^^rdf:langString .

<https://example.org/kanalar/nav-nett> a cv:Channel ;
    dct:identifier "nav-kanal-nett" ;
    vcard:hasURL "https://www.nav.no/dagpenger"^^xsd:anyURI .

<https://example.org/kanalar/nav-telefon> a cv:Channel ;
    cv:openingHours "Mo-Fr 08:00-15:30" ;
    dct:identifier "nav-kanal-telefon" .

<https://example.org/resultattypar/dagpengar-vedtak> a cpsvno:OutputType ;
    dct:description "Eit vedtak som innvilgar eller avslår søknad om dagpengar."^^rdf:langString ;
    dct:title "Vedtak om dagpengar"^^rdf:langString ;
    cpsvno:possibleLanguage "http://publications.europa.eu/resource/authority/language/NNO"^^dct:language,
        "http://publications.europa.eu/resource/authority/language/NOB"^^dct:language .

<https://example.org/tenestar/dagpenger> a cpsv:PublicService ;
    cv:contactPoint <https://example.org/kontaktpunkt/nav-hovud> ;
    cv:hasChannel <https://example.org/kanalar/nav-nett>,
        <https://example.org/kanalar/nav-telefon> ;
    cv:hasCompetentAuthority <https://example.org/organisasjonar/nav> ;
    dct:description "Teneste for å søkje om dagpengar ved arbeidsløyse."^^rdf:langString ;
    dct:identifier "nav-dagpenger-2024" ;
    dct:title "Søk om dagpengar"^^rdf:langString ;
    cpsvno:hasOutputType <https://example.org/resultattypar/dagpengar-vedtak> .

<https://example.org/kontaktpunkt/nav-hovud> a cv:ContactPoint ;
    cv:contactPage "https://www.nav.no/kontakt-oss"^^xsd:anyURI ;
    cv:telephone "55553333" .

<https://example.org/organisasjonar/nav> a cv:PublicOrganisation ;
    dct:identifier "974652269" ;
    dct:spatial <http://publications.europa.eu/resource/authority/country/NOR> ;
    dct:title "NAV"^^rdf:langString ;
    skos:prefLabel "Arbeids- og velferdsetaten"^^rdf:langString .

[] a ns1:Container ;
    ns1:katalogar <https://example.org/katalogar/nav-tenestekatalog> ;
    ns1:kontaktpunkt <https://example.org/kontaktpunkt/nav-hovud> ;
    ns1:offentligeOrganisasjonar <https://example.org/organisasjonar/nav> ;
    ns1:offentligeTenestar <https://example.org/tenestar/dagpenger> ;
    ns1:regulativeRessursar <https://example.org/regelverk/folketrygdlova-kap4> ;
    ns1:tenestekanalar <https://example.org/kanalar/nav-nett>,
        <https://example.org/kanalar/nav-telefon> ;
    ns1:tenesteresultattypar <https://example.org/resultattypar/dagpengar-vedtak> .

