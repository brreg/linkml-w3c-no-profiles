adms:Identifier a sh:NodeShape ;
    rdfs:comment "Ein alternativ identifikator for ein ressurs." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
