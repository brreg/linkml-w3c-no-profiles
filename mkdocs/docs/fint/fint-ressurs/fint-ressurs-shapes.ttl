            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/:id> ],
        [ sh:datatype xsd:string ;
            sh:description "Verdi som identifiserer omgrepet." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path fint:kode ],
        [ sh:datatype xsd:string ;
            sh:description "Hovudnamn for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path fint:navn ] ;
    sh:targetClass res:Handhevingstype .

res:Identitet a sh:NodeShape ;
    rdfs:comment "Identitet som identifiserer innehavaren av rettigheiter i organisasjonen." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Referanse til Personalressurs (Administrasjon)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path res:personalressurs ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/:id> ],
        [ sh:class res:Rettighet ;
            sh:description "Rettigheiter knytt til identiteten." ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path res:rettighet ] ;
    sh:targetClass res:Identitet .

res:Lisensmodell a sh:NodeShape ;
    rdfs:comment "Lisensmodellar som kan knytast til ein lisens." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
