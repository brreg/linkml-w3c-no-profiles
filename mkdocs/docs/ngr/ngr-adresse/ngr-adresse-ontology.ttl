@prefix dct: <http://purl.org/dc/terms/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix locn: <http://www.w3.org/ns/locn#> .
@prefix ngr: <https://data.norge.no/vocabulary/ngr-adresse#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://data.norge.no/linkml/ngr-adresse.owl.ttl> a owl:Ontology ;
    rdfs:label "ngr-adresse" ;
    dct:title "Nasjonale grunndata – Adresse" ;
    skos:definition "Domenemodell for norske adressar basert på Nasjonale grunndata (utkast). Modellerer Offisiell adresse og Postboksadresse med tilhøyrande geografiske inndelingar og adressekomponentar. Basert på https://informasjonsforvaltning.github.io/nasjonale-grunndata/#Adresse" .

<https://data.norge.no/linkml/ngr-adresse/AdresseContainer> a owl:Class ;
    rdfs:label "AdresseContainer" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Poststed> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/poststeder> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/representasjonspunkt> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/bygningar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/bruksenhetsnummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/fylke> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Kirkesokn> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/kirkesokn> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/KommunalKrets> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/kommunaleKretsar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adressenavn> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Fylke> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/fylke> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adresseomrader> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/postboksar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/svalbardOmrader> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Representasjonspunkt> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/representasjonspunkt> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Postboks> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/postboksar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/bruksenheter> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Bygning> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/bygningar> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Svalbard> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/svalbardOmrader> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Kommune> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/kommunar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/stemmekretsar> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Adressenavn> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adressenavn> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/tettstadar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/kommunaleKretsar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/grunnkretsar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/kommunar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/husnummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Stemmekrets> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/stemmekretsar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/kirkesokn> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adressekoder> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Bruksenhet> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/bruksenheter> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/OffisiellAdresse> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/offisielleAdresser> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Grunnkrets> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/grunnkretsar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/poststeder> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Adresseomrade> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adresseomrader> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/postboksadresser> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Adressekode> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adressekoder> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Husnummer> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/husnummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Postboksadresse> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/postboksadresser> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Tettsted> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/tettstadar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/offisielleAdresser> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Bruksenhetsnummer> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/bruksenhetsnummer> ] ;
    skos:definition "Rotklasse for NGR-adresse-datafiler. Held flate lister av alle instansierbare klassar; referansar mellom objekt brukar URI-lenking." ;
    skos:inScheme <https://data.norge.no/linkml/ngr-adresse> .

<https://data.norge.no/linkml/ngr-adresse/:Etasjeplan#H> a owl:Class ;
    rdfs:label "H" ;
    rdfs:subClassOf <https://data.norge.no/linkml/ngr-adresse/:Etasjeplan> ;
    skos:definition "Høgde (over bakkenivå)" .

<https://data.norge.no/linkml/ngr-adresse/:Etasjeplan#K> a owl:Class ;
    rdfs:label "K" ;
    rdfs:subClassOf <https://data.norge.no/linkml/ngr-adresse/:Etasjeplan> ;
    skos:definition "Kjellar" .

<https://data.norge.no/linkml/ngr-adresse/:Etasjeplan#L> a owl:Class ;
    rdfs:label "L" ;
    rdfs:subClassOf <https://data.norge.no/linkml/ngr-adresse/:Etasjeplan> ;
    skos:definition "Loft" .

<https://data.norge.no/linkml/ngr-adresse/:Etasjeplan#M> a owl:Class ;
    rdfs:label "M" ;
    rdfs:subClassOf <https://data.norge.no/linkml/ngr-adresse/:Etasjeplan> ;
    skos:definition "Mesanin" .

<https://data.norge.no/linkml/ngr-adresse/:Etasjeplan#U> a owl:Class ;
    rdfs:label "U" ;
    rdfs:subClassOf <https://data.norge.no/linkml/ngr-adresse/:Etasjeplan> ;
    skos:definition "Under bakkenivå" .

<https://data.norge.no/linkml/ngr-adresse/Fylke> a owl:Class ;
    rdfs:label "Fylke" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/fylkesnummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/fylkesnummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/fylkesnummer> ],
        <https://data.norge.no/linkml/ngr-adresse/GeografiskOmrade> ;
    skos:definition "Eit norsk fylke." ;
    skos:exactMatch ngr:Fylke ;
    skos:inScheme <https://data.norge.no/linkml/ngr-adresse> .

<https://data.norge.no/linkml/ngr-adresse/GeografiskAdresse> a owl:Class ;
    rdfs:label "GeografiskAdresse" ;
    rdfs:subClassOf [ owl:unionOf ( <https://data.norge.no/linkml/ngr-adresse/OffisiellAdresse> <https://data.norge.no/linkml/ngr-adresse/Postboksadresse> ) ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/id> ] ;
    skos:definition "Abstrakt basisklasse for norske adressar. Konkrete subklassar er OffisiellAdresse og Postboksadresse." ;
    skos:exactMatch locn:Address ;
    skos:inScheme <https://data.norge.no/linkml/ngr-adresse> .

<https://data.norge.no/linkml/ngr-adresse/Grunnkrets> a owl:Class ;
    rdfs:label "Grunnkrets" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/grunnkretsnummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/grunnkretsnummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/grunnkretsnummer> ],
        <https://data.norge.no/linkml/ngr-adresse/GeografiskOmrade> ;
    skos:definition "Ei grunnkrets – minste geografiske eining i statistisk inndeling." ;
    skos:exactMatch ngr:Grunnkrets ;
    skos:inScheme <https://data.norge.no/linkml/ngr-adresse> .

<https://data.norge.no/linkml/ngr-adresse/Kirkesokn> a owl:Class ;
    rdfs:label "Kirkesokn" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/kirkesoknnummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/kirkesoknnummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/kirkesoknnummer> ],
        <https://data.norge.no/linkml/ngr-adresse/GeografiskOmrade> ;
    skos:definition "Eit kyrkjesokn." ;
    skos:exactMatch ngr:Kirkesokn ;
    skos:inScheme <https://data.norge.no/linkml/ngr-adresse> .

<https://data.norge.no/linkml/ngr-adresse/KommunalKrets> a owl:Class ;
    rdfs:label "KommunalKrets" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/kretsnummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/kretsnummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/kretsnummer> ],
        <https://data.norge.no/linkml/ngr-adresse/GeografiskOmrade> ;
    skos:definition "Ein kommunal krets (administrativ inndeling definert av kommunen)." ;
    skos:exactMatch ngr:KommunalKrets ;
    skos:inScheme <https://data.norge.no/linkml/ngr-adresse> .

<https://data.norge.no/linkml/ngr-adresse/OffisiellAdresse> a owl:Class ;
    rdfs:label "OffisiellAdresse" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Bruksenhet> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adresserer_bruksenhet> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/bruksenhetsnummer_ref> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/representasjonspunkt_ref> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adressekode_ref> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adressenavn_ref> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adressetilleggsnavn> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adresserer_bygning> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/husnummer_ref> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/geografisk_omrade> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/matrikkelnummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/matrikkelnummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Kommune> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/kommunenummer_ref> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/representasjonspunkt_ref> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/matrikkelnummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/GeografiskOmrade> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/geografisk_omrade> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adressekode_ref> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Bygning> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adresserer_bygning> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adresserer_bruksenhet> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Adressekode> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adressekode_ref> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adresserer_bruksenhet> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/bruksenhetsnummer_ref> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Husnummer> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/husnummer_ref> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/kommunenummer_ref> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Bruksenhetsnummer> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/bruksenhetsnummer_ref> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adressetilleggsnavn> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adressetilleggsnavn> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adresserer_annet_objekt> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adresserer_annet_objekt> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/kommunenummer_ref> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Representasjonspunkt> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/representasjonspunkt_ref> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adresserer_bygning> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adressenavn_ref> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Adressenavn> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adressenavn_ref> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/adresserer_annet_objekt> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/husnummer_ref> ],
        <https://data.norge.no/linkml/ngr-adresse/GeografiskAdresse> ;
    skos:definition "Ei offisiell adresse tildelt av kommunen, beståande av vegadresse (adressenavn + husnummer) eller matrikkelnummer. Forvaltas av Matrikkelen." ;
    skos:exactMatch ngr:OffisiellAdresse ;
    skos:inScheme <https://data.norge.no/linkml/ngr-adresse> .

<https://data.norge.no/linkml/ngr-adresse/Postboksadresse> a owl:Class ;
    rdfs:label "Postboksadresse" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/poststed_ref> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/postboks_ref> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/postboksanleggsnavn> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/poststed_ref> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/postboks_ref> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/postboksanleggsnavn> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/ngr-adresse/Postboks> ;
            owl:onProperty <https://data.norge.no/linkml/ngr-adresse/postboks_ref> ],
        [ a owl:Restriction ;
