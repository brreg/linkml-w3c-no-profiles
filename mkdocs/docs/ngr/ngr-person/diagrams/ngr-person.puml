"Person" --> "0..*" "Statsborgerskap" : "har_statsborgerskap"(i)
"PersonContainer" *--> "0..*" "Statsborgerskap" : "statsborgerskap"
class "SpraakForElektroniskKommunikasjon" [[{Føretrekt språk for elektronisk kommunikasjon med offentlege styresmakter, valt av personen sjølv.}]] {
    {field} id : uriorcurie  
    {field} spraakkode : string  
}
"Person" --> "1" "SpraakForElektroniskKommunikasjon" : "har_valgt_spraak"
"Person" --> "0..1" "SpraakForElektroniskKommunikasjon" : "har_valgt_spraak"(i)
"PersonContainer" *--> "0..*" "SpraakForElektroniskKommunikasjon" : "spraak"
class "Sivilstand" [[{Sivilstand registrert på ein person i Folkeregisteret.}]] {
    {field} id : uriorcurie  
    {field} sivilstand_type : SivilstandType  
