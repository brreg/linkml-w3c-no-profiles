@prefix aksje: <https://example.no/ontology/aksje#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

aksje:Tidspunkt a owl:Class ;
    rdfs:label "Tidspunkt" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:dato ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty aksje:dato ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aksje:dato ] ;
    skos:definition "Tidspunkt for ei hending." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:antall a owl:DatatypeProperty ;
    rdfs:label "antall" ;
    rdfs:range xsd:integer ;
    skos:definition "Numerisk verdi." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

<https://example.no/ontology/aksje-eierskap.owl.ttl> a owl:Ontology ;
    rdfs:label "aksje_eierskap" ;
    dcterms:title "Aksje- og eigarskapsmodell" ;
    skos:definition """LinkML-modell for aksjeselskap, aksjar, eigarskap og eigarskapshendingar. Modellen er tilpassa RDF-generering, SHACL og Ontodia-visualisering.
""" .

aksje:Aksjeeierrettighet a owl:Class ;
    rdfs:label "Aksjeeierrettighet" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom aksje:Aksjeklasse ;
            owl:onProperty aksje:gjelder_aksjer_i_aksjeklasse ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:gjelder_aksjer_i_aksjeklasse ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aksje:gjelder_aksjer_i_aksjeklasse ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:beskrivelse ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty aksje:identifikator ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aksje:beskrivelse ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:identifikator ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty aksje:beskrivelse ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty aksje:identifikator ] ;
    skos:definition "Rettigheiter knytt til aksjar, til dømes stemmerett." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:InnbetaltAksjekapital a owl:Class ;
    rdfs:label "InnbetaltAksjekapital" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aksje:belop ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:belop ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:decimal ;
            owl:onProperty aksje:belop ] ;
    skos:definition "Innbetalt aksjekapital." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:InnbetaltOverkurs a owl:Class ;
    rdfs:label "InnbetaltOverkurs" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:decimal ;
            owl:onProperty aksje:belop ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aksje:belop ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:belop ] ;
    skos:definition "Innbetalt overkurs utover pålydande." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:aksjeeiere a owl:ObjectProperty ;
    rdfs:label "aksjeeiere" ;
    rdfs:domain aksje:Containerklasse ;
    rdfs:range aksje:Aksjeeier ;
    skos:definition "Samling av aksjeeigarar." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:aksjeeierrettigheter a owl:ObjectProperty ;
    rdfs:label "aksjeeierrettigheter" ;
    rdfs:domain aksje:Containerklasse ;
    rdfs:range aksje:Aksjeeierrettighet ;
    skos:definition "Samling av aksjeeierrettigheiter." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:aksjeinnskudder a owl:ObjectProperty ;
    rdfs:label "aksjeinnskudder" ;
    rdfs:domain aksje:Containerklasse ;
    rdfs:range aksje:Aksjeinnskudd ;
    skos:definition "Samling av aksjeinnskot." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:aksjekapitaler a owl:ObjectProperty ;
    rdfs:label "aksjekapitaler" ;
    rdfs:domain aksje:Containerklasse ;
    rdfs:range aksje:Aksjekapital ;
    skos:definition "Samling av aksjekapitalar." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:aksjeklasser a owl:ObjectProperty ;
    rdfs:label "aksjeklasser" ;
    rdfs:domain aksje:Containerklasse ;
    rdfs:range aksje:Aksjeklasse ;
    skos:definition "Samling av aksjeklasser." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:aksjeoverdragelser a owl:ObjectProperty ;
    rdfs:label "aksjeoverdragelser" ;
    rdfs:domain aksje:Containerklasse ;
    rdfs:range aksje:Aksjeoverdragelse ;
    skos:definition "Samling av aksjeoverdragingar." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:aksjeposter a owl:ObjectProperty ;
    rdfs:label "aksjeposter" ;
    rdfs:domain aksje:Containerklasse ;
    rdfs:range aksje:Aksjepost ;
    skos:definition "Samling av aksjepostar." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:aksjer a owl:ObjectProperty ;
    rdfs:label "aksjer" ;
    rdfs:domain aksje:Containerklasse ;
    rdfs:range aksje:Aksje ;
    skos:definition "Samling av aksjar." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:aksjeselskaper a owl:ObjectProperty ;
    rdfs:label "aksjeselskaper" ;
    rdfs:domain aksje:Containerklasse ;
    rdfs:range aksje:Aksjeselskap ;
    skos:definition "Samling av aksjeselskap." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:eierposisjoner a owl:ObjectProperty ;
    rdfs:label "eierposisjoner" ;
    rdfs:domain aksje:Containerklasse ;
    rdfs:range aksje:Eierposisjon ;
    skos:definition "Samling av eigarposisjonar." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:eierskapstransaksjoner a owl:ObjectProperty ;
    rdfs:label "eierskapstransaksjoner" ;
    rdfs:domain aksje:Containerklasse ;
    rdfs:range aksje:Eierskapstransaksjon ;
    skos:definition "Samling av eigarskapstransaksjonar." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:innbetalt_aksjekapitaler a owl:ObjectProperty ;
    rdfs:label "innbetalt_aksjekapitaler" ;
    rdfs:domain aksje:Containerklasse ;
    rdfs:range aksje:InnbetaltAksjekapital ;
    skos:definition "Samling av innbetalt aksjekapital." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:innbetalt_overkurser a owl:ObjectProperty ;
    rdfs:label "innbetalt_overkurser" ;
    rdfs:domain aksje:Containerklasse ;
    rdfs:range aksje:InnbetaltOverkurs ;
    skos:definition "Samling av innbetalt overkurs." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:selskapshendelser a owl:ObjectProperty ;
    rdfs:label "selskapshendelser" ;
    rdfs:domain aksje:Containerklasse ;
    rdfs:range aksje:Selskapshendelse ;
    skos:definition "Samling av selskapshendingar." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:utbytter a owl:ObjectProperty ;
    rdfs:label "utbytter" ;
    rdfs:domain aksje:Containerklasse ;
    rdfs:range aksje:Utbytte ;
    skos:definition "Samling av utbytte." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:utdelinger a owl:ObjectProperty ;
    rdfs:label "utdelinger" ;
    rdfs:domain aksje:Containerklasse ;
    rdfs:range aksje:Utdeling ;
    skos:definition "Samling av utdelingar." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:vederlager a owl:ObjectProperty ;
    rdfs:label "vederlager" ;
    rdfs:domain aksje:Containerklasse ;
    rdfs:range aksje:Vederlag ;
    skos:definition "Samling av vederlag." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:Aksjeeier a owl:Class ;
    rdfs:label "Aksjeeier" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:navn ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aksje:navn ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:identifikator ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty aksje:identifikator ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty aksje:navn ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty aksje:identifikator ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aksje:har_eierposisjon ],
        [ a owl:Restriction ;
            owl:allValuesFrom aksje:Eierposisjon ;
            owl:onProperty aksje:har_eierposisjon ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:har_eierposisjon ] ;
    skos:definition "Person eller organisasjon som eig aksjar." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:beskrivelse a owl:DatatypeProperty ;
    rdfs:label "beskrivelse" ;
    rdfs:range xsd:string ;
    skos:definition "Tekstleg forklaring av instansen." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:dato a owl:DatatypeProperty ;
    rdfs:label "dato" ;
    rdfs:range xsd:date ;
    skos:definition "Kalenderdato." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:er_basert_paa_eierposisjon a owl:ObjectProperty ;
    rdfs:label "er_basert_paa_eierposisjon" ;
    rdfs:domain aksje:Utbytte ;
    rdfs:range aksje:Eierposisjon ;
    skos:definition "Utbytte knytt til eigarposisjonen." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:gjelder_aksjepost a owl:ObjectProperty ;
    rdfs:label "gjelder_aksjepost" ;
    rdfs:domain aksje:Eierposisjon ;
    rdfs:range aksje:Aksjepost ;
    skos:definition "Aksjepost som inngår i eigarposisjonen." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:gjelder_innbetalt_aksjekapital a owl:DatatypeProperty ;
    rdfs:label "gjelder_innbetalt_aksjekapital" ;
    rdfs:domain aksje:Aksjeinnskudd ;
    rdfs:range xsd:decimal ;
    skos:definition "Innbetalt aksjekapital." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:gjelder_innbetalt_overkurs a owl:DatatypeProperty ;
    rdfs:label "gjelder_innbetalt_overkurs" ;
    rdfs:domain aksje:Aksjeinnskudd ;
    rdfs:range xsd:decimal ;
    skos:definition "Innbetalt overkurs." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:har_aksjekapital a owl:ObjectProperty ;
    rdfs:label "har_aksjekapital" ;
    rdfs:domain aksje:Aksjeselskap ;
    rdfs:range aksje:Aksjekapital ;
    skos:definition "Aksjekapital som høyrer til selskapet." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:har_eierposisjon a owl:ObjectProperty ;
    rdfs:label "har_eierposisjon" ;
    rdfs:domain aksje:Aksjeeier ;
    rdfs:range aksje:Eierposisjon ;
    skos:definition "Eierposisjon aksjeeigaren har." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:har_palydende_belop a owl:DatatypeProperty ;
    rdfs:label "har_palydende_belop" ;
    rdfs:domain aksje:Aksje ;
    rdfs:range xsd:decimal ;
    skos:definition "Pålydande verdi for aksja." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:har_utdeling a owl:ObjectProperty ;
    rdfs:label "har_utdeling" ;
    rdfs:domain aksje:Utbytte ;
    rdfs:range aksje:Utdeling ;
    skos:definition "Utdeling knytt til utbyttet." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:kan_ha_aksjeinnskudd a owl:ObjectProperty ;
    rdfs:label "kan_ha_aksjeinnskudd" ;
    rdfs:domain aksje:Selskapshendelse ;
    rdfs:range aksje:Aksjeinnskudd ;
    skos:definition "Aksjeinnskot i selskapshending." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:kan_ha_vederlag a owl:ObjectProperty ;
    rdfs:label "kan_ha_vederlag" ;
    rdfs:domain aksje:Aksjeoverdragelse ;
    rdfs:range aksje:Vederlag ;
    skos:definition "Vederlag for aksjeoverdraging." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:kan_vaere_aksjeoverdragelse a owl:ObjectProperty ;
    rdfs:label "kan_vaere_aksjeoverdragelse" ;
    rdfs:domain aksje:Eierskapstransaksjon ;
    rdfs:range aksje:Aksjeoverdragelse ;
    skos:definition "Aksjeoverdraging i transaksjonen." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:kan_vaere_selskapshendelse a owl:ObjectProperty ;
    rdfs:label "kan_vaere_selskapshendelse" ;
    rdfs:domain aksje:Eierskapstransaksjon ;
    rdfs:range aksje:Selskapshendelse ;
    skos:definition "Selskapshendelse i transaksjonen." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:paavirker_eierposisjon a owl:ObjectProperty ;
    rdfs:label "paavirker_eierposisjon" ;
    rdfs:domain aksje:Eierskapstransaksjon ;
    rdfs:range aksje:Eierposisjon ;
    skos:definition "Eierskapstransaksjon knytt til eigarposisjonen." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:tilhorer_aksjeklasse a owl:ObjectProperty ;
    rdfs:label "tilhorer_aksjeklasse" ;
    rdfs:domain aksje:Aksje ;
    rdfs:range aksje:Aksjeklasse ;
    skos:definition "Klassen aksja høyrer til." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:utsteder_aksje a owl:ObjectProperty ;
    rdfs:label "utsteder_aksje" ;
    rdfs:domain aksje:Aksjeselskap ;
    rdfs:range aksje:Aksje ;
    skos:definition "Aksje utstedt av selskapet" ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:Aksjekapital a owl:Class ;
    rdfs:label "Aksjekapital" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty aksje:identifikator ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty aksje:identifikator ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty aksje:har_antall_aksjer ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:har_antall_aksjer ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aksje:har_antall_aksjer ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:identifikator ] ;
    skos:definition "Den registrerte aksjekapitalen i eit aksjeselskap." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:Aksjepost a owl:Class ;
    rdfs:label "Aksjepost" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:har_antall_aksjer ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aksje:gjelder_aksjer_i_aksjeklasse ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty aksje:identifikator ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:gjelder_aksjer_i_aksjeklasse ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty aksje:har_antall_aksjer ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aksje:har_antall_aksjer ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:identifikator ],
        [ a owl:Restriction ;
            owl:allValuesFrom aksje:Aksjeklasse ;
            owl:onProperty aksje:gjelder_aksjer_i_aksjeklasse ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty aksje:identifikator ] ;
    skos:definition "Samling aksjar eigd av ein aksjeeigar." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:Aksjeselskap a owl:Class ;
    rdfs:label "Aksjeselskap" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:navn ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty aksje:navn ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:har_aksjekapital ],
        [ a owl:Restriction ;
            owl:allValuesFrom aksje:Aksje ;
            owl:onProperty aksje:utsteder_aksje ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aksje:utsteder_aksje ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:utsteder_aksje ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:identifikator ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aksje:har_aksjekapital ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty aksje:identifikator ],
        [ a owl:Restriction ;
            owl:allValuesFrom aksje:Aksjekapital ;
            owl:onProperty aksje:har_aksjekapital ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty aksje:identifikator ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aksje:navn ] ;
    skos:definition "Selskap som utsteder aksjar og har aksjekapital." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:Utbytte a owl:Class ;
    rdfs:label "Utbytte" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty aksje:identifikator ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:er_basert_paa_eierposisjon ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aksje:er_basert_paa_eierposisjon ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aksje:har_utdeling ],
        [ a owl:Restriction ;
            owl:allValuesFrom aksje:Utdeling ;
            owl:onProperty aksje:har_utdeling ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty aksje:tidspunkt ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aksje:tidspunkt ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:tidspunkt ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty aksje:identifikator ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:har_utdeling ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:identifikator ],
        [ a owl:Restriction ;
            owl:allValuesFrom aksje:Eierposisjon ;
            owl:onProperty aksje:er_basert_paa_eierposisjon ] ;
    skos:definition "Utbytte knytt til ein eigarposisjon." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:Utdeling a owl:Class ;
    rdfs:label "Utdeling" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty aksje:belop ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:identifikator ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:decimal ;
            owl:onProperty aksje:belop ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty aksje:identifikator ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:belop ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty aksje:identifikator ] ;
    skos:definition "Konkret utdeling av verdiar til aksjeeigarar." ;
    skos:inScheme <https://example.no/ontology/aksje-eierskap> .

aksje:Vederlag a owl:Class ;
    rdfs:label "Vederlag" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:identifikator ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:decimal ;
            owl:onProperty aksje:belop ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty aksje:belop ],
        [ a owl:Restriction ;
