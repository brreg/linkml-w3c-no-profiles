<https://data.norge.no/linkml/ngr-eiendom/YtreInngang> a linkml:ClassDefinition ;
    skos:inScheme "https://data.norge.no/linkml/ngr-eiendom"^^xsd:anyURI ;
    skos:mappingRelation "ngre:YtreInngang"^^xsd:anyURI ;
    linkml:class_uri "https://data.norge.no/vocabulary/ngr-eiendom#YtreInngang"^^xsd:anyURI ;
    linkml:definition_uri "https://data.norge.no/linkml/ngr-eiendom/YtreInngang"^^xsd:anyURI ;
    linkml:description "Ytre inngang til ein bygning. Registrerast ikkje som eige objekt i Matrikkelen, men adressepunktet refererer til ytre inngang. Gir tilgang til éi eller fleire brukseiningar." ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://data.norge.no/linkml/ngr-eiendom/YtreInngang_gjelder_bruksenhet>,
        <https://data.norge.no/linkml/ngr-eiendom/YtreInngang_har_offisiell_adresse>,
        <https://data.norge.no/linkml/ngr-eiendom/id> .

<https://data.norge.no/linkml/ngr-eiendom/integer> a linkml:TypeDefinition ;
    skos:editorialNote "If you are authoring schemas in LinkML YAML, the type is referenced with the lower case \"integer\"." ;
    skos:exactMatch "schema:Integer"^^xsd:anyURI ;
    skos:inScheme "https://w3id.org/linkml/types"^^xsd:anyURI ;
    linkml:base "int" ;
    linkml:definition_uri "https://w3id.org/linkml/Integer"^^xsd:anyURI ;
    linkml:description "An integer" ;
    linkml:imported_from "linkml:types" ;
    linkml:uri "http://www.w3.org/2001/XMLSchema#integer"^^xsd:anyURI .

<https://data.norge.no/linkml/ngr-eiendom/Bruksenhetsnummer> a linkml:ClassDefinition ;
    skos:inScheme "https://data.norge.no/linkml/ngr-eiendom"^^xsd:anyURI ;
    skos:mappingRelation "ngre:Bruksenhetsnummer"^^xsd:anyURI ;
    linkml:class_uri "https://data.norge.no/vocabulary/ngr-eiendom#Bruksenhetsnummer"^^xsd:anyURI ;
    linkml:definition_uri "https://data.norge.no/linkml/ngr-eiendom/Bruksenhetsnummer"^^xsd:anyURI ;
    linkml:description "Identifikator for ei brukseining innanfor ein bygning, t.d. H0201 = 2. etasje, eining 1 (etasjeplan + etasjenummer + nummerering)." ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://data.norge.no/linkml/ngr-eiendom/Bruksenhetsnummer_etasjenummer>,
        <https://data.norge.no/linkml/ngr-eiendom/Bruksenhetsnummer_etasjeplan>,
        <https://data.norge.no/linkml/ngr-eiendom/Bruksenhetsnummer_nummerering_i_etasjen>,
        <https://data.norge.no/linkml/ngr-eiendom/id> .

<https://data.norge.no/linkml/ngr-eiendom/Valgfri> a linkml:SubsetDefinition ;
    skos:inScheme "https://data.norge.no/linkml/ngr-eiendom"^^xsd:anyURI ;
    linkml:definition_uri "https://data.norge.no/linkml/ngr-eiendom/Valgfri"^^xsd:anyURI ;
    linkml:description "Valfrie eigenskapar i domenemodellen." .

<https://data.norge.no/linkml/ngr-eiendom/Borettslagsandel> a linkml:ClassDefinition ;
    skos:inScheme "https://data.norge.no/linkml/ngr-eiendom"^^xsd:anyURI ;
    skos:mappingRelation "ngre:Borettslagsandel"^^xsd:anyURI ;
    linkml:class_uri "https://data.norge.no/vocabulary/ngr-eiendom#Borettslagsandel"^^xsd:anyURI ;
    linkml:definition_uri "https://data.norge.no/linkml/ngr-eiendom/Borettslagsandel"^^xsd:anyURI ;
    linkml:description "Ein andel i eit burettslag som gir eksklusiv bruksrett til ein bestemt bustad i burettslagsbygningen." ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://data.norge.no/linkml/ngr-eiendom/Borettslagsandel_har_eierforhold>,
        <https://data.norge.no/linkml/ngr-eiendom/Borettslagsandel_har_tinglyst_heftelse>,
        <https://data.norge.no/linkml/ngr-eiendom/Borettslagsandel_tilhoerer_borettslag>,
        <https://data.norge.no/linkml/ngr-eiendom/id> .

<https://data.norge.no/linkml/ngr-eiendom/Representasjonspunkt> a linkml:ClassDefinition ;
    skos:inScheme "https://data.norge.no/linkml/ngr-eiendom"^^xsd:anyURI ;
    skos:mappingRelation "ngre:Representasjonspunkt"^^xsd:anyURI ;
    linkml:class_uri "https://data.norge.no/vocabulary/ngr-eiendom#Representasjonspunkt"^^xsd:anyURI ;
    linkml:definition_uri "https://data.norge.no/linkml/ngr-eiendom/Representasjonspunkt"^^xsd:anyURI ;
    linkml:description "Geografisk punkt (koordinatpar) som representerer posisjonen til bygningen." ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://data.norge.no/linkml/ngr-eiendom/Representasjonspunkt_koordinat_nord>,
        <https://data.norge.no/linkml/ngr-eiendom/Representasjonspunkt_koordinat_ost>,
        <https://data.norge.no/linkml/ngr-eiendom/Representasjonspunkt_koordinatsystem>,
        <https://data.norge.no/linkml/ngr-eiendom/id> .

<https://data.norge.no/linkml/ngr-eiendom/Bruksenhet> a linkml:ClassDefinition ;
    skos:inScheme "https://data.norge.no/linkml/ngr-eiendom"^^xsd:anyURI ;
    skos:mappingRelation "ngre:Bruksenhet"^^xsd:anyURI ;
    linkml:class_uri "https://data.norge.no/vocabulary/ngr-eiendom#Bruksenhet"^^xsd:anyURI ;
    linkml:definition_uri "https://data.norge.no/linkml/ngr-eiendom/Bruksenhet"^^xsd:anyURI ;
    linkml:description "Ei brukseining (leilegheit, kontor o.l.) innanfor ein bygning. Har eit bruksenheitsnummer, ligg i minst éi etasje og kan vere knytt til ei matrikkelenheit." ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://data.norge.no/linkml/ngr-eiendom/Bruksenhet_er_tilknyttet_matrikkelenhet>,
        <https://data.norge.no/linkml/ngr-eiendom/Bruksenhet_har_bruksenhetsnummer>,
        <https://data.norge.no/linkml/ngr-eiendom/Bruksenhet_har_offisiell_adresse>,
        <https://data.norge.no/linkml/ngr-eiendom/Bruksenhet_ligger_i_etasje>,
        <https://data.norge.no/linkml/ngr-eiendom/id> .

<https://data.norge.no/linkml/ngr-eiendom/Matrikkelnummer> a linkml:ClassDefinition ;
    skos:inScheme "https://data.norge.no/linkml/ngr-eiendom"^^xsd:anyURI ;
    skos:mappingRelation "ngre:Matrikkelnummer"^^xsd:anyURI ;
    linkml:class_uri "https://data.norge.no/vocabulary/ngr-eiendom#Matrikkelnummer"^^xsd:anyURI ;
    linkml:definition_uri "https://data.norge.no/linkml/ngr-eiendom/Matrikkelnummer"^^xsd:anyURI ;
    linkml:description "Offisiell identifikator for ei matrikkelenheit, beståande av kommunenummer, gards-, bruks- og eventuelt feste- og seksjonsnummer." ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://data.norge.no/linkml/ngr-eiendom/Matrikkelnummer_bestar_av_bruksnummer>,
        <https://data.norge.no/linkml/ngr-eiendom/Matrikkelnummer_bestar_av_festenummer>,
        <https://data.norge.no/linkml/ngr-eiendom/Matrikkelnummer_bestar_av_gaardsnummer>,
        <https://data.norge.no/linkml/ngr-eiendom/Matrikkelnummer_bestar_av_kommunenummer>,
        <https://data.norge.no/linkml/ngr-eiendom/Matrikkelnummer_bestar_av_seksjonsnummer>,
        <https://data.norge.no/linkml/ngr-eiendom/id> .

<https://data.norge.no/linkml/ngr-eiendom/Eierforhold> a linkml:ClassDefinition ;
    skos:inScheme "https://data.norge.no/linkml/ngr-eiendom"^^xsd:anyURI ;
    skos:mappingRelation "ngre:Eierforhold"^^xsd:anyURI ;
    linkml:abstract true ;
    linkml:class_uri "https://data.norge.no/vocabulary/ngr-eiendom#Eierforhold"^^xsd:anyURI ;
    linkml:definition_uri "https://data.norge.no/linkml/ngr-eiendom/Eierforhold"^^xsd:anyURI ;
    linkml:description "Abstrakt klasse for eigarforhold forvalta av Grunnboka. Eit eigarforhold gjeld éi matrikkelenheit og kan eventuelt gjelde ein burettslagsandel. Inneheld heimelsdokument som fastset kven som er eigar og på kva vilkår." ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://data.norge.no/linkml/ngr-eiendom/Eierforhold_gjelder_hjemmel_eiendomsrett>,
        <https://data.norge.no/linkml/ngr-eiendom/Eierforhold_gjelder_hjemmel_festerett>,
        <https://data.norge.no/linkml/ngr-eiendom/Eierforhold_gjelder_hjemmel_framfesterett>,
        <https://data.norge.no/linkml/ngr-eiendom/Eierforhold_gjelder_matrikkelenhet>,
        <https://data.norge.no/linkml/ngr-eiendom/Eierforhold_kan_gjelde_borettslagsandel>,
        <https://data.norge.no/linkml/ngr-eiendom/id> .

<https://data.norge.no/linkml/ngr-eiendom/Obligatorisk> a linkml:SubsetDefinition ;
    skos:inScheme "https://data.norge.no/linkml/ngr-eiendom"^^xsd:anyURI ;
    linkml:definition_uri "https://data.norge.no/linkml/ngr-eiendom/Obligatorisk"^^xsd:anyURI ;
    linkml:description "Obligatoriske eigenskapar i domenemodellen." .

<https://data.norge.no/linkml/ngr-eiendom/FastEiendom> a linkml:ClassDefinition ;
    skos:inScheme "https://data.norge.no/linkml/ngr-eiendom"^^xsd:anyURI ;
    skos:mappingRelation "ngre:FastEiendom"^^xsd:anyURI ;
    linkml:class_uri "https://data.norge.no/vocabulary/ngr-eiendom#FastEiendom"^^xsd:anyURI ;
    linkml:definition_uri "https://data.norge.no/linkml/ngr-eiendom/FastEiendom"^^xsd:anyURI ;
    linkml:description "Fast eiendom er eit grunnomgrep i eigedomsdomenet. Identifiserast av og består av éi matrikkelenheit, og kan innehalde bygningar og rettar som er nødvendige for å benytte eigedommen." ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://data.norge.no/linkml/ngr-eiendom/FastEiendom_bestar_av_bygning>,
        <https://data.norge.no/linkml/ngr-eiendom/FastEiendom_bestar_av_matrikkelenhet>,
        <https://data.norge.no/linkml/ngr-eiendom/FastEiendom_bestar_av_rettighet>,
        <https://data.norge.no/linkml/ngr-eiendom/FastEiendom_har_eierforhold>,
        <https://data.norge.no/linkml/ngr-eiendom/FastEiendom_har_tinglyst_heftelse>,
        <https://data.norge.no/linkml/ngr-eiendom/FastEiendom_identifiseres_av>,
        <https://data.norge.no/linkml/ngr-eiendom/id> .

<https://data.norge.no/linkml/ngr-eiendom/Bygning> a linkml:ClassDefinition ;
    skos:inScheme "https://data.norge.no/linkml/ngr-eiendom"^^xsd:anyURI ;
    skos:mappingRelation "ngre:Bygning"^^xsd:anyURI ;
    linkml:class_uri "https://data.norge.no/vocabulary/ngr-eiendom#Bygning"^^xsd:anyURI ;
    linkml:definition_uri "https://data.norge.no/linkml/ngr-eiendom/Bygning"^^xsd:anyURI ;
    linkml:description "Ein bygning registrert i Matrikkelen. Knytt til éi matrikkelenheit og kan ha fleire ytre innganger, brukseiningar og etasjar. Bygningsinformasjon er i dag spreidd i fleire databasar." ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://data.norge.no/linkml/ngr-eiendom/Bygning_er_knyttet_til_matrikkelenhet>,
        <https://data.norge.no/linkml/ngr-eiendom/Bygning_har_bruksenhet>,
        <https://data.norge.no/linkml/ngr-eiendom/Bygning_har_bygningsnummer>,
        <https://data.norge.no/linkml/ngr-eiendom/Bygning_har_etasje>,
        <https://data.norge.no/linkml/ngr-eiendom/Bygning_har_representasjonspunkt>,
        <https://data.norge.no/linkml/ngr-eiendom/Bygning_har_ytre_inngang>,
        <https://data.norge.no/linkml/ngr-eiendom/id> .

