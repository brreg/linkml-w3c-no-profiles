            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/er_del_av_teig> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/identifiseres_med> ],
        [ a owl:Restriction ;
