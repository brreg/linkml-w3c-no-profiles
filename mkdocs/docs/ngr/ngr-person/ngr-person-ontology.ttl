            owl:onProperty <https://data.norge.no/linkml/ngr-person/foedslar> ] ;
    skos:definition "Rotklasse for NGR-person-datafiler. Held flate lister av alle instansierbare klassar; referansar mellom objekt brukar URI-lenking." ;
    skos:inScheme <https://data.norge.no/linkml/ngr-person> .

<https://data.norge.no/linkml/ngr-person/DNummer> a owl:Class ;
    rdfs:label "DNummer" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/identifikatornummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/identifikatornummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/identifikatornummer> ],
        <https://data.norge.no/linkml/ngr-person/Folkeregisteridentifikator> ;
    skos:definition "Elleve-sifra D-nummer tildelt utanlandske personar med mellombels opphald i Noreg (t.d. med d-nummer, om dei har midlertidig eller permanent opphald). Brukes om de har midlertidig eller ikkje har permanent opphald." ;
    skos:exactMatch ngrp:DNummer ;
    skos:inScheme <https://data.norge.no/linkml/ngr-person> .

<https://data.norge.no/linkml/ngr-person/Foedselsnummer> a owl:Class ;
    rdfs:label "Foedselsnummer" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/identifikatornummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/identifikatornummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-person/identifikatornummer> ],
        <https://data.norge.no/linkml/ngr-person/Folkeregisteridentifikator> ;
    skos:definition "Elleve-sifra fødselsnummer tildelt norske statsborgarar og personar med fast opphald i Noreg." ;
    skos:exactMatch ngrp:Foedselsnummer ;
    skos:inScheme <https://data.norge.no/linkml/ngr-person> .

