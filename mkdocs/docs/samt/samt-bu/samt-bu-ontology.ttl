        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty samtbuskole:har_anbefalt_term ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/dqv-ap-no/er_deldimensjon_av> ],
        <https://data.norge.no/linkml/dqv-ap-no/Kvalitetsdimensjon> ;
    skos:definition "Ein deldimensjon av ein kvalitetsdimensjon." ;
    skos:exactMatch <https://data.norge.no/vocabulary/dqvno#SubDimension> ;
    skos:inScheme <https://data.norge.no/linkml/dqv-ap-no> .

