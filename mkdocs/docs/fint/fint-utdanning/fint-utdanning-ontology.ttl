@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix fint: <https://schema.fintlabs.no/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pav: <http://purl.org/pav/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix utd: <https://schema.fintlabs.no/utdanning/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://data.norge.no/linkml/fint-utdanning.owl.ttl> a owl:Ontology ;
    rdfs:label "fint-utdanning" ;
    dcterms:title "FINT Utdanning" ;
    pav:version "4.0.20" ;
    skos:definition """FINT-domenemodell for utdanning. Dekkjer elevar, skular, skoleressursar, elevforhold, undervisningsforhold, klasser, undervisningsgrupper, faggrupper, kontaktlærergrupper, utdanningsprogram, programområde, vurdering, lærling og OT.
""" .

<https://schema.fintlabs.no/:Matrikkelnummer> a owl:Class ;
    rdfs:label "Matrikkelnummer" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Kommune> ;
            owl:onProperty <https://schema.fintlabs.no/:kommunenummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:gaardsnummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:bruksnummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:gaardsnummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:seksjonsnummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:gaardsnummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:kommunenummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:festenummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Adresse> ;
            owl:onProperty <https://schema.fintlabs.no/:adresse> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:kommunenummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:festenummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:seksjonsnummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:seksjonsnummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:bruksnummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:festenummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:adresse> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:adresse> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:bruksnummer> ] ;
    skos:definition "Eintydleg identifisering av matrikkeleining innanfor kommune." ;
    skos:exactMatch fint:Matrikkelnummer ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:Valuta> a owl:Class ;
    rdfs:label "Valuta" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Identifikator> ;
            owl:onProperty <https://schema.fintlabs.no/:bokstavkode> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:bokstavkode> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:valuta_navn> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:bokstavkode> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:valuta_navn> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:nummerkode> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Identifikator> ;
            owl:onProperty <https://schema.fintlabs.no/:nummerkode> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:valuta_navn> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:nummerkode> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:id> ] ;
    skos:definition "Valutakodar for offisielle valutaer." ;
    skos:exactMatch fint:Valuta ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:Virksomhet> a owl:Class ;
    rdfs:label "Virksomhet" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:laerling> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://schema.fintlabs.no/:laerling> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Identifikator> ;
            owl:onProperty <https://schema.fintlabs.no/:virksomhetsId> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:virksomhetsId> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:virksomhetsId> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        <https://schema.fintlabs.no/:Enhet> ;
    skos:definition "Ein juridisk organisasjon som produserer varer eller tenester." ;
    skos:exactMatch fint:Virksomhet ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

