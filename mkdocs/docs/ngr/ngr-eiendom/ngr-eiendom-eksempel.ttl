@prefix ngre: <https://data.norge.no/vocabulary/ngr-eiendom#> .
@prefix ns1: <https://data.norge.no/linkml/ngr-eiendom/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://data.norge.no/vocabulary/ngr-eiendom#eksempel/fast-eiendom-1> a ngre:FastEiendom ;
    ngre:bestarAvBygning <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/bygning-1> ;
    ngre:bestarAvMatrikkelenhet <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/matrikkelenhet-1> ;
    ngre:harEierforhold <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/eierforhold-1> ;
    ngre:identifiseresAv <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/matrikkelenhet-1> .

<https://data.norge.no/vocabulary/ngr-eiendom#eksempel/andel-1> a ngre:Andel ;
    ngre:harRettighetshaver <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/rettighetshaver-1> .

<https://data.norge.no/vocabulary/ngr-eiendom#eksempel/bygning-1> a ngre:Bygning ;
    ngre:erKnyttetTilMatrikkelenhet <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/matrikkelenhet-1> ;
    ngre:harBruksenhet <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/bruksenhet-1> ;
    ngre:harBygningsnummer <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/bygningsnummer-12345678> ;
    ngre:harEtasje <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/etasje-1>,
        <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/etasje-2> ;
    ngre:harRepresentasjonspunkt <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/punkt-1> ;
    ngre:harYtreInngang <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/inngang-1> .

<https://data.norge.no/vocabulary/ngr-eiendom#eksempel/eierforhold-1> a ngre:TinglystEierforhold ;
    ngre:gjelderHjemmelEiendomsrett <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/hjemmel-1> ;
    ngre:gjelderMatrikkelenhet <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/matrikkelenhet-1> .

<https://data.norge.no/vocabulary/ngr-eiendom#eksempel/etasje-1> a ngre:Etasje ;
    ngre:etasjenummer 1 .

<https://data.norge.no/vocabulary/ngr-eiendom#eksempel/hjemmel-1> a ngre:HjemmelTilEiendomsrett ;
    ngre:harAndel <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/andel-1> .

<https://data.norge.no/vocabulary/ngr-eiendom#eksempel/inngang-1> a ngre:YtreInngang ;
    ngre:gjelderBruksenhet <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/bruksenhet-1> ;
    ngre:harOffisiellAdresse <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/adresse-1> .

<https://data.norge.no/vocabulary/ngr-eiendom#eksempel/matrikkelnummer-1> a ngre:Matrikkelnummer ;
    ngre:bestarAvBruksnummer <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/bruksnummer-2> ;
    ngre:bestarAvGaardsnummer <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/gaardsnummer-25> ;
    ngre:bestarAvKommunenummer <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/kommunenummer-0301> .

<https://data.norge.no/vocabulary/ngr-eiendom#eksempel/punkt-1> a ngre:Representasjonspunkt ;
    ngre:koordinatNord "6650000.0"^^xsd:float ;
    ngre:koordinatOst "262000.0"^^xsd:float ;
    ngre:koordinatsystem "EPSG:25833" .

<https://data.norge.no/vocabulary/ngr-eiendom#eksempel/rettighetshaver-1> a ngre:Rettighetshaver ;
    ngre:erAvTypePerson <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/person-1> .

<https://data.norge.no/vocabulary/ngr-eiendom#eksempel/teig-1> a ngre:Teig .

<https://data.norge.no/vocabulary/ngr-eiendom#eksempel/bruksenhet-1> a ngre:Bruksenhet ;
    ngre:erTilknyttetMatrikkelenhet <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/matrikkelenhet-1> ;
    ngre:harBruksenhetsnummer <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/boenhetsnummer-1> ;
    ngre:harOffisiellAdresse <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/adresse-1> ;
    ngre:liggerIEtasje <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/etasje-2> .

<https://data.norge.no/vocabulary/ngr-eiendom#eksempel/etasje-2> a ngre:Etasje ;
    ngre:etasjenummer 2 .

<https://data.norge.no/vocabulary/ngr-eiendom#eksempel/matrikkelenhet-1> a ngre:Grunneiendom ;
    ngre:harTeig <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/teig-1> ;
    ngre:identifiseresMed <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/matrikkelnummer-1> ;
    ngre:liggerInnenforKommune <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/kommune-0301> .

[] a ns1:EiendomContainer ;
    ns1:andeler <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/andel-1> ;
    ns1:bruksenheter <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/bruksenhet-1> ;
    ns1:bygninger <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/bygning-1> ;
    ns1:etasjer <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/etasje-1>,
        <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/etasje-2> ;
    ns1:fasteEiendommer <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/fast-eiendom-1> ;
    ns1:grunneiendommer <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/matrikkelenhet-1> ;
    ns1:hjemmelEiendomsrett <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/hjemmel-1> ;
    ns1:matrikkelnumre <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/matrikkelnummer-1> ;
    ns1:representasjonspunkt <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/punkt-1> ;
    ns1:rettighetshavere <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/rettighetshaver-1> ;
    ns1:teiger <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/teig-1> ;
    ns1:tinglystEierforhold <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/eierforhold-1> ;
    ns1:ytreInnganger <https://data.norge.no/vocabulary/ngr-eiendom#eksempel/inngang-1> .

