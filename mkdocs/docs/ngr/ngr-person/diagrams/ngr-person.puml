}
class "ForeldreansvarForelder" [[{Relasjonsklasse som registrerer kven som har det juridiske foreldreansvaret for eit barn. Seier kven som er den ansvarlege forelderen.}]] {
    {field} id : uriorcurie  
    {field} ansvarsstatus : string  
}
class "Foedsel" [[{Fødselsinformasjon om ein person registrert i Folkeregisteret.}]] {
