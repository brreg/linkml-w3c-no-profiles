@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix modelldcatno: <https://data.norge.no/vocabulary/modelldcatno#> .
@prefix ns1: <https://data.norge.no/linkml/modelldcat-ap-no-fixture/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.org/kodeelement/matrikkeladresse> a modelldcatno:CodeElement ;
    skos:definition "Adresse basert på matrikkelnummer."^^rdf:langString ;
    skos:inScheme <https://example.org/kodelister/adressetype> ;
    skos:notation "M" ;
    skos:prefLabel "Matrikkeladresse"^^rdf:langString .

<https://example.org/kodeelement/vegadresse> a modelldcatno:CodeElement ;
    skos:definition "Adresse med vegnamn og husnummer."^^rdf:langString ;
    skos:inScheme <https://example.org/kodelister/adressetype> ;
    skos:notation "V" ;
    skos:prefLabel "Vegadresse"^^rdf:langString .

<https://example.org/modelkatalogar/adresse> a dcat:Catalog ;
    dct:description "Katalog over informasjonsmodellar for adressedomenet."^^rdf:langString ;
    dct:hasPart <https://example.org/informasjonsmodellar/offisiell-adresse> ;
    dct:identifier "adresse-modelkatalog-001" ;
    dct:issued "2024-01-15"^^xsd:date ;
    dct:language "http://publications.europa.eu/resource/authority/language/NOB"^^dct:language ;
    dct:modified "2024-06-01"^^xsd:date ;
    dct:publisher <https://organization-catalog.fellesdatakatalog.digdir.no/organizations/991825827> ;
    dct:title "Adressemodellkatalog"^^rdf:langString ;
    dcat:contactPoint <https://example.org/kontakt/matrikkeleininga> ;
    modelldcatno:model <https://example.org/informasjonsmodellar/offisiell-adresse> .

<https://example.org/attributtar/adressekode> a modelldcatno:Attribute ;
    dct:description "Nummer som entydig identifiserer adresserbare gater, vegar, stiar, plassar og område."^^rdf:langString ;
    dct:title "adressekode"^^rdf:langString ;
    modelldcatno:hasSimpleType <https://example.org/enkle-typar/firesifra-heltall> ;
    modelldcatno:maxOccurs "1" ;
    modelldcatno:minOccurs "1"^^xsd:nonNegativeInteger .

<https://example.org/attributtar/adressenavn> a modelldcatno:Attribute ;
    dct:description "Namn på gate, veg, sti, plass eller område som er ført i matrikkelen."^^rdf:langString ;
    dct:title "adressenavn"^^rdf:langString ;
    modelldcatno:maxOccurs "1" ;
    modelldcatno:minOccurs "1"^^xsd:nonNegativeInteger .

<https://example.org/attributtar/bokstav> a modelldcatno:Attribute ;
    dct:description "Bokstavtillegg til husnummeret."^^rdf:langString ;
    dct:title "bokstav"^^rdf:langString ;
    modelldcatno:hasSimpleType <https://example.org/enkle-typar/enkelt-teikn> ;
    modelldcatno:maxOccurs "1" ;
    modelldcatno:minOccurs "0"^^xsd:nonNegativeInteger .

<https://example.org/attributtar/bruksnummer> a modelldcatno:Attribute ;
    dct:description "Bruksnummer i matrikkelen."^^rdf:langString ;
    dct:title "bruksnummer"^^rdf:langString ;
    modelldcatno:hasSimpleType <https://example.org/enkle-typar/positivt-heltall> ;
    modelldcatno:maxOccurs "1" ;
    modelldcatno:minOccurs "1"^^xsd:nonNegativeInteger .

<https://example.org/attributtar/gardsnummer> a modelldcatno:Attribute ;
    dct:description "Gardsnummer i matrikkelen."^^rdf:langString ;
    dct:title "gardsnummer"^^rdf:langString ;
    modelldcatno:hasSimpleType <https://example.org/enkle-typar/positivt-heltall> ;
    modelldcatno:maxOccurs "1" ;
    modelldcatno:minOccurs "1"^^xsd:nonNegativeInteger .

<https://example.org/attributtar/nummer> a modelldcatno:Attribute ;
    dct:description "Husnummer — nummer i adressenummereringssystemet for vegadressa."^^rdf:langString ;
    dct:title "nummer"^^rdf:langString ;
    modelldcatno:hasSimpleType <https://example.org/enkle-typar/positivt-heltall> ;
    modelldcatno:maxOccurs "1" ;
    modelldcatno:minOccurs "1"^^xsd:nonNegativeInteger .

<https://example.org/enkle-typar/enkelt-teikn> a modelldcatno:SimpleType ;
    dct:description "Ein enkelt bokstav (A–Å)."^^rdf:langString ;
    dct:title "EnkeltTeikn"^^rdf:langString ;
    xsd:length "1"^^xsd:nonNegativeInteger ;
    xsd:pattern "[A-ZÆØÅa-zæøå]" ;
    modelldcatno:typeDefinitionReference "http://www.w3.org/2001/XMLSchema#string"^^xsd:anyURI .

<https://example.org/enkle-typar/firesifra-heltall> a modelldcatno:SimpleType ;
    dct:description "Heltalsverdi med nøyaktig 4 sifre."^^rdf:langString ;
    dct:title "FiresifraHeltall"^^rdf:langString ;
    xsd:maxInclusive "9999" ;
    xsd:minInclusive "1000" ;
    xsd:totalDigits "4"^^xsd:nonNegativeInteger ;
    modelldcatno:typeDefinitionReference "http://www.w3.org/2001/XMLSchema#integer"^^xsd:anyURI .

<https://example.org/objekttypar/matrikkeladresse> a modelldcatno:ObjectType ;
    dct:description "Adresse basert på matrikkelnummer (gardsnummer, bruksnummer m.m.)."^^rdf:langString ;
    dct:title "Matrikkeladresse"^^rdf:langString ;
    modelldcatno:hasProperty <https://example.org/attributtar/bruksnummer>,
        <https://example.org/attributtar/gardsnummer> .

<https://example.org/objekttypar/vegadresse> a modelldcatno:ObjectType ;
    dct:description "Adresse der vegnamn, husnummer og eventuell bokstav inngår."^^rdf:langString ;
    dct:title "Vegadresse"^^rdf:langString ;
    modelldcatno:hasProperty <https://example.org/attributtar/adressekode>,
        <https://example.org/attributtar/adressenavn>,
        <https://example.org/attributtar/bokstav>,
        <https://example.org/attributtar/nummer> .

<https://example.org/informasjonsmodellar/offisiell-adresse> a modelldcatno:InformationModel ;
    dct:description "Informasjonsmodell for offisielle adresser i Noreg basert på Matrikkelen."^^rdf:langString ;
    dct:identifier "offisiell-adresse-v1" ;
    dct:issued "2024-01-15"^^xsd:date ;
    dct:publisher <https://organization-catalog.fellesdatakatalog.digdir.no/organizations/991825827> ;
    dct:title "Offisiell adresse"^^rdf:langString ;
    owl:versionInfo "1.0" ;
    modelldcatno:containsModelElement <https://example.org/kodelister/adressetype>,
        <https://example.org/objekttypar/matrikkeladresse>,
        <https://example.org/objekttypar/vegadresse> ;
    modelldcatno:informationModelIdentifier "https://example.org/modell/adresse/v1" .

<https://organization-catalog.fellesdatakatalog.digdir.no/organizations/991825827> a foaf:Agent ;
    foaf:name "Digitaliseringsdirektoratet"^^rdf:langString .

<https://example.org/enkle-typar/positivt-heltall> a modelldcatno:SimpleType ;
    dct:description "Heltalsverdi større enn null."^^rdf:langString ;
    dct:title "PositivtHeltall"^^rdf:langString ;
    xsd:minInclusive "1" ;
    modelldcatno:typeDefinitionReference "http://www.w3.org/2001/XMLSchema#positiveInteger"^^xsd:anyURI .

<https://example.org/kodelister/adressetype> a modelldcatno:CodeList ;
    dct:description "Kodeliste over lovlege adressetypar."^^rdf:langString ;
    dct:title "Adressetype"^^rdf:langString ;
    rdfs:seeAlso "https://register.geonorge.no/sosi-kodelister/matrikkelen/adressetype"^^xsd:anyURI .

[] a ns1:Container ;
    ns1:aktorar <https://organization-catalog.fellesdatakatalog.digdir.no/organizations/991825827> ;
    ns1:attributtar <https://example.org/attributtar/adressekode>,
        <https://example.org/attributtar/adressenavn>,
        <https://example.org/attributtar/bokstav>,
        <https://example.org/attributtar/bruksnummer>,
        <https://example.org/attributtar/gardsnummer>,
        <https://example.org/attributtar/nummer> ;
    ns1:enkle_typar <https://example.org/enkle-typar/enkelt-teikn>,
        <https://example.org/enkle-typar/firesifra-heltall>,
        <https://example.org/enkle-typar/positivt-heltall> ;
    ns1:informasjonsmodellar <https://example.org/informasjonsmodellar/offisiell-adresse> ;
    ns1:kodeelement <https://example.org/kodeelement/matrikkeladresse>,
        <https://example.org/kodeelement/vegadresse> ;
    ns1:kodelister <https://example.org/kodelister/adressetype> ;
    ns1:modelkatalogar <https://example.org/modelkatalogar/adresse> ;
    ns1:objekttypar <https://example.org/objekttypar/matrikkeladresse>,
        <https://example.org/objekttypar/vegadresse> .

