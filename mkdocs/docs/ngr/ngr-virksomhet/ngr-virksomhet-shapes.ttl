@prefix ngrv: <https://data.norge.no/vocabulary/ngr-virksomhet#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://data.norge.no/linkml/ngr-virksomhet/VirksomhetContainer> a sh:NodeShape ;
    rdfs:comment "Rotklasse for NGR-virksomhet-datafiler. Held flate lister av alle instansierbare klassar; referansar mellom objekt brukar URI-lenking." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ngrv:Sektorkode ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/sektorkoder> ],
        [ sh:class ngrv:Aktivitet ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/aktivitetar> ],
        [ sh:class ngrv:Forretningsadresse ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/forretningsadresser> ],
        [ sh:class ngrv:Varslingsadresse ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/varslingsadresser> ],
        [ sh:class ngrv:Postadresse ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/postadresser> ],
        [ sh:class ngrv:RolleIVirksomhet ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/rollerIVirksomhet> ],
        [ sh:class ngrv:Beliggenhetsadresse ;
            sh:nodeKind sh:IRI ;
            sh:order 15 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/beliggenhetsadresser> ],
        [ sh:class ngrv:Signaturrett ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/signaturrettar> ],
        [ sh:class ngrv:Rolleinnehaver ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/rolleinnehavere> ],
        [ sh:class ngrv:Hovedenhet ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/hovedenheter> ],
        [ sh:class ngrv:Kontaktinformasjon ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/kontaktinformasjon> ],
        [ sh:class ngrv:Underenhet ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/underenheter> ],
        [ sh:class ngrv:Organisasjonsform ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/organisasjonsformer> ],
        [ sh:class ngrv:Naeringskode ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/naeringskoder> ],
        [ sh:class ngrv:Tilstand ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/tilstander> ],
        [ sh:class ngrv:Prokura ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/prokuraer> ] ;
    sh:targetClass <https://data.norge.no/linkml/ngr-virksomhet/VirksomhetContainer> .

ngrv:GeografiskAdresse a sh:NodeShape ;
    rdfs:comment "Abstrakt klasse for geografiske adresser. Tilhøyrer Domene adresse og forvaltast av Matrikkelen. Enhetsregisteret nyttar Kartverket som kjelde til vegadresse, og gjer jamnleg vask mot Posten sitt adresseregister." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/id> ] ;
    sh:targetClass ngrv:GeografiskAdresse .

ngrv:Virksomhet a sh:NodeShape ;
    rdfs:comment "Abstrakt overklasse for alle einingar registrert i Enhetsregisteret. Ei verksemd er alltid anten ei underleining eller ei hovudeining." ;
    sh:closed false ;
    sh:ignoredProperties ( ngrv:harBeliggenhetsadresse ngrv:harBestemmelserOmSignaturrett ngrv:harForretningsadresse ngrv:erKlassifisertISektorkode ngrv:harRolleIVirksomhet ngrv:utoevarAktivitet ngrv:nedleggelsesdato ngrv:oppstartsdato ngrv:harBestemmelserOmProkura ngrv:stiftelsesdato ngrv:eierskiftedato rdf:type ) ;
    sh:property [ sh:class ngrv:Varslingsadresse ;
            sh:description "Offisiell varslingsadresse for offentlege meldingar." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path ngrv:harVarslingsadresse ],
        [ sh:class ngrv:Naeringskode ;
            sh:description "Næringskode(r) verksemda er klassifisert under (1–3)." ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path ngrv:erKlassifisertINaeringskode ],
        [ sh:class ngrv:Kontaktinformasjon ;
            sh:description "Kontaktinformasjon registrert på verksemda." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path ngrv:harKontaktinformasjon ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/id> ],
        [ sh:datatype xsd:integer ;
            sh:description "Antal tilsette i verksemda (rapportert til a-ordninga)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ngrv:antallAnsatte ],
        [ sh:datatype xsd:string ;
            sh:description "Niesifra organisasjonsnummer tildelt av Enhetsregisteret." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ngrv:organisasjonsnummer ],
        [ sh:datatype xsd:string ;
            sh:description "Registrert namn på verksemda i Enhetsregisteret." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ngrv:navn ],
        [ sh:class ngrv:Organisasjonsform ;
            sh:description "Organisasjonsform (juridisk form) for verksemda." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path ngrv:erKlassifisertSomOrganisasjonsform ],
        [ sh:class ngrv:Postadresse ;
            sh:description "Postadressa verksemda mottar post på." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path ngrv:mottarPostPaa ],
        [ sh:class ngrv:Tilstand ;
            sh:description "Registrert tilstand (status) for verksemda, inkl. historikk." ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path ngrv:harTilstand ] ;
    sh:targetClass ngrv:Virksomhet .

ngrv:Hovedenhet a sh:NodeShape ;
    rdfs:comment "Ei hovudeining er den juridiske eininga registrert i Enhetsregisteret (t.d. AS, ENK, BA). Kan ha undereiningar og rolleinnehavarar." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ngrv:Postadresse ;
            sh:description "Postadressa verksemda mottar post på." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path ngrv:mottarPostPaa ],
        [ sh:class ngrv:Forretningsadresse ;
            sh:description "Forretningsadressa (hovudkontor) til hovudeininga." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path ngrv:harForretningsadresse ],
        [ sh:class ngrv:Prokura ;
            sh:description "Prokurabestemmelse(r) for hovudeininga." ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path ngrv:harBestemmelserOmProkura ],
        [ sh:class ngrv:Naeringskode ;
            sh:description "Næringskode(r) verksemda er klassifisert under (1–3)." ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 15 ;
            sh:path ngrv:erKlassifisertINaeringskode ],
        [ sh:class ngrv:Signaturrett ;
            sh:description "Bestemmelse om signaturrett for hovudeininga." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path ngrv:harBestemmelserOmSignaturrett ],
        [ sh:class ngrv:RolleIVirksomhet ;
            sh:description "Roller registrert i hovudeininga (minimum 1)." ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path ngrv:harRolleIVirksomhet ],
        [ sh:class ngrv:Organisasjonsform ;
            sh:description "Organisasjonsform (juridisk form) for verksemda." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path ngrv:erKlassifisertSomOrganisasjonsform ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/id> ],
        [ sh:class ngrv:Aktivitet ;
            sh:description "Aktiviteten hovudeininga utøver." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path ngrv:utoevarAktivitet ],
        [ sh:datatype xsd:string ;
            sh:description "Registrert namn på verksemda i Enhetsregisteret." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path ngrv:navn ],
        [ sh:datatype xsd:integer ;
            sh:description "Antal tilsette i verksemda (rapportert til a-ordninga)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path ngrv:antallAnsatte ],
        [ sh:class ngrv:Varslingsadresse ;
            sh:description "Offisiell varslingsadresse for offentlege meldingar." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path ngrv:harVarslingsadresse ],
        [ sh:class ngrv:Tilstand ;
            sh:description "Registrert tilstand (status) for verksemda, inkl. historikk." ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path ngrv:harTilstand ],
        [ sh:class ngrv:Kontaktinformasjon ;
            sh:description "Kontaktinformasjon registrert på verksemda." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path ngrv:harKontaktinformasjon ],
        [ sh:datatype xsd:date ;
            sh:description "Datoen hovudeininga vart stifta." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ngrv:stiftelsesdato ],
        [ sh:class ngrv:Sektorkode ;
            sh:description "Institusjonell sektorkode for hovudeininga." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path ngrv:erKlassifisertISektorkode ],
        [ sh:datatype xsd:string ;
            sh:description "Niesifra organisasjonsnummer tildelt av Enhetsregisteret." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path ngrv:organisasjonsnummer ] ;
    sh:targetClass ngrv:Hovedenhet .

ngrv:Person a sh:NodeShape ;
    rdfs:comment "Ein fysisk person. Tilhøyrer Domene person og forvaltast av Folkeregisteret. Enhetsregisteret nyttar kopi av data frå Folkeregisteret." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/id> ] ;
    sh:targetClass ngrv:Person .

ngrv:Underenhet a sh:NodeShape ;
    rdfs:comment "Ei underleining er ein geografisk lokasjon der aktiviteten til ei hovudeining vert utøvd. Knyt seg til ei hovudeining via organisasjonsnummeret." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Registrert namn på verksemda i Enhetsregisteret." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path ngrv:navn ],
        [ sh:datatype xsd:date ;
            sh:description "Datoen underleininga vart oppretta/starta." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ngrv:oppstartsdato ],
        [ sh:class ngrv:Naeringskode ;
            sh:description "Næringskode(r) verksemda er klassifisert under (1–3)." ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path ngrv:erKlassifisertINaeringskode ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/id> ],
        [ sh:class ngrv:Beliggenhetsadresse ;
            sh:description "Beliggenheitsadressa til underleininga." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path ngrv:harBeliggenhetsadresse ],
        [ sh:class ngrv:Organisasjonsform ;
            sh:description "Organisasjonsform (juridisk form) for verksemda." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path ngrv:erKlassifisertSomOrganisasjonsform ],
        [ sh:class ngrv:Kontaktinformasjon ;
            sh:description "Kontaktinformasjon registrert på verksemda." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path ngrv:harKontaktinformasjon ],
        [ sh:class ngrv:Varslingsadresse ;
            sh:description "Offisiell varslingsadresse for offentlege meldingar." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path ngrv:harVarslingsadresse ],
        [ sh:class ngrv:Tilstand ;
            sh:description "Registrert tilstand (status) for verksemda, inkl. historikk." ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path ngrv:harTilstand ],
        [ sh:datatype xsd:date ;
            sh:description "Datoen underleininga vart lagt ned." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ngrv:nedleggelsesdato ],
        [ sh:datatype xsd:string ;
            sh:description "Niesifra organisasjonsnummer tildelt av Enhetsregisteret." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ngrv:organisasjonsnummer ],
        [ sh:datatype xsd:integer ;
            sh:description "Antal tilsette i verksemda (rapportert til a-ordninga)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path ngrv:antallAnsatte ],
        [ sh:class ngrv:Postadresse ;
            sh:description "Postadressa verksemda mottar post på." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path ngrv:mottarPostPaa ],
        [ sh:datatype xsd:date ;
            sh:description "Dato(ar) for eigarskifte i underleininga." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ngrv:eierskiftedato ] ;
    sh:targetClass ngrv:Underenhet .

ngrv:Aktivitet a sh:NodeShape ;
    rdfs:comment "Skildring av kva aktivitet ei hovudeining utøver. Svarer til formålsparagrafen eller føremålet til verksemda." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/id> ],
        [ sh:datatype xsd:string ;
            sh:description "Skildring av kva aktivitet verksemda utøver (formålsparagraf o.l.)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ngrv:aktivitetBeskrivelse ] ;
    sh:targetClass ngrv:Aktivitet .

ngrv:Beliggenhetsadresse a sh:NodeShape ;
    rdfs:comment "Beliggenheitsadressa til underleininga – den fysiske adressa der aktiviteten vert utøvd." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/id> ] ;
    sh:targetClass ngrv:Beliggenhetsadresse .

ngrv:Forretningsadresse a sh:NodeShape ;
    rdfs:comment "Forretningsadressa til hovudeininga – adressa der hovudkontoret held til." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/id> ] ;
    sh:targetClass ngrv:Forretningsadresse .

ngrv:Prokura a sh:NodeShape ;
    rdfs:comment "Prokura gjev ein person fullmakt til å handle på vegne av verksemda i næringssaker. Verksemda kan ha fleire prokuraistar." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/id> ],
        [ sh:datatype xsd:string ;
            sh:description "Tekstleg bestemmelse om prokura og kven som er tildelt den." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ngrv:prokurabEstemmelse ] ;
    sh:targetClass ngrv:Prokura .

ngrv:RolleIVirksomhet a sh:NodeShape ;
    rdfs:comment "Ein definert rolle i ei hovudeining (t.d. dagleg leiar, styreleiar). Kvar rolle kan ha éin eller fleire rolleinnehavarar." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Kva type rolle dette er (dagleg leiar, styreleiar o.l.)." ;
            sh:in ( "DAGLIG_LEDER" "STYRELEDER" "STYREMEDLEM" "VARAMEDLEM" "KONTAKTPERSON" "KOMPLEMENTAR" "DELTAKER" "BESTYRENDE_REDAKTOR" "FORRETNINGSFORER" "REVISOR" "REGNSKAPSFORER" "NORSK_REPRESENTANT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path ngrv:rollebetegnelse ],
        [ sh:class ngrv:Rolleinnehaver ;
            sh:description "Rolleinnehavar(ar) for denne rolla." ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path ngrv:harRolleinnehaver ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/id> ] ;
    sh:targetClass ngrv:RolleIVirksomhet .

ngrv:Rolleinnehaver a sh:NodeShape ;
    rdfs:comment "Den som innehar ein rolle i ei verksemd. Kan vere ein fysisk person (frå Folkeregisteret) eller ei anna eining." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ngrv:Person ;
            sh:description "Personen som er rolleinnehavar (frå Folkeregisteret)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path ngrv:kanVaereAvTypePerson ],
        [ sh:datatype xsd:string ;
            sh:description "Namn på rolleinnehavar (nyttes for institusjonelle rollehavarar)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ngrv:rolleinnehaverNavn ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/id> ] ;
    sh:targetClass ngrv:Rolleinnehaver .

ngrv:Sektorkode a sh:NodeShape ;
    rdfs:comment "Institusjonell sektorkode som klassifiserer kva sektor verksemda tilhøyrer (t.d. offentleg, privat)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Tekstleg skildring av sektorkoden." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ngrv:sektorkodeBeskrivelse ],
        [ sh:datatype xsd:string ;
            sh:description "Institusjonell sektorkode (t.d. 1120 for statsforvaltinga)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ngrv:sektorkodeKode ],
        [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/ngr-virksomhet/id> ] ;
    sh:targetClass ngrv:Sektorkode .

ngrv:Signaturrett a sh:NodeShape ;
    rdfs:comment "Bestemmelse om kven som har rett til å signere på vegne av verksemda (t.d. \"Styret i fellesskap\" eller \"Dagleg leiar aleine\")." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Tekstleg bestemmelse om signaturrett (t.d. 'Styret i fellesskap')." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ngrv:signaturrettBestemmelse ],
        [ sh:datatype xsd:anyURI ;
