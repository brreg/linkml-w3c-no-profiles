@prefix ngrp: <https://data.norge.no/vocabulary/ngr-person#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://data.norge.no/ngr/ngr-person/PersonContainer> a sh:NodeShape ;
    rdfs:comment "Rotklasse for NGR-person-datafiler. Held flate lister av alle instansierbare klassar; referansar mellom objekt brukar URI-lenking." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ngrp:ReservasjonMotKommunikasjonPaaNett ;
            sh:nodeKind sh:IRI ;
            sh:order 29 ;
            sh:path <https://data.norge.no/ngr/ngr-person/reservasjonar> ],
        [ sh:class ngrp:Kontaktopplysninger ;
            sh:nodeKind sh:IRI ;
            sh:order 30 ;
            sh:path <https://data.norge.no/ngr/ngr-person/kontaktopplysningar> ],
        [ sh:class ngrp:SpraakForElektroniskKommunikasjon ;
            sh:nodeKind sh:IRI ;
            sh:order 31 ;
            sh:path <https://data.norge.no/ngr/ngr-person/spraak> ],
        [ sh:class ngrp:ForeldreansvarBarn ;
            sh:nodeKind sh:IRI ;
            sh:order 15 ;
            sh:path <https://data.norge.no/ngr/ngr-person/foreldreansvarBarn> ],
        [ sh:class ngrp:RettsligHandleevne ;
            sh:nodeKind sh:IRI ;
            sh:order 28 ;
            sh:path <https://data.norge.no/ngr/ngr-person/rettsligHandleevne> ],
        [ sh:class ngrp:Identitetsgrunnlag ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path <https://data.norge.no/ngr/ngr-person/identitetsgrunnlag> ],
        [ sh:class ngrp:Personidentifikasjon ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path <https://data.norge.no/ngr/ngr-person/personidentifikasjonar> ],
        [ sh:class ngrp:Sivilstand ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path <https://data.norge.no/ngr/ngr-person/sivilstand> ],
        [ sh:class ngrp:Personnavn ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path <https://data.norge.no/ngr/ngr-person/personnavn> ],
        [ sh:class ngrp:Verge ;
            sh:nodeKind sh:IRI ;
            sh:order 27 ;
            sh:path <https://data.norge.no/ngr/ngr-person/verger> ],
        [ sh:class ngrp:FalskIdentitet ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path <https://data.norge.no/ngr/ngr-person/falskIdentitetar> ],
        [ sh:class ngrp:Kjoenn ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path <https://data.norge.no/ngr/ngr-person/kjoenn> ],
        [ sh:class ngrp:Bostedsadresse ;
            sh:nodeKind sh:IRI ;
            sh:order 24 ;
            sh:path <https://data.norge.no/ngr/ngr-person/bostedsadresser> ],
        [ sh:class ngrp:Adressebeskyttelse ;
            sh:nodeKind sh:IRI ;
            sh:order 23 ;
            sh:path <https://data.norge.no/ngr/ngr-person/adressebeskyttelse> ],
        [ sh:class ngrp:Dodsfall ;
            sh:nodeKind sh:IRI ;
            sh:order 19 ;
            sh:path <https://data.norge.no/ngr/ngr-person/dodsfall> ],
        [ sh:class ngrp:InnflyttingTilNorge ;
            sh:nodeKind sh:IRI ;
            sh:order 21 ;
            sh:path <https://data.norge.no/ngr/ngr-person/innflytting> ],
        [ sh:class ngrp:FamilierelasjonBarn ;
            sh:nodeKind sh:IRI ;
            sh:order 17 ;
            sh:path <https://data.norge.no/ngr/ngr-person/familierelasjonBarn> ],
        [ sh:class ngrp:Foedsel ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path <https://data.norge.no/ngr/ngr-person/foedslar> ],
        [ sh:class ngrp:Person ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ngr/ngr-person/personar> ],
        [ sh:class ngrp:DNummer ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path <https://data.norge.no/ngr/ngr-person/dnummer> ],
        [ sh:class ngrp:KontaktinformasjonDoedsbo ;
            sh:nodeKind sh:IRI ;
            sh:order 20 ;
            sh:path <https://data.norge.no/ngr/ngr-person/kontaktinformasjonDoedsbo> ],
        [ sh:class ngrp:Foedselsnummer ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path <https://data.norge.no/ngr/ngr-person/foedselsnummer> ],
        [ sh:class ngrp:ForeldreansvarForelder ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path <https://data.norge.no/ngr/ngr-person/foreldreansvarForelder> ],
        [ sh:class ngrp:Statsborgerskap ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path <https://data.norge.no/ngr/ngr-person/statsborgerskap> ],
        [ sh:class ngrp:Identifikasjonsdokument ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path <https://data.norge.no/ngr/ngr-person/identifikasjonsdokument> ],
        [ sh:class ngrp:Personstatus ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path <https://data.norge.no/ngr/ngr-person/personstatus> ],
        [ sh:class ngrp:UtflyttingFraNorge ;
            sh:nodeKind sh:IRI ;
            sh:order 22 ;
            sh:path <https://data.norge.no/ngr/ngr-person/utflytting> ],
        [ sh:class ngrp:Opphold ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path <https://data.norge.no/ngr/ngr-person/opphold> ],
        [ sh:class ngrp:Postadresse ;
            sh:nodeKind sh:IRI ;
            sh:order 25 ;
            sh:path <https://data.norge.no/ngr/ngr-person/postadresser> ],
        [ sh:class ngrp:Oppholdsadresse ;
            sh:nodeKind sh:IRI ;
            sh:order 26 ;
            sh:path <https://data.norge.no/ngr/ngr-person/oppholdsadresser> ],
        [ sh:class ngrp:FamilierelasjonEktefelle ;
            sh:nodeKind sh:IRI ;
            sh:order 18 ;
            sh:path <https://data.norge.no/ngr/ngr-person/familierelasjonEktefelle> ],
        [ sh:class ngrp:FamilierelasjonForelder ;
            sh:nodeKind sh:IRI ;
            sh:order 16 ;
            sh:path <https://data.norge.no/ngr/ngr-person/familierelasjonForelder> ] ;
    sh:targetClass <https://data.norge.no/ngr/ngr-person/PersonContainer> .

ngrp:GeografiskAdresse a sh:NodeShape ;
    rdfs:comment "Abstrakt klasse for geografiske adresser. Tilhøyrer Domene adresse og forvaltast av Matrikkelen. Konkrete typar er Bostedsadresse, Postadresse og Oppholdsadresse." ;
    sh:closed false ;
    sh:ignoredProperties ( ngrp:gyldigTilOgMed ngrp:gyldigFraOgMed rdf:type ) ;
    sh:property [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ngr/ngr-person/id> ] ;
    sh:targetClass ngrp:GeografiskAdresse .

ngrp:DNummer a sh:NodeShape ;
    rdfs:comment "Elleve-sifra D-nummer tildelt utanlandske personar med mellombels opphald i Noreg (t.d. med d-nummer, om dei har midlertidig eller permanent opphald). Brukes om de har midlertidig eller ikkje har permanent opphald." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Sjølve identifikatoren som tekststreng (11 siffer for fødselsnummer/D-nummer)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ngrp:identifikatornummer ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ngr/ngr-person/id> ] ;
    sh:targetClass ngrp:DNummer .

ngrp:Foedselsnummer a sh:NodeShape ;
    rdfs:comment "Elleve-sifra fødselsnummer tildelt norske statsborgarar og personar med fast opphald i Noreg." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Sjølve identifikatoren som tekststreng (11 siffer for fødselsnummer/D-nummer)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ngrp:identifikatornummer ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ngr/ngr-person/id> ] ;
    sh:targetClass ngrp:Foedselsnummer .

ngrp:Folkeregisteridentifikator a sh:NodeShape ;
    rdfs:comment "Abstrakt overklasse for unik identifikator i Folkeregisteret. Konkrete underklassar er Fødselsnummer og D-nummer." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Sjølve identifikatoren som tekststreng (11 siffer for fødselsnummer/D-nummer)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ngrp:identifikatornummer ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ngr/ngr-person/id> ] ;
    sh:targetClass ngrp:Folkeregisteridentifikator .

ngrp:Adressebeskyttelse a sh:NodeShape ;
    rdfs:comment "Gradering av adressebeskyttelse for innflyttede personar til Noreg. Tidlegare kalla kode 6 (strengt fortroleg) og kode 7 (fortroleg)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ngr/ngr-person/id> ],
        [ sh:description "Graderinga av adressebeskyttelsen (STRENGT_FORTROLIG, FORTROLIG o.l.)." ;
            sh:in ( "STRENGT_FORTROLIG" "FORTROLIG" "STRENGT_FORTROLIG_UTLAND" "UGRADERT" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path ngrp:adressebeskyttelseGradering ] ;
    sh:targetClass ngrp:Adressebeskyttelse .

ngrp:Bostedsadresse a sh:NodeShape ;
    rdfs:comment "Adressa personen er registrert busett på i Folkeregisteret." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path <https://data.norge.no/ngr/ngr-person/id> ],
        [ sh:datatype xsd:date ;
            sh:description "Dato opplysinga er gyldig frå og med." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path ngrp:gyldigFraOgMed ],
        [ sh:datatype xsd:date ;
            sh:description "Dato opplysinga er gyldig til og med." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ngrp:gyldigTilOgMed ] ;
    sh:targetClass ngrp:Bostedsadresse .

ngrp:Dodsfall a sh:NodeShape ;
    rdfs:comment "Dødsfallsinformasjon om ein person registrert i Folkeregisteret." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ngr/ngr-person/id> ],
        [ sh:datatype xsd:string ;
            sh:description "Stad for dødsfallet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ngrp:doedssted ],
        [ sh:datatype xsd:date ;
            sh:description "Dato for dødsfallet." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ngrp:doedsdato ] ;
    sh:targetClass ngrp:Dodsfall .

ngrp:FalskIdentitet a sh:NodeShape ;
    rdfs:comment "Registrering av at ein person har opptrådt med falsk identitet. Kan peke på den rette identiteten om denne er kjent." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ngrp:Person ;
            sh:description "Den rette identiteten til ein person som har opptrådt med falsk identitet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path ngrp:rettIdentitet ],
        [ sh:datatype xsd:boolean ;
            sh:description "Om denne identiteten er registrert som falsk." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ngrp:erFalsk ],
        [ sh:datatype xsd:boolean ;
            sh:description "Om den rette identiteten er ukjent (når falsk identitet er registrert)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ngrp:rettIdentitetErUkjent ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ngr/ngr-person/id> ] ;
    sh:targetClass ngrp:FalskIdentitet .

ngrp:FamilierelasjonBarn a sh:NodeShape ;
    rdfs:comment "Familierelasjon der den relaterte personen er barn." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ngr/ngr-person/id> ],
        [ sh:class ngrp:Person ;
            sh:description "Personen som denne relasjonen peikar til." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path ngrp:erAvTypePerson ] ;
    sh:targetClass ngrp:FamilierelasjonBarn .

ngrp:FamilierelasjonEktefelle a sh:NodeShape ;
    rdfs:comment "Familierelasjon der den relaterte personen er ektefelle eller registrert partnar. Dette er strengt tatt same informasjon som sivilstand GIFT." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ngrp:Person ;
            sh:description "Personen som denne relasjonen peikar til." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path ngrp:erAvTypePerson ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ngr/ngr-person/id> ] ;
    sh:targetClass ngrp:FamilierelasjonEktefelle .

ngrp:FamilierelasjonForelder a sh:NodeShape ;
    rdfs:comment "Familierelasjon der den relaterte personen er forelder." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class ngrp:Person ;
            sh:description "Personen som denne relasjonen peikar til." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path ngrp:erAvTypePerson ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ngr/ngr-person/id> ],
        [ sh:datatype xsd:string ;
            sh:description "Type foreldrerelasjon (MOR, FAR, MEDMOR o.l.)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ngrp:foreldrerelasjonType ] ;
    sh:targetClass ngrp:FamilierelasjonForelder .

ngrp:Foedsel a sh:NodeShape ;
    rdfs:comment "Fødselsinformasjon om ein person registrert i Folkeregisteret." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ngr/ngr-person/id> ],
        [ sh:datatype xsd:date ;
            sh:description "Fødselsdato (kan vere ukjent for eldre registreringar)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ngrp:foedselsdato ],
        [ sh:datatype xsd:integer ;
            sh:description "Fødselsår (alltid tilgjengeleg, sjølv om fullstendig dato manglar)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ngrp:foedselsaar ],
        [ sh:datatype xsd:string ;
            sh:description "Fødested (kommune eller land)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ngrp:foedested ] ;
    sh:targetClass ngrp:Foedsel .

ngrp:ForeldreansvarBarn a sh:NodeShape ;
    rdfs:comment "Relasjonsklasse som registrerer at eit barn er under foreldreansvaret til ein person." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ngr/ngr-person/id> ],
        [ sh:class ngrp:Person ;
            sh:description "Personen som denne relasjonen peikar til." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path ngrp:erAvTypePerson ] ;
    sh:targetClass ngrp:ForeldreansvarBarn .

ngrp:ForeldreansvarForelder a sh:NodeShape ;
    rdfs:comment "Relasjonsklasse som registrerer kven som har det juridiske foreldreansvaret for eit barn. Seier kven som er den ansvarlege forelderen." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ngr/ngr-person/id> ],
        [ sh:datatype xsd:string ;
            sh:description "Status for foreldreansvaret (t.d. FELLES, ALENE)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ngrp:ansvarsstatus ],
        [ sh:class ngrp:Person ;
            sh:description "Personen som denne relasjonen peikar til." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path ngrp:erAvTypePerson ] ;
    sh:targetClass ngrp:ForeldreansvarForelder .

ngrp:Identifikasjonsdokument a sh:NodeShape ;
    rdfs:comment "Utanlandsk identifikasjonsdokument som pass, førekort eller nasjonalt ID-kort knytt til ein person." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Nummeret på identifikasjonsdokumentet." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ngrp:dokumentnummer ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ngr/ngr-person/id> ],
        [ sh:description "Type identifikasjonsdokument (pass, førekort, nasjonalt ID-kort o.l.)." ;
            sh:in ( "PASS" "FOERERKORT" "NASJONAL_ID_KORT" "OPPHOLDSTILLATELSE" "ANNET" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path ngrp:dokumenttype ],
        [ sh:datatype xsd:date ;
            sh:description "Datoen dokumentet vart utstedt." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path ngrp:utstedtdato ],
        [ sh:datatype xsd:string ;
            sh:description "ISO 3166-1 landkode for landet som utsteda dokumentet." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path ngrp:utstederland ],
        [ sh:datatype xsd:date ;
            sh:description "Datoen dokumentet går ut på dato." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path ngrp:utloepsdato ] ;
    sh:targetClass ngrp:Identifikasjonsdokument .

ngrp:Identitetsgrunnlag a sh:NodeShape ;
    rdfs:comment "Grunnlaget som er brukt for å fastsetje identiteten til ein person ved registrering i Folkeregisteret." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Status/type for identitetsgrunnlaget (t.d. FOLKEREGISTERET, PASS)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path ngrp:identitetsgrunnlagStatus ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ngr/ngr-person/id> ],
        [ sh:datatype xsd:string ;
            sh:description "Kjelde for identitetsgrunnlaget." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path ngrp:identitetsgrunnlagKilde ] ;
    sh:targetClass ngrp:Identitetsgrunnlag .

ngrp:InnflyttingTilNorge a sh:NodeShape ;
    rdfs:comment "Registrering av innflytting til Noreg i Folkeregisteret." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/ngr/ngr-person/id> ],
        [ sh:datatype xsd:string ;
            sh:description "ISO 3166-1 landkode for landet personen flytta frå." ;
            sh:maxCount 1 ;
