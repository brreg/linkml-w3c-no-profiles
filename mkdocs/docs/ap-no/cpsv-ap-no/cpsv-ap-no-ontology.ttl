        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ap-no/cpsv-ap-no/Kontaktpunkt> ;
            owl:onProperty <https://data.norge.no/ap-no/cpsv-ap-no/har_kontaktpunkt> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/heimeside> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/identifikator_literal> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/dekningsomraade> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/cpsv-ap-no/utgjevar> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdf:langString ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/tittel> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/identifikator_literal> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/endringsdato> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/cpsv-ap-no/utgjevar> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ap-no/cpsv-ap-no/OffentligTjeneste> ;
            owl:onProperty <https://data.norge.no/ap-no/cpsv-ap-no/inneheld_teneste> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
