"PersonContainer" *--> "0..*" "ReservasjonMotKommunikasjonPaaNett" : "reservasjonar"
class "Personstatus" [[{Status for ein person i Folkeregisteret (t.d. bosatt, utflyttet, død).}]] {
    {field} id : uriorcurie  
    {field} personstatus_type : PersonstatusType  
    {field} gyldig_fra_og_med : date  
}
"Person" --> "1" "Personstatus" : "har_personstatus"
"Person" --> "0..1" "Personstatus" : "har_personstatus"(i)
"PersonContainer" *--> "0..*" "Personstatus" : "personstatus"
class "Personnavn" [[{Offisielt registrert namn på ein person i Folkeregisteret.}]] {
    {field} id : uriorcurie  
    {field} fornavn : string  
    {field} mellomnavn : string  
