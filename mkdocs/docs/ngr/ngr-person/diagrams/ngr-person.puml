}
class "Identitetsgrunnlag" [[{Grunnlaget som er brukt for å fastsetje identiteten til ein person ved registrering i Folkeregisteret.}]] {
    {field} id : uriorcurie  
    {field} identitetsgrunnlag_status : string  
