    skos:inScheme <https://data.norge.no/linkml/fint-arkiv> .

<https://schema.fintlabs.no/arkiv/:tilknyttetDato> a owl:DatatypeProperty ;
    rdfs:label "tilknyttetDato" ;
    rdfs:range xsd:dateTime ;
