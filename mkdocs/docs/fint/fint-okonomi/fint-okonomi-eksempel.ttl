@prefix fint: <https://schema.fintlabs.no/> .
@prefix okn: <https://schema.fintlabs.no/okonomi/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.no/fint/faktura/f-2024-001> a okn:Faktura ;
    okn:belop 15625000 ;
    okn:betalt false ;
    okn:dato "2024-04-01"^^xsd:date ;
    okn:fakturagrunnlag <https://example.no/fint/fakturagrunnlag/fg-2024-001> ;
    okn:fakturanummer [ a fint:Identifikator ;
            fint:identifikatorverdi "F-2024-001" ] ;
    okn:fakturert true ;
    okn:forfallsdato "2024-05-01"^^xsd:date ;
    okn:kreditert false ;
    okn:mottaker "Ola Nordmann" ;
    okn:restbelop 15625000 .

<https://example.no/fint/faktura/f-2024-002> a okn:Faktura ;
    okn:belop 8750000 ;
    okn:betalt true ;
    okn:dato "2024-04-15"^^xsd:date ;
    okn:fakturagrunnlag <https://example.no/fint/fakturagrunnlag/fg-2024-001> ;
    okn:fakturanummer [ a fint:Identifikator ;
            fint:identifikatorverdi "F-2024-002" ] ;
    okn:fakturert true ;
    okn:forfallsdato "2024-05-15"^^xsd:date ;
    okn:kreditert false ;
    okn:mottaker "Leverandør AS" ;
    okn:restbelop 0 .

<https://example.no/fint/leverandor/leverandor-1> a okn:Leverandor ;
    okn:kontonummer "1503.12.34567" ;
    okn:leverandornummer [ a fint:Identifikator ;
            fint:identifikatorverdi "LEV001" ] .

<https://example.no/fint/merverdiavgift/mva25> a okn:Merverdiavgift ;
    fint:kode "25" ;
    fint:navn "Standard MVA 25%" ;
    okn:sats 25 .

<https://example.no/fint/vare/konsulenttenester> a okn:Vare ;
    fint:kode "KON" ;
    fint:navn "Konsulenttjenester" ;
    okn:enhet "time" ;
    okn:fakturautsteder <https://example.no/fint/fakturautsteder/kommunen> ;
    okn:merverdiavgift <https://example.no/fint/merverdiavgift/mva25> ;
    okn:pris 1250000 .

<https://example.no/fint/fakturagrunnlag/fg-2024-001> a okn:Fakturagrunnlag ;
    okn:avgiftsbelop 3125000 ;
    okn:fakturalinjer [ a okn:Fakturalinje ;
            okn:antall "10.0"^^xsd:float ;
            okn:fritekst "Konsulenttimer mars 2024" ;
            okn:pris 1250000 ;
            okn:vare <https://example.no/fint/vare/konsulenttenester> ] ;
    okn:fakturamottaker [ a okn:Fakturamottaker ;
            fint:person <https://example.no/fint/person/ola-nordmann> ] ;
    okn:fakturautsteder <https://example.no/fint/fakturautsteder/kommunen> ;
    okn:leveringsdato "2024-03-31"^^xsd:date ;
    okn:nettobelop 12500000 ;
    okn:ordrenummer [ a fint:Identifikator ;
            fint:identifikatorverdi "ORD-2024-001" ] ;
    okn:totalbelop 15625000 .

<https://example.no/fint/fakturautsteder/kommunen> a okn:Fakturautsteder ;
    fint:navn "Eksempel kommune" .

[] a <https://schema.fintlabs.no/okonomi/:OkonomiContainer> ;
    okn:fakturaer <https://example.no/fint/faktura/f-2024-001>,
        <https://example.no/fint/faktura/f-2024-002> ;
    okn:fakturagrunnlag <https://example.no/fint/fakturagrunnlag/fg-2024-001> ;
    okn:fakturautstederear <https://example.no/fint/fakturautsteder/kommunen> ;
    okn:leverandorar <https://example.no/fint/leverandor/leverandor-1> ;
    okn:merverdiavgifter <https://example.no/fint/merverdiavgift/mva25> ;
    okn:varer <https://example.no/fint/vare/konsulenttenester> .

