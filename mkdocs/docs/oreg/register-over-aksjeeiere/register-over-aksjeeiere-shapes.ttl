            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:identifikator> ],
        [ sh:datatype xsd:string ;
            sh:description "Tekstleg forklaring av instansen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:beskrivelse> ],
        [ sh:class <https://data.norge.no/linkml/register-over-aksjeeiere/:Aksjeklasse> ;
            sh:description "Rettigheiter knytt til aksjeklassen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:gjelder_aksjer_i_aksjeklasse> ] ;
    sh:targetClass <https://data.norge.no/linkml/register-over-aksjeeiere/:Aksjeeierrettighet> .

<https://data.norge.no/linkml/register-over-aksjeeiere/:Aksjeselskap> a sh:NodeShape ;
    rdfs:comment "Selskap som utsteder aksjar og har aksjekapital." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Namn på instansen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:navn> ],
        [ sh:description "Global identifikator for instansen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:identifikator> ],
        [ sh:class <https://data.norge.no/linkml/register-over-aksjeeiere/:Aksje> ;
            sh:description "Aksje utstedt av selskapet" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path <https://data.norge.no/linkml/register-over-aksjeeiere/:utsteder_aksje> ],
        [ sh:class <https://data.norge.no/linkml/register-over-aksjeeiere/:Aksjekapital> ;
            sh:description "Aksjekapital som høyrer til selskapet." ;
            sh:maxCount 1 ;
