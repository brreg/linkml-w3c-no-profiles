    {field} forkortet_navn : string  
}
"Person" --> "1" "Personnavn" : "har_personnavn"
"Person" --> "0..1" "Personnavn" : "har_personnavn"(i)
"PersonContainer" *--> "0..*" "Personnavn" : "personnavn"
class "Personidentifikasjon" [[{Utanlandsk eller alternativ identifikasjon av ein person, t.d. UDIs DUF-nummer, utanlandsk skatteidentifikasjon eller social security number.}]] {
    {field} id : uriorcurie  
    {field} identifikasjonstype : string  
    {field} identifikatornummer : string  
}
"Person" --> "0..*" "Personidentifikasjon" : "har_personidentifikasjon"
"Person" --> "0..*" "Personidentifikasjon" : "har_personidentifikasjon"(i)
"PersonContainer" *--> "0..*" "Personidentifikasjon" : "personidentifikasjonar"
class "Kontaktopplysninger" [[{Kontaktopplysningar (e-post og mobilnummer) for digital kommunikasjon med det offentlege. Forvaltast av Kontakt- og reservasjonsregisteret (KRR).}]] {
    {field} id : uriorcurie  
    {field} epostadresse_verdi : string  
    {field} mobiltelefonnummer : string  
    {field} sist_oppdatert : date  
}
class "Oppholdsadresse" [[{Adressa der personen faktisk oppheld seg (ikkje nødvendigvis bustadsadressa).}]] {
    {field} gyldig_fra_og_med : date  
    {field} gyldig_til_og_med : date  
    {field} id(i) : uriorcurie  
}
class "Postadresse" [[{Adressa der personen mottar post.}]] {
    {field} gyldig_fra_og_med : date  
    {field} gyldig_til_og_med : date  
    {field} id(i) : uriorcurie  
}
class "Bostedsadresse" [[{Adressa personen er registrert busett på i Folkeregisteret.}]] {
    {field} gyldig_fra_og_med : date  
    {field} gyldig_til_og_med : date  
    {field} id(i) : uriorcurie  
}
class "Adressebeskyttelse" [[{Gradering av adressebeskyttelse for innflyttede personar til Noreg. Tidlegare kalla kode 6 (strengt fortroleg) og kode 7 (fortroleg).}]] {
    {field} id : uriorcurie  
    {field} adressebeskyttelse_gradering : AdressebeskyttelseGradering  
}
class "InnflyttingTilNorge" [[{Registrering av innflytting til Noreg i Folkeregisteret.}]] {
    {field} id : uriorcurie  
    {field} fraflyttingsland : string  
    {field} fraflyttingssted_i_utlandet : string  
    {field} innflyttingsdato : date  
}
class "KontaktinformasjonDoedsbo" [[{Kontaktinformasjon for eit dødsbu.}]] {
    {field} id : uriorcurie  
    {field} navn : string  
    {field} telefonnummer : string  
    {field} epostadresse_verdi : string  
}
class "Dodsfall" [[{Dødsfallsinformasjon om ein person registrert i Folkeregisteret.}]] {
    {field} id : uriorcurie  
    {field} doedsdato : date  
    {field} doedssted : string  
}
class "FamilierelasjonEktefelle" [[{Familierelasjon der den relaterte personen er ektefelle eller registrert partnar. Dette er strengt tatt same informasjon som sivilstand GIFT.}]] {
    {field} id : uriorcurie  
}
class "FamilierelasjonBarn" [[{Familierelasjon der den relaterte personen er barn.}]] {
    {field} id : uriorcurie  
}
class "FamilierelasjonForelder" [[{Familierelasjon der den relaterte personen er forelder.}]] {
    {field} id : uriorcurie  
    {field} foreldrerelasjon_type : string  
}
class "ForeldreansvarBarn" [[{Relasjonsklasse som registrerer at eit barn er under foreldreansvaret til ein person.}]] {
