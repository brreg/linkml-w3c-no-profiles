        "/mnt/c/dev/github/linkml-w3c-no-profiles/src/mcp-json2linkml/profiles:/app/profiles:ro",
        "mcp-json2linkml"
      ],
      "env": {}
    },
    "linkml-validator": {
      "type": "stdio",
      "command": "podman",
      "args": [
        "run",
        "-i",
        "--rm",
        "-v",
