utd:FagvurderingAbstrakt a sh:NodeShape ;
    rdfs:comment "Abstrakt basisklasse for fagvurderingar." ;
    sh:closed false ;
    sh:ignoredProperties ( utd:elevvurdering utd:karakterhistorie utd:eksamensgruppe rdf:type ) ;
    sh:property [ sh:class utd:Fag ;
            sh:description "Fag." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path utd:fag ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Dato og tidspunkt for vurderinga." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path utd:vurderingsdato ],
        [ sh:class utd:Skoleaar ;
            sh:description "Skoleåret." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path utd:skoleaar ],
        [ sh:datatype xsd:string ;
            sh:description "Kommentar." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path utd:kommentar ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/:id> ],
        [ sh:class utd:Karakterverdi ;
            sh:description "Karakterverdi." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path utd:karakter ] ;
    sh:targetClass utd:FagvurderingAbstrakt .

utd:Gruppe a sh:NodeShape ;
    rdfs:comment "Abstrakt basisklasse for alle gruppetypar i utdanning." ;
    sh:closed false ;
    sh:ignoredProperties ( fint:elev utd:trinn utd:gruppemedlemskap utd:persongruppemedlemskap utd:termin utd:skuletime utd:klassemedlemskap rdf:type utd:kontaktlaerergruppe utd:skoleressurs utd:eksamensform utd:eksamensdato utd:skole utd:eksamen utd:sensor utd:faggruppemedlemskap utd:faggruppe utd:skoleaar utd:undervisningsgruppe utd:eksamensgruppe utd:undervisningsforhold utd:grepreferanse utd:vigoreferanse utd:fag utd:klasse utd:programomrade utd:tilrettelegging ) ;
    sh:property [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/:id> ],
        [ sh:datatype xsd:string ;
            sh:description "Beskriven namn eller omtale." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path fint:beskrivelse ],
        [ sh:datatype xsd:string ;
            sh:description "Hovudnamn for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path fint:navn ] ;
    sh:targetClass utd:Gruppe .

utd:Gruppemedlemskap a sh:NodeShape ;
    rdfs:comment "Abstrakt basisklasse for gruppemedlemskapar i utdanning." ;
    sh:closed false ;
    sh:ignoredProperties ( utd:kandidatnummer utd:nus utd:betalingsstatus rdf:type utd:kontaktlaerergruppe utd:delegert utd:elevforhold utd:foretrukketSensor utd:fagmerknad utd:faggruppe utd:varsel utd:undervisningsgruppe utd:eksamensgruppe utd:persongruppe utd:foretrukketSkole utd:delegertTil utd:klasse utd:programomrade utd:fagstatus ) ;
    sh:property [ sh:class fint:Periode ;
            sh:description "Periode ressursen er gyldig for." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path fint:gyldighetsperiode ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/:id> ] ;
    sh:targetClass utd:Gruppemedlemskap .

utd:OrdensvurderingAbstrakt a sh:NodeShape ;
