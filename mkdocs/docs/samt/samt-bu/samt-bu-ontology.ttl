@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix samtbuskole: <https://example.no/ontology/skole#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://data.norge.no/linkml/common-ap-no/anbefalt_term> a owl:DatatypeProperty ;
    rdfs:label "anbefalt_term" ;
    rdfs:range rdf:langString ;
    skos:definition "Føretrukke term/namn for ressursen (skos:prefLabel)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/dcat-ap-no/referanse> a owl:DatatypeProperty ;
    rdfs:label "referanse" ;
    rdfs:range xsd:anyURI ;
    skos:definition "Referanse til ekstern ressurs." ;
    skos:inScheme <https://data.norge.no/linkml/dcat-ap-no> .

<https://data.norge.no/linkml/dcat-ap-no/tittel_literal> a owl:DatatypeProperty ;
    rdfs:label "tittel_literal" ;
    rdfs:range xsd:string ;
    skos:definition "Namn/tittel utan språktag." ;
    skos:inScheme <https://data.norge.no/linkml/dcat-ap-no> .

<https://data.norge.no/linkml/dqv-ap-no/Kvalitetssertifikat> a owl:Class ;
    rdfs:label "Kvalitetssertifikat" ;
    rdfs:subClassOf <https://data.norge.no/linkml/dqv-ap-no/Kvalitetsmerknad> ;
    skos:definition "Eit sertifikat som stadfester kvaliteten til eit datasett." ;
    skos:exactMatch <http://www.w3.org/ns/dqv#QualityCertificate> ;
    skos:inScheme <https://data.norge.no/linkml/dqv-ap-no> .

<https://example.no/ontology/samt-bu-skole.owl.ttl> a owl:Ontology ;
    rdfs:label "skole_ontologi" ;
    dcterms:title "Skoleontologi (Ontodia-vennlig)" ;
    skos:definition "Ontodia-vennlig LinkML-modell for skoler" .

samtbuskole:Containerklasse a owl:Class ;
    rdfs:label "Containerklasse" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:organisasjoner ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:tidsromer ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:kontaktlaerere ],
        [ a owl:Restriction ;
            owl:allValuesFrom samtbuskole:Basisgruppe ;
            owl:onProperty samtbuskole:basisgrupper ],
        [ a owl:Restriction ;
            owl:allValuesFrom samtbuskole:Skole ;
            owl:onProperty samtbuskole:skoler ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:kvalitetsmaalinger ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:datasettdistribusjoner ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:dataset_metadata ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:kvalitetsdimensjoner ],
        [ a owl:Restriction ;
            owl:allValuesFrom samtbuskole:Fylke ;
            owl:onProperty samtbuskole:fylker ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/dcat-ap-no/Aktor> ;
            owl:onProperty samtbuskole:organisasjoner ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:standarder ],
        [ a owl:Restriction ;
            owl:allValuesFrom samtbuskole:Rektor ;
            owl:onProperty samtbuskole:rektorer ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/dcat-ap-no/Aktor> ;
            owl:onProperty samtbuskole:grupper ],
        [ a owl:Restriction ;
            owl:allValuesFrom samtbuskole:PrivatVirksomhet ;
            owl:onProperty samtbuskole:private_virksomheter ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/dqv-ap-no/Kvalitetsmerknad> ;
            owl:onProperty samtbuskole:kvalitetsmerknader ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:utgivere ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:kvalitetsmerknader ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:skoler ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:tekstdeler ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/dqv-ap-no/Brukartilbakemelding> ;
            owl:onProperty samtbuskole:brukertilbakemeldinger ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:elever ],
        [ a owl:Restriction ;
            owl:allValuesFrom samtbuskole:Kontaktlaerer ;
            owl:onProperty samtbuskole:kontaktlaerere ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/dcat-ap-no/Kontaktopplysning> ;
            owl:onProperty samtbuskole:kontaktpunkter ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:gjeldende_lovgivninger ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:private_virksomheter ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/dqv-ap-no/Kvalitetsdimensjon> ;
            owl:onProperty samtbuskole:kvalitetsdimensjoner ],
        [ a owl:Restriction ;
            owl:allValuesFrom samtbuskole:Kommune ;
            owl:onProperty samtbuskole:kommuner ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/dcat-ap-no/Aktor> ;
            owl:onProperty samtbuskole:utgivere ],
        [ a owl:Restriction ;
            owl:allValuesFrom samtbuskole:Elev ;
            owl:onProperty samtbuskole:elever ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:brukertilbakemeldinger ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:grupper ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:kommuner ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/dqv-ap-no/Standard> ;
            owl:onProperty samtbuskole:standarder ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:kontaktpunkter ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/dqv-ap-no/Kvalitetsmaaling> ;
            owl:onProperty samtbuskole:kvalitetsmaalinger ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:rektorer ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/dcat-ap-no/RegulativRessurs> ;
            owl:onProperty samtbuskole:gjeldende_lovgivninger ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/dcat-ap-no/Tidsrom> ;
            owl:onProperty samtbuskole:tidsromer ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:fylker ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/dcat-ap-no/Datasett> ;
            owl:onProperty samtbuskole:dataset_metadata ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/dqv-ap-no/Tekstdel> ;
            owl:onProperty samtbuskole:tekstdeler ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/dcat-ap-no/Distribusjon> ;
            owl:onProperty samtbuskole:datasettdistribusjoner ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:basisgrupper ] ;
    skos:definition "Containerklasse for alle klasser som kan inngå i datasettet." ;
    skos:inScheme <https://example.no/ontology/samt-bu-skole> .

xsd:duration a rdfs:Datatype .

xsd:gYear a rdfs:Datatype .

xsd:nonNegativeInteger a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:onDatatype xsd:integer ;
            owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] .

<https://data.norge.no/linkml/common-ap-no/Begrepssamling> a owl:Class ;
    rdfs:label "Begrepssamling" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ] ;
    skos:definition "Ei SKOS-omgrepssamling (temavokabular)." ;
    skos:exactMatch skos:ConceptScheme ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/heimeside> a owl:DatatypeProperty ;
    rdfs:label "heimeside" ;
    rdfs:range xsd:anyURI ;
    skos:definition "Heimeside for ressursen eller organisasjonen (foaf:homepage)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

