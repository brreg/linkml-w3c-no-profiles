ngrv:Naeringskode a sh:NodeShape ;
    rdfs:comment "Næringskode basert på SSBs Standard for næringsgruppering (SN2007/NACE). Ei verksemd kan ha 1–3 næringskoder." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
