            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/ligger_innenfor_kommune> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/ngr/ngr-eiendom/id> ],
        [ a owl:Restriction ;
