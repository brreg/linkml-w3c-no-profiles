res:Status a sh:NodeShape ;
    rdfs:comment "Status på ei digital eining i fagsystemet." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
