            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://schema.fintlabs.no/:fodselsdato> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Spraak> ;
            owl:onProperty <https://schema.fintlabs.no/:maalform> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Personnavn> ;
            owl:onProperty <https://schema.fintlabs.no/:person_navn> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Person> ;
            owl:onProperty <https://schema.fintlabs.no/:foreldre> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Landkode> ;
            owl:onProperty <https://schema.fintlabs.no/:statsborgerskap> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Kommune> ;
            owl:onProperty <https://schema.fintlabs.no/:kommune> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:person_navn> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:kommune> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://schema.fintlabs.no/:personalressurs> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:fodselsnummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:bilde> ],
        <https://schema.fintlabs.no/:Aktoer> ;
    skos:definition "Fysiske private personar." ;
    skos:exactMatch fint:Person ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:Identifikator> a owl:Class ;
    rdfs:label "Identifikator" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:gyldighetsperiode> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:identifikatorverdi> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Periode> ;
            owl:onProperty <https://schema.fintlabs.no/:gyldighetsperiode> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:identifikatorverdi> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:identifikatorverdi> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:gyldighetsperiode> ] ;
    skos:definition "Unik identifikasjon til eit objekt." ;
    skos:exactMatch fint:Identifikator ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:navn> a owl:DatatypeProperty ;
    rdfs:label "navn" ;
    rdfs:range xsd:string ;
    skos:definition "Hovudnamn for ressursen." ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:gyldighetsperiode> a owl:ObjectProperty ;
    rdfs:label "gyldighetsperiode" ;
    rdfs:range <https://schema.fintlabs.no/:Periode> ;
    skos:definition "Periode ressursen er gyldig for." ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:id> a owl:DatatypeProperty ;
    rdfs:label "id" ;
    rdfs:range xsd:anyURI ;
    skos:definition "URI-identifikator for ressursen." ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .


