    linkml:definition_uri "https://data.norge.no/linkml/ngr-eiendom/Eierseksjon"^^xsd:anyURI ;
    linkml:description "Ein eigarseksjon er ein eigarandel i ein seksjonert eigedom. Eigaren har einerett til å bruke ein bestemt del av eigedommen, medan heile eigedommen er i sameige med dei andre seksjonseigarane. Eigedommen som er seksjonert kan vere grunneigendom, festegrunn eller anleggseigendom." ;
    linkml:is_a <https://data.norge.no/linkml/ngr-eiendom/Matrikkelenhet> ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://data.norge.no/linkml/ngr-eiendom/Eierseksjon_kan_vaere_pa>,
        <https://data.norge.no/linkml/ngr-eiendom/Matrikkelenhet_er_del_av_teig>,
        <https://data.norge.no/linkml/ngr-eiendom/Matrikkelenhet_har_anleggsprojeksjonsflate>,
        <https://data.norge.no/linkml/ngr-eiendom/Matrikkelenhet_har_teig>,
        <https://data.norge.no/linkml/ngr-eiendom/Matrikkelenhet_identifiseres_med>,
        <https://data.norge.no/linkml/ngr-eiendom/Matrikkelenhet_ligger_innenfor_kommune>,
        <https://data.norge.no/linkml/ngr-eiendom/id> .

