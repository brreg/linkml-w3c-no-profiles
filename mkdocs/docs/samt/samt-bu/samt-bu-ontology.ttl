samtbuskole:Fylke a owl:Class ;
    rdfs:label "Fylke" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:fylkesnummer ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty samtbuskole:fylkesnummer ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty samtbuskole:fylkesnummer ],
        samtbuskole:Skoleeier ;
    skos:definition "Fylke (etter norrønt fylki) er en betegnelse på et undernasjonalt, regionalt geografisk område, tilsvarende amt og len." ;
    skos:exactMatch org:Organization ;
    skos:inScheme <https://example.no/ontology/samt-bu-skole> .

samtbuskole:Kommune a owl:Class ;
    rdfs:label "Kommune" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty samtbuskole:kommunenummer ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:kommunenummer ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty samtbuskole:kommunenummer ],
        samtbuskole:Skoleeier ;
    skos:definition "En kommune er et geografisk avgrenset område som utgjør en egen politisk og administrativ enhet innen en statsdannelse." ;
    skos:exactMatch org:Organization ;
    skos:inScheme <https://example.no/ontology/samt-bu-skole> .

