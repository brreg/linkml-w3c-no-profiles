samtbuskole:Person a owl:Class ;
    rdfs:label "Person" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:navn ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty samtbuskole:navn ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty samtbuskole:navn ] ;
    skos:definition "Eit menneske individ" ;
    skos:exactMatch foaf:Person ;
    skos:inScheme <https://example.no/ontology/samt-bu-skole> .

samtbuskole:Rektor a owl:Class ;
    rdfs:label "Rektor" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:enhetsleder_for ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty samtbuskole:enhetsleder_for ],
        [ a owl:Restriction ;
            owl:allValuesFrom samtbuskole:Skole ;
            owl:onProperty samtbuskole:enhetsleder_for ],
        samtbuskole:Person ;
    skos:definition "Høgaste akademiske leder av en skole" ;
    skos:inScheme <https://example.no/ontology/samt-bu-skole> .

samtbuskole:del_av_skole a owl:ObjectProperty ;
    rdfs:label "del_av_skole" ;
    rdfs:domain samtbuskole:Basisgruppe ;
    rdfs:range samtbuskole:Skole ;
    skos:closeMatch <http://schema.org/isPartOf> ;
    skos:definition "Skolen basisgruppa tilhører" ;
    skos:inScheme <https://example.no/ontology/samt-bu-skole> .

samtbuskole:enhetsleder_for a owl:ObjectProperty ;
    rdfs:label "enhetsleder_for" ;
    rdfs:domain samtbuskole:Rektor ;
    rdfs:range samtbuskole:Skole ;
    skos:closeMatch org:headOf ;
    skos:definition "Enhet rektor er enhetsleder for" ;
    skos:inScheme <https://example.no/ontology/samt-bu-skole> .

samtbuskole:fylkesnummer a owl:DatatypeProperty ;
    rdfs:label "fylkesnummer" ;
    rdfs:range xsd:string ;
    skos:closeMatch skos:notation ;
    skos:definition "Fylkesnummer er definerte identifikasjonskoder for Norges fylker og to territorier (Svalbard og Jan Mayen)." ;
    skos:inScheme <https://example.no/ontology/samt-bu-skole> .

samtbuskole:har_saerlig_ansvar_for a owl:ObjectProperty ;
    rdfs:label "har_saerlig_ansvar_for" ;
    rdfs:domain samtbuskole:Kontaktlaerer ;
    rdfs:range samtbuskole:Elev ;
    skos:definition "Elev kontaktlæreren har særlig ansvar for" ;
    skos:inScheme <https://example.no/ontology/samt-bu-skole> .

samtbuskole:har_skoleeier a owl:ObjectProperty ;
    rdfs:label "har_skoleeier" ;
    rdfs:domain samtbuskole:Skole ;
    rdfs:range samtbuskole:Skoleeier ;
    skos:definition "Skoleeier for skolen" ;
    skos:exactMatch org:hasUnit ;
    skos:inScheme <https://example.no/ontology/samt-bu-skole> .

samtbuskole:horer_til_basisgruppe a owl:ObjectProperty ;
    rdfs:label "horer_til_basisgruppe" ;
    rdfs:domain samtbuskole:Elev ;
    rdfs:range samtbuskole:Basisgruppe ;
    skos:closeMatch <http://schema.org/memberOf> ;
    skos:definition "Basisgruppe elev tilhører" ;
    skos:inScheme <https://example.no/ontology/samt-bu-skole> .

samtbuskole:jobber_paa_skole a owl:ObjectProperty ;
    rdfs:label "jobber_paa_skole" ;
    rdfs:domain samtbuskole:Kontaktlaerer ;
    rdfs:range samtbuskole:Skole ;
    skos:closeMatch <http://schema.org/worksFor>,
        org:memberOf ;
    skos:definition "Skolen kontaktlæreren jobber på" ;
    skos:inScheme <https://example.no/ontology/samt-bu-skole> .

samtbuskole:kommunenummer a owl:DatatypeProperty ;
    rdfs:label "kommunenummer" ;
    rdfs:range xsd:string ;
    skos:closeMatch skos:notation ;
    skos:definition "Kommunenummer er en nummerrekke som identifiserer kommuner eller kommunefrie områder." ;
    skos:inScheme <https://example.no/ontology/samt-bu-skole> .

samtbuskole:organisasjonsnummer a owl:DatatypeProperty ;
    rdfs:label "organisasjonsnummer" ;
    rdfs:range xsd:string ;
    skos:definition "Organisasjonsnummer er i Norge et ni-sifret registreringsnummer som tildeles av Enhetsregisteret ved Brønnøysundregistrene for en organisasjon (foretak, idrettslag og lignende)." ;
    skos:exactMatch <http://www.w3.org/ns/adms#identifier> ;
    skos:inScheme <https://example.no/ontology/samt-bu-skole> .

samtbuskole:tilknyttet_basisgruppe a owl:ObjectProperty ;
    rdfs:label "tilknyttet_basisgruppe" ;
    rdfs:domain samtbuskole:Kontaktlaerer ;
    rdfs:range samtbuskole:Basisgruppe ;
    skos:closeMatch <http://schema.org/teaches> ;
    skos:definition "Basisgruppe kontaktlærer er tilknyttet" ;
    skos:inScheme <https://example.no/ontology/samt-bu-skole> .

samtbuskole:trinniva a owl:DatatypeProperty ;
    rdfs:label "trinniva" ;
    rdfs:range xsd:string ;
    skos:definition "Grunnskolen (6-15 år) er delt opp i 10 trinn, eit for kvart år." ;
    skos:inScheme <https://example.no/ontology/samt-bu-skole> .

<https://data.norge.no/linkml/common-ap-no/har_referanse> a owl:DatatypeProperty ;
    rdfs:label "har_referanse" ;
    rdfs:range xsd:anyURI ;
    skos:definition "Referanse til ekstern ressurs (rdfs:seeAlso)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/nokkelord> a owl:DatatypeProperty ;
