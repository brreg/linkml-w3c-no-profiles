{
  "mcpServers": {
    "json2linkml": {
      "type": "stdio",
      "command": "podman",
      "args": [
        "run",
        "-i",
        "--rm",
        "-v",
        "/mnt/c/dev/github/linkml-w3c-no-profiles/src/mcp-json2linkml/server.py:/app/server.py:ro",
        "-v",
