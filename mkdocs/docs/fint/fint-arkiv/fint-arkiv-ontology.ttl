    skos:inScheme <https://data.norge.no/linkml/fint-arkiv> .

<https://schema.fintlabs.no/:Landkode> a owl:Class ;
    rdfs:label "Landkode" ;
    rdfs:subClassOf <https://schema.fintlabs.no/:Begrep> ;
