@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix fint: <https://schema.fintlabs.no/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pav: <http://purl.org/pav/> .
@prefix pvn: <https://schema.fintlabs.no/personvern/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://data.norge.no/linkml/fint-personvern.owl.ttl> a owl:Ontology ;
    rdfs:label "fint-personvern" ;
    dcterms:title "FINT Personvern" ;
    pav:version "4.0.20" ;
    skos:definition """FINT-domenemodell for personvern. Dekkjer behandling av personopplysningar, samtykke, tenester og kodeverk for behandlingsgrunnlag og personopplysningstypar.
""" .

<https://schema.fintlabs.no/:Matrikkelnummer> a owl:Class ;
    rdfs:label "Matrikkelnummer" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:seksjonsnummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:kommunenummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:adresse> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:bruksnummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:adresse> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:festenummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:seksjonsnummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:gaardsnummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:gaardsnummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:kommunenummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:festenummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:bruksnummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:festenummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Adresse> ;
            owl:onProperty <https://schema.fintlabs.no/:adresse> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:bruksnummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Kommune> ;
            owl:onProperty <https://schema.fintlabs.no/:kommunenummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:gaardsnummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:seksjonsnummer> ] ;
    skos:definition "Eintydleg identifisering av matrikkeleining innanfor kommune." ;
    skos:exactMatch fint:Matrikkelnummer ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:Valuta> a owl:Class ;
    rdfs:label "Valuta" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:nummerkode> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:bokstavkode> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Identifikator> ;
            owl:onProperty <https://schema.fintlabs.no/:nummerkode> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:bokstavkode> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Identifikator> ;
            owl:onProperty <https://schema.fintlabs.no/:bokstavkode> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:valuta_navn> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:nummerkode> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:valuta_navn> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:valuta_navn> ] ;
    skos:definition "Valutakodar for offisielle valutaer." ;
    skos:exactMatch fint:Valuta ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/personvern/:PersonvernContainer> a owl:Class ;
    rdfs:label "PersonvernContainer" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/personvern/:Personopplysning> ;
            owl:onProperty <https://schema.fintlabs.no/personvern/:personopplysningar> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/personvern/:Behandlingsgrunnlag> ;
            owl:onProperty <https://schema.fintlabs.no/personvern/:behandlingsgrunnlag> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/personvern/:personopplysningar> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/personvern/:Behandling> ;
            owl:onProperty <https://schema.fintlabs.no/personvern/:behandlingar> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/personvern/:Tjeneste> ;
            owl:onProperty <https://schema.fintlabs.no/personvern/:tenester> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/personvern/:Samtykke> ;
            owl:onProperty <https://schema.fintlabs.no/personvern/:samtykker> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/personvern/:behandlingar> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/personvern/:samtykker> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/personvern/:behandlingsgrunnlag> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/personvern/:tenester> ] ;
    skos:definition "Rotcontainer for FINT Personvern-instansar." ;
    skos:inScheme <https://data.norge.no/linkml/fint-personvern> .

<https://schema.fintlabs.no/:Virksomhet> a owl:Class ;
    rdfs:label "Virksomhet" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://schema.fintlabs.no/:laerling> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:virksomhetsId> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Identifikator> ;
            owl:onProperty <https://schema.fintlabs.no/:virksomhetsId> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:virksomhetsId> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:laerling> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        <https://schema.fintlabs.no/:Enhet> ;
    skos:definition "Ein juridisk organisasjon som produserer varer eller tenester." ;
    skos:exactMatch fint:Virksomhet ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:Aktoer> a owl:Class ;
    rdfs:label "Aktoer" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:kontaktinformasjon> ],
        [ owl:unionOf ( <https://schema.fintlabs.no/:Enhet> <https://schema.fintlabs.no/:Person> ) ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:kontaktinformasjon> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:postadresse> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:postadresse> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Adresse> ;
            owl:onProperty <https://schema.fintlabs.no/:postadresse> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Kontaktinformasjon> ;
            owl:onProperty <https://schema.fintlabs.no/:kontaktinformasjon> ] ;
    skos:definition "Abstrakt base for person eller eining vi samhandlar med." ;
    skos:exactMatch fint:Aktoer ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:Elev> a owl:Class ;
    rdfs:label "Elev" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Identifikator> ;
            owl:onProperty <https://schema.fintlabs.no/:elevnummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:elevnummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:person> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Person> ;
            owl:onProperty <https://schema.fintlabs.no/:person> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:elevnummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:person> ] ;
    skos:definition "Ein elev registrert i skulesystemet." ;
    skos:exactMatch fint:Elev ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:Enhet> a owl:Class ;
    rdfs:label "Enhet" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Identifikator> ;
            owl:onProperty <https://schema.fintlabs.no/:organisasjonsnummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:forretningsadresse> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:organisasjonsnavn> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:organisasjonsnummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:organisasjonsnummer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:forretningsadresse> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Adresse> ;
            owl:onProperty <https://schema.fintlabs.no/:forretningsadresse> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:organisasjonsnavn> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:organisasjonsnavn> ],
        <https://schema.fintlabs.no/:Aktoer>,
        <https://schema.fintlabs.no/:Virksomhet> ;
    skos:definition "Abstrakt base for alle hovudeiningar, undereiningar og organisasjonsledd identifisert med organisasjonsnummer." ;
    skos:exactMatch fint:Enhet ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:Kontaktperson> a owl:Class ;
    rdfs:label "Kontaktperson" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Person> ;
            owl:onProperty <https://schema.fintlabs.no/:kontaktperson> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:type> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:type> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:kontaktperson> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:kontaktinformasjon> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Kontaktinformasjon> ;
            owl:onProperty <https://schema.fintlabs.no/:kontaktinformasjon> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:type> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Personnavn> ;
            owl:onProperty <https://schema.fintlabs.no/:kontaktperson_navn> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:kontaktperson_navn> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:kontaktinformasjon> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:kontaktperson_navn> ] ;
    skos:definition "Kontaktperson (pårørande) til ein person." ;
    skos:exactMatch fint:Kontaktperson ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:adresselinje> a owl:DatatypeProperty ;
    rdfs:label "adresselinje" ;
    rdfs:range xsd:string ;
    skos:definition "Adresseinformasjon." ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:foreldre> a owl:ObjectProperty ;
    rdfs:label "foreldre" ;
    rdfs:range <https://schema.fintlabs.no/:Person> ;
    skos:definition "Den/dei som har foreldreansvar til personen." ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:foreldreansvar> a owl:ObjectProperty ;
    rdfs:label "foreldreansvar" ;
    rdfs:range <https://schema.fintlabs.no/:Person> ;
    skos:definition "Personar denne personen har foreldreansvar for." ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:kontaktperson> a owl:ObjectProperty ;
    rdfs:label "kontaktperson" ;
    rdfs:range <https://schema.fintlabs.no/:Person> ;
    skos:definition "Personar kontaktpersonen er pårørande for." ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:parorende> a owl:ObjectProperty ;
    rdfs:label "parorende" ;
    rdfs:range <https://schema.fintlabs.no/:Kontaktperson> ;
    skos:definition "Pårørande kontaktperson til personen." ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:statsborgerskap> a owl:ObjectProperty ;
    rdfs:label "statsborgerskap" ;
    rdfs:range <https://schema.fintlabs.no/:Landkode> ;
    skos:definition "Alle statsborgarskap personen har." ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/personvern/:behandlingar> a owl:ObjectProperty ;
    rdfs:label "behandlingar" ;
    skos:inScheme <https://data.norge.no/linkml/fint-personvern> .

<https://schema.fintlabs.no/personvern/:personopplysningar> a owl:ObjectProperty ;
    rdfs:label "personopplysningar" ;
    skos:inScheme <https://data.norge.no/linkml/fint-personvern> .

<https://schema.fintlabs.no/personvern/:samtykke> a owl:ObjectProperty ;
    rdfs:label "samtykke" ;
    rdfs:range <https://schema.fintlabs.no/personvern/:Samtykke> ;
    skos:definition "Samtykker tilknytt ei behandling." ;
    skos:inScheme <https://data.norge.no/linkml/fint-personvern> .

<https://schema.fintlabs.no/personvern/:samtykker> a owl:ObjectProperty ;
    rdfs:label "samtykker" ;
    skos:inScheme <https://data.norge.no/linkml/fint-personvern> .

<https://schema.fintlabs.no/personvern/:tenester> a owl:ObjectProperty ;
    rdfs:label "tenester" ;
    skos:inScheme <https://data.norge.no/linkml/fint-personvern> .

<https://schema.fintlabs.no/:Fylke> a owl:Class ;
    rdfs:label "Fylke" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:kommune> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Kommune> ;
            owl:onProperty <https://schema.fintlabs.no/:kommune> ],
        <https://schema.fintlabs.no/:Begrep> ;
    skos:definition "Liste over Norges fylker." ;
    skos:exactMatch fint:Fylke ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:Kjonn> a owl:Class ;
    rdfs:label "Kjonn" ;
    rdfs:subClassOf <https://schema.fintlabs.no/:Begrep> ;
    skos:definition "Verdiar for kjønn basert på ISO/IEC 5218." ;
    skos:exactMatch fint:Kjonn ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:Kontaktinformasjon> a owl:Class ;
    rdfs:label "Kontaktinformasjon" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:mobiltelefonnummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:epostadresse> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:telefonnummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:mobiltelefonnummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:nettsted> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:sip> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:nettsted> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:sip> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:epostadresse> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:telefonnummer> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:sip> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:telefonnummer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:nettsted> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:epostadresse> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:mobiltelefonnummer> ] ;
    skos:definition "Informasjon som kan brukast for å oppnå kontakt." ;
    skos:exactMatch fint:Kontaktinformasjon ;
    skos:inScheme <https://data.norge.no/linkml/fint-common> .

<https://schema.fintlabs.no/:adresse> a owl:ObjectProperty ;
