<https://begrep.brreg.no/samlingar/registerbegrep-2025> a skos:Collection ;
    dct:description "Begreper knytt til Enhetsregisteret, Foretaksregisteret og registerforvaltning."^^rdf:langString ;
    dct:identifier "https://begrep.brreg.no/samlingar/registerbegrep-2025" ;
    dct:publisher <https://data.norge.no/organizations/974760673> ;
    dct:title "Registerenheten i Brønnøysund – begrepskatalog 2025"^^rdf:langString ;
    skos:member <https://begrep.brreg.no/aksjeklasser>,
        <https://begrep.brreg.no/foretaksnavn>,
        <https://begrep.brreg.no/nestleder> ;
    dcat:contactPoint <https://begrep.brreg.no/kontakt/begrepsansvarleg> .

<https://begrep.brreg.no/aksjeklasser> a skos:Concept ;
    euvoc:xlDefinition <https://begrep.brreg.no/def/aksjeklasser-nb> ;
    dct:identifier "https://begrep.brreg.no/aksjeklasser" ;
    dct:publisher <https://data.norge.no/organizations/974760673> ;
    dct:subject <https://psi.norge.no/los/tema/naringsliv> ;
    skos:example "A-aksjer, b-aksjer, preferanseaksjer"^^rdf:langString ;
    skos:prefLabel "aksjeklasser"^^rdf:langString ;
    skos:scopeNote "I utgangspunktet skal alle aksjer gi lik rett i selskapet, men vedtektene kan bestemme at aksjene skal deles inn i forskjellige aksjeklasser."^^rdf:langString ;
    dcat:contactPoint <https://begrep.brreg.no/kontakt/begrepsansvarleg> .

<https://begrep.brreg.no/def/aksjeklasser-nb> a euvoc:XlNote ;
    rdf:value "inndeling av aksjer som gir aksjene ulike rettigheter"^^rdf:langString ;
    skosno:relationshipWithSource <https://data.norge.no/vocabulary/relationship-with-source-type#derived-from-source> .

<https://begrep.brreg.no/def/foretaksnavn-nb> a euvoc:XlNote ;
    rdf:value "det offisielle navnet på en næringsdrivende juridisk person og kjennetegnet for et enkeltpersonforetak"^^rdf:langString ;
    skosno:relationshipWithSource <https://data.norge.no/vocabulary/relationship-with-source-type#direct-from-source> .

<https://begrep.brreg.no/def/nestleder-en> a euvoc:XlNote ;
    rdf:value "board member who acts as the chair in the absence of the chair"^^rdf:langString ;
    skosno:relationshipWithSource <https://data.norge.no/vocabulary/relationship-with-source-type#self-composed> .

<https://begrep.brreg.no/def/nestleder-nb> a euvoc:XlNote ;
    rdf:value "styremedlem som opptrer som styreleder ved leders fravær"^^rdf:langString ;
    skosno:relationshipWithSource <https://data.norge.no/vocabulary/relationship-with-source-type#self-composed> .

<https://begrep.brreg.no/def/nestleder-nn> a euvoc:XlNote ;
    rdf:value "styremedlem som opptrer som styreleiar i fråværet til leiaren"^^rdf:langString ;
    skosno:relationshipWithSource <https://data.norge.no/vocabulary/relationship-with-source-type#self-composed> .

<https://begrep.brreg.no/foretaksnavn> a skos:Concept ;
