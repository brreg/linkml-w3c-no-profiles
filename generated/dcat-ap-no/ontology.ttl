        <https://data.norge.no/linkml/dcat-ap-no/KatalogisertRessurs> ;
    skos:definition "En samling av data utgitt eller kuratert av én aktør." ;
    skos:exactMatch dcat:Dataset ;
    skos:inScheme <https://data.norge.no/linkml/dcat-ap-no> .

<https://data.norge.no/linkml/dcat-ap-no/tittel> a owl:DatatypeProperty ;
    rdfs:label "tittel" ;
    rdfs:range rdf:langString ;
    skos:definition "Navn/tittel på ressursen." ;
    skos:inScheme <https://data.norge.no/linkml/dcat-ap-no> .

<https://data.norge.no/linkml/dcat-ap-no/utgiver> a owl:ObjectProperty ;
    rdfs:label "utgiver" ;
    rdfs:range <https://data.norge.no/linkml/dcat-ap-no/Aktor> ;
    skos:definition "Aktøren som er ansvarlig for å tilgjengeliggjøre ressursen." ;
    skos:inScheme <https://data.norge.no/linkml/dcat-ap-no> .

<https://data.norge.no/linkml/dcat-ap-no/endringsdato> a owl:DatatypeProperty ;
    rdfs:label "endringsdato" ;
    rdfs:range xsd:date ;
    skos:definition "Dato for siste endring av ressursen." ;
    skos:inScheme <https://data.norge.no/linkml/dcat-ap-no> .

<https://data.norge.no/linkml/dcat-ap-no/identifikator_literal> a owl:DatatypeProperty ;
    rdfs:label "identifikator_literal" ;
    rdfs:range xsd:string ;
    skos:definition "Tekstlig identifikator for ressursen." ;
    skos:inScheme <https://data.norge.no/linkml/dcat-ap-no> .

<https://data.norge.no/linkml/dcat-ap-no/utgivelsesdato> a owl:DatatypeProperty ;
    rdfs:label "utgivelsesdato" ;
    rdfs:range xsd:date ;
    skos:definition "Dato ressursen ble første gang publisert." ;
    skos:inScheme <https://data.norge.no/linkml/dcat-ap-no> .

<https://data.norge.no/linkml/dcat-ap-no/beskrivelse> a owl:DatatypeProperty ;
    rdfs:label "beskrivelse" ;
    rdfs:range rdf:langString ;
    skos:definition "Fritekstbeskrivelse av ressursen." ;
    skos:inScheme <https://data.norge.no/linkml/dcat-ap-no> .

rdf:langString a rdfs:Datatype .

<https://data.norge.no/linkml/dcat-ap-no/Begrep> a owl:Class ;
    rdfs:label "Begrep" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/dcat-ap-no/id> ] ;
    skos:definition "Et SKOS-begrep fra et kontrollert vokabular." ;
    skos:exactMatch skos:Concept ;
    skos:inScheme <https://data.norge.no/linkml/dcat-ap-no> .

<https://data.norge.no/linkml/dcat-ap-no/id> a owl:DatatypeProperty ;
    rdfs:label "id" ;
    rdfs:range xsd:anyURI ;
    skos:definition "URI-identifikator for ressursen." ;
    skos:inScheme <https://data.norge.no/linkml/dcat-ap-no> .


