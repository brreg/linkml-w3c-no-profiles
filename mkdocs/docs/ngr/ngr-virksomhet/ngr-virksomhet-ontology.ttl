<https://data.norge.no/linkml/ngr-virksomhet/Person> a owl:Class ;
    rdfs:label "Person" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-virksomhet/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/ngr-virksomhet/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-virksomhet/id> ] ;
    skos:definition "Ein fysisk person. Tilhøyrer Domene person og forvaltast av Folkeregisteret. Enhetsregisteret nyttar kopi av data frå Folkeregisteret." ;
    skos:exactMatch ngrv:Person ;
    skos:inScheme <https://data.norge.no/linkml/ngr-virksomhet> .

<https://data.norge.no/linkml/ngr-virksomhet/Virksomhet> a owl:Class ;
    rdfs:label "Virksomhet" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://data.norge.no/linkml/ngr-virksomhet/navn> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/ngr-virksomhet/antall_ansatte> ],
