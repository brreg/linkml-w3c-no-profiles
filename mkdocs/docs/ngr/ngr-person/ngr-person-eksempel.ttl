@prefix ngrp: <https://data.norge.no/vocabulary/ngr-person#> .
@prefix ns1: <https://data.norge.no/linkml/ngr-person/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://data.norge.no/vocabulary/ngr-person#eksempel/person-1> a ngrp:Person ;
    ngrp:harBostedPaa <https://data.norge.no/vocabulary/ngr-person#eksempel/bostedsadresse-1> ;
    ngrp:harFoedsel <https://data.norge.no/vocabulary/ngr-person#eksempel/foedsel-1> ;
    ngrp:harFolkeregisteridentifikator <https://data.norge.no/vocabulary/ngr-person#eksempel/fnr-1> ;
    ngrp:harKjoenn <https://data.norge.no/vocabulary/ngr-person#eksempel/kjoenn-1> ;
    ngrp:harKontaktopplysninger <https://data.norge.no/vocabulary/ngr-person#eksempel/kontakt-1> ;
    ngrp:harPersonnavn <https://data.norge.no/vocabulary/ngr-person#eksempel/personnavn-1> ;
    ngrp:harPersonstatus <https://data.norge.no/vocabulary/ngr-person#eksempel/personstatus-1> ;
    ngrp:harSivilstand <https://data.norge.no/vocabulary/ngr-person#eksempel/sivilstand-1> ;
    ngrp:harStatsborgerskap <https://data.norge.no/vocabulary/ngr-person#eksempel/statsborgerskap-1> ;
    ngrp:harValgtSpraak <https://data.norge.no/vocabulary/ngr-person#eksempel/spraak-1> .

<https://data.norge.no/vocabulary/ngr-person#eksempel/bostedsadresse-1> a ngrp:Bostedsadresse ;
    ngrp:gyldigFraOgMed "2010-01-01"^^xsd:date .

<https://data.norge.no/vocabulary/ngr-person#eksempel/fnr-1> a ngrp:Foedselsnummer ;
    ngrp:identifikatornummer "12057012345" .

<https://data.norge.no/vocabulary/ngr-person#eksempel/foedsel-1> a ngrp:Foedsel ;
    ngrp:foedested "Oslo" ;
    ngrp:foedselsaar 1970 ;
    ngrp:foedselsdato "1970-05-12"^^xsd:date .

<https://data.norge.no/vocabulary/ngr-person#eksempel/kjoenn-1> a ngrp:Kjoenn ;
    ngrp:gyldigFraOgMed "1970-05-12"^^xsd:date ;
    ngrp:kjoennKode "KVINNE" .

<https://data.norge.no/vocabulary/ngr-person#eksempel/kontakt-1> a ngrp:Kontaktopplysninger ;
    ngrp:epostadresse "kari.nordmann@example.no" ;
    ngrp:mobiltelefonnummer "99012345" ;
    ngrp:sistOppdatert "2024-03-15"^^xsd:date .

<https://data.norge.no/vocabulary/ngr-person#eksempel/personnavn-1> a ngrp:Personnavn ;
    ngrp:etternavn "Nordmann" ;
    ngrp:fornavn "Kari" .

<https://data.norge.no/vocabulary/ngr-person#eksempel/personstatus-1> a ngrp:Personstatus ;
    ngrp:gyldigFraOgMed "1970-05-12"^^xsd:date ;
    ngrp:personstatusType "BOSATT" .

<https://data.norge.no/vocabulary/ngr-person#eksempel/sivilstand-1> a ngrp:Sivilstand ;
    ngrp:gyldigFraOgMed "1970-05-12"^^xsd:date ;
    ngrp:sivilstandType "UGIFT" .

<https://data.norge.no/vocabulary/ngr-person#eksempel/spraak-1> a ngrp:SpraakForElektroniskKommunikasjon ;
    ngrp:spraakkode "nb" .

<https://data.norge.no/vocabulary/ngr-person#eksempel/statsborgerskap-1> a ngrp:Statsborgerskap ;
    ngrp:gyldigFraOgMed "1970-05-12"^^xsd:date ;
    ngrp:landkode "NO" .

[] a ns1:PersonContainer ;
    ns1:bostedsadresser <https://data.norge.no/vocabulary/ngr-person#eksempel/bostedsadresse-1> ;
    ns1:foedselsnummer <https://data.norge.no/vocabulary/ngr-person#eksempel/fnr-1> ;
    ns1:foedslar <https://data.norge.no/vocabulary/ngr-person#eksempel/foedsel-1> ;
    ns1:kjoenn <https://data.norge.no/vocabulary/ngr-person#eksempel/kjoenn-1> ;
    ns1:kontaktopplysningar <https://data.norge.no/vocabulary/ngr-person#eksempel/kontakt-1> ;
    ns1:personar <https://data.norge.no/vocabulary/ngr-person#eksempel/person-1> ;
    ns1:personnavn <https://data.norge.no/vocabulary/ngr-person#eksempel/personnavn-1> ;
    ns1:personstatus <https://data.norge.no/vocabulary/ngr-person#eksempel/personstatus-1> ;
    ns1:sivilstand <https://data.norge.no/vocabulary/ngr-person#eksempel/sivilstand-1> ;
    ns1:spraak <https://data.norge.no/vocabulary/ngr-person#eksempel/spraak-1> ;
    ns1:statsborgerskap <https://data.norge.no/vocabulary/ngr-person#eksempel/statsborgerskap-1> .

