    sh:targetClass dcat:Relationship .

dcat:Resource a sh:NodeShape ;
    rdfs:comment "Basisklasse for ressursar som kan katalogiserast." ;
    sh:closed false ;
    sh:ignoredProperties ( dcat:landingPage dct:relation adms:identifier dcat:version dcat:record dct:identifier dcat:endpointURL dcat:dataset dcat:inSeries cv:hasCost dcat:last foaf:homepage dct:rights dct:accrualPeriodicity dcat:endpointDescription rdf:type dcat:first dct:publisher foaf:page dct:title dct:conformsTo dcatap:availability adms:status dcat:qualifiedRelation dcat:contactPoint adms:versionNotes dct:language dct:license dct:format dcat:theme dct:temporal dcat:service dct:accessRights dcat:catalog dct:provenance <http://www.w3.org/ns/dqv#hasQualityAnnotation> dct:modified dct:description adms:sample dct:subject dcat:keyword <http://www.w3.org/ns/dqv#hasQualityMeasurement> dcatap:applicableLegislation dct:creator prov:wasGeneratedBy dct:source dcat:servesDataset dcat:distribution dct:issued dct:hasPart dct:spatial dcat:themeTaxonomy prov:qualifiedAttribution dct:type ) ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://data.norge.no/linkml/common-ap-no/id> ] ;
    sh:targetClass dcat:Resource .

<http://www.w3.org/ns/dqv#Metric> a sh:NodeShape ;
