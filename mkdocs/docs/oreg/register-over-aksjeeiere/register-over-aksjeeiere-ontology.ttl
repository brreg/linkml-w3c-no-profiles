<https://example.no/ontology/aksje-eierskap.owl.ttl> a owl:Ontology ;
    rdfs:label "register-over-aksjeeiere" ;
    dcterms:title "Aksje- og eigarskapsmodell" ;
    skos:definition """LinkML-modell for aksjeselskap, aksjar, eigarskap og eigarskapshendingar. Modellen er tilpassa RDF-generering, SHACL og Ontodia-visualisering.
""" .

