@prefix dct: <http://purl.org/dc/terms/> .
@prefix euvoc: <http://publications.europa.eu/ontology/euvoc#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pav: <http://purl.org/pav/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosno: <https://data.norge.no/vocabulary/skosno#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

xsd:duration a rdfs:Datatype .

xsd:gYear a rdfs:Datatype .

xsd:nonNegativeInteger a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:onDatatype xsd:integer ;
            owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] .

<https://data.norge.no/linkml/common-ap-no/Begrepssamling> a owl:Class ;
    rdfs:label "Begrepssamling" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ] ;
    skos:definition "Ei SKOS-omgrepssamling (temavokabular)." ;
    skos:exactMatch skos:ConceptScheme ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/Mediatype> a owl:Class ;
    rdfs:label "Mediatype" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ] ;
    skos:definition "Ein medietype eller filformat (dct:MediaTypeOrExtent)." ;
    skos:exactMatch dct:MediaTypeOrExtent ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/dekningsomraade> a owl:ObjectProperty ;
    rdfs:label "dekningsomraade" ;
    rdfs:range <https://data.norge.no/linkml/common-ap-no/Konsept> ;
    skos:definition "Geografisk dekningsområde (dct:spatial)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/format> a owl:DatatypeProperty ;
    rdfs:label "format" ;
    rdfs:range xsd:string ;
    skos:definition "Filformat eller medietype (dct:format)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/har_merknad> a owl:DatatypeProperty ;
    rdfs:label "har_merknad" ;
    rdfs:range rdf:langString ;
    skos:definition "Fritekstmerknad (rdfs:comment)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/har_referanse> a owl:DatatypeProperty ;
    rdfs:label "har_referanse" ;
    rdfs:range xsd:anyURI ;
    skos:definition "Referanse til ekstern ressurs (rdfs:seeAlso)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/heimeside> a owl:DatatypeProperty ;
    rdfs:label "heimeside" ;
    rdfs:range xsd:anyURI ;
    skos:definition "Heimeside for ressursen eller organisasjonen (foaf:homepage)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/nokkelord> a owl:DatatypeProperty ;
    rdfs:label "nokkelord" ;
    rdfs:range rdf:langString ;
    skos:definition "Nøkkelord som beskriv ressursen (dcat:keyword)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/spraak> a owl:DatatypeProperty ;
    rdfs:label "spraak" ;
    rdfs:range dct:language ;
    skos:definition "Språk brukt i ressursen (dct:language)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/status> a owl:ObjectProperty ;
    rdfs:label "status" ;
    rdfs:range <https://data.norge.no/linkml/common-ap-no/Konsept> ;
    skos:definition "Status for ressursen frå eit kontrollert vokabular (adms:status)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/type_concept> a owl:ObjectProperty ;
    rdfs:label "type_concept" ;
    rdfs:range <https://data.norge.no/linkml/common-ap-no/Konsept> ;
    skos:definition "Type ressurs frå eit kontrollert vokabular (dct:type)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/utgivelsesdato> a owl:DatatypeProperty ;
    rdfs:label "utgivelsesdato" ;
    rdfs:range xsd:date ;
    skos:definition "Dato ressursen vart første gong publisert (dct:issued)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/valuta> a owl:ObjectProperty ;
    rdfs:label "valuta" ;
    rdfs:range <https://data.norge.no/linkml/common-ap-no/Konsept> ;
    skos:definition "Valuta (cv:currency)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/skos-ap-no.owl.ttl> a owl:Ontology ;
    rdfs:label "skos-ap-no" ;
    dct:title "SKOS-AP-NO" ;
    pav:version "2.0" ;
    skos:definition "Norsk applikasjonsprofil av SKOS for omgrep (begrep), modellert i LinkML med lenking framfor inlining. Basert på https://informasjonsforvaltning.github.io/skos-ap-no-begrep/" .

dct:language a rdfs:Datatype .

<https://data.norge.no/linkml/common-ap-no/anbefalt_term> a owl:DatatypeProperty ;
    rdfs:label "anbefalt_term" ;
    rdfs:range rdf:langString ;
    skos:definition "Føretrukke term/namn for ressursen (skos:prefLabel)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/beskrivelse> a owl:DatatypeProperty ;
    rdfs:label "beskrivelse" ;
    rdfs:range rdf:langString ;
    skos:definition "Fritekstbeskrivelse av ressursen (dct:description)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/tittel> a owl:DatatypeProperty ;
    rdfs:label "tittel" ;
    rdfs:range rdf:langString ;
    skos:definition "Namn/tittel på ressursen (dct:title)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/versjonsmerknad> a owl:DatatypeProperty ;
    rdfs:label "versjonsmerknad" ;
    rdfs:range rdf:langString ;
    skos:definition "Merknad om endringar i denne versjonen (adms:versionNotes)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/skos-ap-no/AssosiativRelasjon> a owl:Class ;
    rdfs:label "AssosiativRelasjon" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/til_omgrep> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/relasjontype> ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdf:langString ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/relasjontype> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/skos-ap-no/Begrep> ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/til_omgrep> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/relasjontype> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ] ;
    skos:definition "Ein assosiativ relasjon mellom to omgrep." ;
    skos:exactMatch skosno:AssociativeConceptRelation ;
    skos:inScheme <https://data.norge.no/linkml/skos-ap-no> .

<https://data.norge.no/linkml/skos-ap-no/Definisjon> a owl:Class ;
    rdfs:label "Definisjon" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/kjelde_relasjon> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/skos-ap-no/Begrep> ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/malgruppe_def> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/kjelde_relasjon> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/skos-ap-no/Begrep> ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/kjelde_relasjon> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/malgruppe_def> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/kjelde> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/tekst> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/kjelde> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/tekst> ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdf:langString ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/tekst> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/malgruppe_def> ] ;
    skos:definition "Ein definisjon av eit omgrep via eit eige objekt (euvoc:XlNote)." ;
    skos:exactMatch euvoc:XlNote ;
    skos:inScheme <https://data.norge.no/linkml/skos-ap-no> .

<https://data.norge.no/linkml/skos-ap-no/GeneriskRelasjon> a owl:Class ;
    rdfs:label "GeneriskRelasjon" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/inndelingskriterium> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/har_generisk_omgrep> ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdf:langString ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/inndelingskriterium> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/skos-ap-no/Begrep> ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/har_generisk_omgrep> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/skos-ap-no/Begrep> ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/har_spesifikt_omgrep> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/har_spesifikt_omgrep> ] ;
    skos:definition "Ein generisk relasjon mellom eit overomgrep og eit underomgrep." ;
    skos:exactMatch skosno:GenericConceptRelation ;
    skos:inScheme <https://data.norge.no/linkml/skos-ap-no> .

<https://data.norge.no/linkml/skos-ap-no/PartitivRelasjon> a owl:Class ;
    rdfs:label "PartitivRelasjon" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom rdf:langString ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/inndelingskriterium> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/skos-ap-no/Begrep> ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/har_heilskapleg_omgrep> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/skos-ap-no/Begrep> ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/har_partitivt_omgrep> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/har_heilskapleg_omgrep> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/har_partitivt_omgrep> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/inndelingskriterium> ] ;
    skos:definition "Ein partitiv relasjon mellom eit heilskapleg og eit partitivt omgrep." ;
    skos:exactMatch skosno:PartitiveConceptRelation ;
    skos:inScheme <https://data.norge.no/linkml/skos-ap-no> .

<https://data.norge.no/linkml/skos-ap-no/Samling> a owl:Class ;
    rdfs:label "Samling" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/skos-ap-no/Organisasjon> ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/utgjevar> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/identifikator_literal> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/tittel> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/beskrivelse> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/skos-ap-no/Begrep> ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/medlem> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/utgjevar> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/medlem> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/skos-ap-no/VCardKontakt> ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/kontaktpunkt_vcard> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/identifikator_literal> ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdf:langString ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/beskrivelse> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/kontaktpunkt_vcard> ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdf:langString ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/tittel> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/skos-ap-no/utgjevar> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/identifikator_literal> ] ;
    skos:definition "Ei namngitt samling av omgrep (skos:Collection)." ;
    skos:exactMatch skos:Collection ;
    skos:inScheme <https://data.norge.no/linkml/skos-ap-no> .

<https://data.norge.no/linkml/skos-ap-no/assosiert_med> a owl:ObjectProperty ;
    rdfs:label "assosiert_med" ;
    rdfs:range <https://data.norge.no/linkml/skos-ap-no/Begrep> ;
    skos:definition "Omgrep dette omgrepet er assosiert med (skos:related)." ;
    skos:inScheme <https://data.norge.no/linkml/skos-ap-no> .

<https://data.norge.no/linkml/skos-ap-no/datastruktur_term> a owl:DatatypeProperty ;
    rdfs:label "datastruktur_term" ;
    rdfs:range xsd:string ;
    skos:definition "Term brukt i datastrukturar (skosno:dataStructureLabel)." ;
    skos:inScheme <https://data.norge.no/linkml/skos-ap-no> .

<https://data.norge.no/linkml/skos-ap-no/definisjon> a owl:DatatypeProperty ;
    rdfs:label "definisjon" ;
    rdfs:range rdf:langString ;
    skos:definition "Direkte definisjon som fritekst (skos:definition)." ;
    skos:inScheme <https://data.norge.no/linkml/skos-ap-no> .

<https://data.norge.no/linkml/skos-ap-no/eksempel> a owl:DatatypeProperty ;
    rdfs:label "eksempel" ;
    rdfs:range rdf:langString ;
    skos:definition "Eksempel på bruk av omgrepet (skos:example)." ;
    skos:inScheme <https://data.norge.no/linkml/skos-ap-no> .

<https://data.norge.no/linkml/skos-ap-no/er_del_av_omgrep> a owl:ObjectProperty ;
    rdfs:label "er_del_av_omgrep" ;
    rdfs:range <https://data.norge.no/linkml/skos-ap-no/Begrep> ;
    skos:definition "Omgrep dette omgrepet er ein del av (xkos:isPartOf)." ;
    skos:inScheme <https://data.norge.no/linkml/skos-ap-no> .

<https://data.norge.no/linkml/skos-ap-no/er_erstatta_av> a owl:ObjectProperty ;
    rdfs:label "er_erstatta_av" ;
    rdfs:range <https://data.norge.no/linkml/skos-ap-no/Begrep> ;
    skos:definition "Omgrep som erstattar dette omgrepet (dct:isReplacedBy)." ;
    skos:inScheme <https://data.norge.no/linkml/skos-ap-no> .

<https://data.norge.no/linkml/skos-ap-no/er_fra_omgrep_i> a owl:ObjectProperty ;
    rdfs:label "er_fra_omgrep_i" ;
    rdfs:range <https://data.norge.no/linkml/skos-ap-no/AssosiativRelasjon> ;
    skos:definition "Assosiativ relasjon der dette omgrepet er frå-omgrepet (skosno:isFromConceptIn)." ;
    skos:inScheme <https://data.norge.no/linkml/skos-ap-no> .

<https://data.norge.no/linkml/skos-ap-no/er_medlem_av> a owl:ObjectProperty ;
    rdfs:label "er_medlem_av" ;
    rdfs:range <https://data.norge.no/linkml/skos-ap-no/Samling> ;
    skos:definition "Samling dette omgrepet er medlem av (uneskos:memberOf)." ;
    skos:inScheme <https://data.norge.no/linkml/skos-ap-no> .

<https://data.norge.no/linkml/skos-ap-no/erstattar> a owl:ObjectProperty ;
    rdfs:label "erstattar" ;
