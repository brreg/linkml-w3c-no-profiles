<https://schema.fintlabs.no/personvern/:Behandlingsgrunnlag> a owl:Class ;
    rdfs:label "Behandlingsgrunnlag" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:kode> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:passiv> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:gyldighetsperiode> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:navn> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:kode> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:navn> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://schema.fintlabs.no/:kode> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:gyldighetsperiode> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://schema.fintlabs.no/:passiv> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://schema.fintlabs.no/:navn> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://schema.fintlabs.no/:Periode> ;
            owl:onProperty <https://schema.fintlabs.no/:gyldighetsperiode> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty <https://schema.fintlabs.no/:passiv> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://schema.fintlabs.no/:id> ] ;
    skos:definition "Rettsleg grunnlag for behandling av personopplysningar." ;
    skos:exactMatch pvn:Behandlingsgrunnlag ;
    skos:inScheme <https://data.norge.no/linkml/fint-personvern> .

<https://schema.fintlabs.no/personvern/:Personopplysning> a owl:Class ;
    rdfs:label "Personopplysning" ;
