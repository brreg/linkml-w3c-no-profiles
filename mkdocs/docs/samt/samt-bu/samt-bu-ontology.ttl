        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty samtbuskole:navn ] ;
    skos:definition "En skole er en privat eller offentlig institusjon eller et lærested hvor lærere underviser i ulike fag, oftest som grunnlag for videre utdannelse og yrkesliv." ;
