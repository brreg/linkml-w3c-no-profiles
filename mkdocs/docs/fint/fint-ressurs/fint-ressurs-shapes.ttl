        [ sh:class res:Enhetstype ;
            sh:description "Type digital eining." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path res:enhetstype ],
        [ sh:description "Referanse til Organisasjonselement grupperinga er tilknytt." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path res:organisasjonsenhet ],
        [ sh:class res:Enhetsgruppemedlemskap ;
            sh:description "Einingsgruppemelemskap." ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path res:enhetsgruppemedlemskap ],
        [ sh:class res:Plattform ;
            sh:description "Plattforma ressursen er knytt til." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path res:plattform ],
        [ sh:description "URI-identifikator for ressursen." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path <https://schema.fintlabs.no/:id> ] ;
    sh:targetClass res:Enhetsgruppe .

res:Handhevingstype a sh:NodeShape ;
    rdfs:comment "Korleis ulike lisensmodellar kan handhevast." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:boolean ;
