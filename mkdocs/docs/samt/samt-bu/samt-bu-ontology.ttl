        samtbuskole:Person ;
    skos:closeMatch <http://schema.org/Teacher> ;
    skos:definition "En lærer med ansvar for ei basisgruppe og er skolens kontaktpunkt for elevane i basisgruppa" ;
    skos:inScheme <https://example.no/ontology/samt-bu-skole> .

