@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix ns1: <https://data.norge.no/linkml/dcat-ap-no/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.org/katalogar/eksempel-1> a dcat:Catalog ;
    dct:description "Ein demonstrasjonskatalog for DCAT-AP-NO modellert i LinkML."^^rdf:langString ;
    dct:issued "2024-01-15"^^xsd:date ;
    dct:language <http://publications.europa.eu/resource/authority/language/NOB> ;
    dct:license <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0> ;
    dct:modified "2024-06-01"^^xsd:date ;
    dct:publisher <https://organization-catalog.fellesdatakatalog.digdir.no/organizations/991825827> ;
    dct:title "Eksempelkatalog"^^rdf:langString ;
    dcat:contactPoint <https://example.org/kontaktpunkt/1> ;
    dcat:dataset <https://example.org/datasett/aapen-adresseregister> .

<https://example.org/datasett/aapen-adresseregister> a dcat:Dataset ;
    dct:description "Eit datasett med norske adresser tilgjengeleg for allmenta."^^rdf:langString ;
    dct:issued "2023-03-01"^^xsd:date ;
    dct:modified "2024-05-15"^^xsd:date ;
    dct:publisher <https://organization-catalog.fellesdatakatalog.digdir.no/organizations/991825827> ;
    dct:title "Ope adresseregister"^^rdf:langString ;
    dcat:contactPoint <https://example.org/kontaktpunkt/1> ;
    dcat:distribution <https://example.org/distribusjonar/adresser-csv> ;
    dcat:keyword "adresse"^^rdf:langString,
        "geografi"^^rdf:langString ;
    dcat:theme <http://publications.europa.eu/resource/authority/data-theme/REGI> .

<https://example.org/distribusjonar/adresser-csv> a dcat:Distribution ;
    dct:format <http://publications.europa.eu/resource/authority/file-type/CSV> ;
    dct:license <http://publications.europa.eu/resource/authority/licence/CC_BY_4_0> ;
    dcat:accessURL "https://example.org/nedlasting/adresser.csv"^^xsd:anyURI ;
    dcat:downloadURL "https://example.org/nedlasting/adresser.csv"^^xsd:anyURI ;
    dcat:mediaType <https://www.iana.org/assignments/media-types/text/csv> .

<https://example.org/kontaktpunkt/1> a vcard:Kind ;
    vcard:fn "Datateam Digdir"^^rdf:langString ;
    vcard:hasEmail "mailto:data@digdir.no"^^xsd:anyURI .

<https://organization-catalog.fellesdatakatalog.digdir.no/organizations/991825827> a foaf:Agent ;
    foaf:name "Digitaliseringsdirektoratet"^^rdf:langString .

[] a ns1:Container ;
    ns1:aktorar <https://organization-catalog.fellesdatakatalog.digdir.no/organizations/991825827> ;
    ns1:datasett <https://example.org/datasett/aapen-adresseregister> ;
    ns1:distribusjonar <https://example.org/distribusjonar/adresser-csv> ;
    ns1:katalogar <https://example.org/katalogar/eksempel-1> ;
    ns1:kontaktopplysningar <https://example.org/kontaktpunkt/1> .

