@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix modelldcatno: <https://data.norge.no/vocabulary/modelldcatno#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pav: <http://purl.org/pav/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

xsd:duration a rdfs:Datatype .

xsd:gYear a rdfs:Datatype .

<https://data.norge.no/linkml/common-ap-no/Mediatype> a owl:Class ;
    rdfs:label "Mediatype" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ] ;
    skos:definition "Ein medietype eller filformat (dct:MediaTypeOrExtent)." ;
    skos:exactMatch dct:MediaTypeOrExtent ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/har_merknad> a owl:DatatypeProperty ;
    rdfs:label "har_merknad" ;
    rdfs:range rdf:langString ;
    skos:definition "Fritekstmerknad (rdfs:comment)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/valuta> a owl:ObjectProperty ;
    rdfs:label "valuta" ;
    rdfs:range <https://data.norge.no/linkml/common-ap-no/Konsept> ;
    skos:definition "Valuta (cv:currency)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/modelldcat-ap-no.owl.ttl> a owl:Ontology ;
    rdfs:label "modelldcat-ap-no" ;
    dct:title "ModelDCAT-AP-NO" ;
    pav:version "1.0" ;
    skos:definition "Norsk applikasjonsprofil for beskriving av informasjonsmodellar i DCAT-format, modellert i LinkML. Basert på https://data.norge.no/specification/modelldcat-ap-no" .

<https://data.norge.no/linkml/modelldcat-ap-no/AlleAv> a owl:Class ;
    rdfs:label "AlleAv" ;
    rdfs:subClassOf <https://data.norge.no/linkml/modelldcat-ap-no/Valg> ;
    skos:definition "Alle av — alle modellelementa i lista må gjelde (logisk OG-mengd)." ;
    skos:exactMatch modelldcatno:AllOf ;
    skos:inScheme <https://data.norge.no/linkml/modelldcat-ap-no> .

<https://data.norge.no/linkml/modelldcat-ap-no/Eller> a owl:Class ;
    rdfs:label "Eller" ;
    rdfs:subClassOf <https://data.norge.no/linkml/modelldcat-ap-no/Betingelsesregel> ;
    skos:definition "Eller — logisk ELLER-betingelse; minst eitt modellelement må gjelde." ;
    skos:exactMatch modelldcatno:Or ;
    skos:inScheme <https://data.norge.no/linkml/modelldcat-ap-no> .

<https://data.norge.no/linkml/modelldcat-ap-no/Ikke> a owl:Class ;
    rdfs:label "Ikke" ;
    rdfs:subClassOf <https://data.norge.no/linkml/modelldcat-ap-no/Betingelsesregel> ;
    skos:definition "Ikkje — negasjon; modellelementet det refererer til må ikkje gjelde." ;
    skos:exactMatch modelldcatno:Not ;
    skos:inScheme <https://data.norge.no/linkml/modelldcat-ap-no> .

<https://data.norge.no/linkml/modelldcat-ap-no/Lokasjon> a owl:Class ;
    rdfs:label "Lokasjon" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ] ;
    skos:definition "Eit geografisk område (dct:Location)." ;
    skos:exactMatch dct:Location ;
    skos:inScheme <https://data.norge.no/linkml/modelldcat-ap-no> .

<https://data.norge.no/linkml/modelldcat-ap-no/NoenAv> a owl:Class ;
    rdfs:label "NoenAv" ;
    rdfs:subClassOf <https://data.norge.no/linkml/modelldcat-ap-no/Valg> ;
    skos:definition "Nokon av — minst eitt modellelement i lista må gjelde (logisk ELLER-mengd)." ;
    skos:exactMatch modelldcatno:AnyOf ;
    skos:inScheme <https://data.norge.no/linkml/modelldcat-ap-no> .

<https://data.norge.no/linkml/modelldcat-ap-no/Og> a owl:Class ;
    rdfs:label "Og" ;
    rdfs:subClassOf <https://data.norge.no/linkml/modelldcat-ap-no/Betingelsesregel> ;
    skos:definition "Og — logisk OG-betingelse; alle deltakande modellelement må gjelde." ;
    skos:exactMatch modelldcatno:And ;
    skos:inScheme <https://data.norge.no/linkml/modelldcat-ap-no> .

<https://data.norge.no/linkml/modelldcat-ap-no/XEllerY> a owl:Class ;
    rdfs:label "XEllerY" ;
    rdfs:subClassOf <https://data.norge.no/linkml/modelldcat-ap-no/Betingelsesregel> ;
    skos:definition "Xor — eksklusiv ELLER-betingelse; nøyaktig eitt modellelement må gjelde." ;
    skos:exactMatch modelldcatno:Xor ;
    skos:inScheme <https://data.norge.no/linkml/modelldcat-ap-no> .

<https://data.norge.no/linkml/modelldcat-ap-no/Abstraksjon> a owl:Class ;
    rdfs:label "Abstraksjon" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/er_abstraksjon_av> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/modelldcat-ap-no/Modellelement> ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/er_abstraksjon_av> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/er_abstraksjon_av> ],
        <https://data.norge.no/linkml/modelldcat-ap-no/Eigenskap> ;
    skos:definition "Ein abstraksjon — ein forenkling som representerer eit modellelement." ;
    skos:exactMatch modelldcatno:Abstraction ;
    skos:inScheme <https://data.norge.no/linkml/modelldcat-ap-no> .

<https://data.norge.no/linkml/modelldcat-ap-no/Assosiasjon> a owl:Class ;
    rdfs:label "Assosiasjon" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/modelldcat-ap-no/Modellelement> ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/refererer_til> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/refererer_til> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/refererer_til> ],
        <https://data.norge.no/linkml/modelldcat-ap-no/Eigenskap> ;
    skos:definition "Ein assosiasjon — ein eigenskap som refererer til eit anna modellelement." ;
    skos:exactMatch modelldcatno:Association ;
    skos:inScheme <https://data.norge.no/linkml/modelldcat-ap-no> .

<https://data.norge.no/linkml/modelldcat-ap-no/Attributt> a owl:Class ;
    rdfs:label "Attributt" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/har_verdi_fra> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/inneholder_objekttype> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/modelldcat-ap-no/Datatype> ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/har_datatype> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/modelldcat-ap-no/Kodeliste> ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/har_verdi_fra> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/har_datatype> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/modelldcat-ap-no/Objekttype> ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/inneholder_objekttype> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/modelldcat-ap-no/EnkelType> ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/har_enkel_type> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/har_enkel_type> ],
        <https://data.norge.no/linkml/modelldcat-ap-no/Eigenskap> ;
    skos:definition "Ein attributt — ein eigenskap med ein datatype eller enkel type som verdi." ;
    skos:exactMatch modelldcatno:Attribute ;
    skos:inScheme <https://data.norge.no/linkml/modelldcat-ap-no> .

<https://data.norge.no/linkml/modelldcat-ap-no/Avhengighet> a owl:Class ;
    rdfs:label "Avhengighet" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/avhengig_av> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/modelldcat-ap-no/Modellelement> ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/avhengig_av> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/avhengig_av> ],
        <https://data.norge.no/linkml/modelldcat-ap-no/Eigenskap> ;
    skos:definition "Ein avhengighet — ein relasjon der det eine modellelementet avheng av det andre." ;
    skos:exactMatch modelldcatno:Dependency ;
    skos:inScheme <https://data.norge.no/linkml/modelldcat-ap-no> .

<https://data.norge.no/linkml/modelldcat-ap-no/Merknad> a owl:Class ;
    rdfs:label "Merknad" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/identifikator_literal> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/identifikator_literal> ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdf:langString ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/tittel> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/tilhorer_modul> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/modelldcat-ap-no/Modellelement> ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/annoterer> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/tittel> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/eigenskapsmerknad> ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdf:langString ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/eigenskapsmerknad> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/modelldcat-ap-no/Modul> ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/tilhorer_modul> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/annoterer> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/identifikator_literal> ] ;
    skos:definition "Ei merknad knytt til eit modellelement eller eigenskap." ;
    skos:exactMatch modelldcatno:Note ;
    skos:inScheme <https://data.norge.no/linkml/modelldcat-ap-no> .

<https://data.norge.no/linkml/modelldcat-ap-no/Realisering> a owl:Class ;
    rdfs:label "Realisering" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/modelldcat-ap-no/Modellelement> ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/har_leverandor> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/har_leverandor> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/har_leverandor> ],
        <https://data.norge.no/linkml/modelldcat-ap-no/Eigenskap> ;
    skos:definition "Ein realisering — ein implementasjonsrelasjon mellom modellelement." ;
    skos:exactMatch modelldcatno:Realization ;
    skos:inScheme <https://data.norge.no/linkml/modelldcat-ap-no> .

<https://data.norge.no/linkml/modelldcat-ap-no/Rolle> a owl:Class ;
    rdfs:label "Rolle" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/modelldcat-ap-no/Objekttype> ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/har_objekttype> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/har_objekttype> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/har_objekttype> ],
        <https://data.norge.no/linkml/modelldcat-ap-no/Eigenskap> ;
    skos:definition "Ein rolle — ein eigenskap som knyter ein objekttype til ein assosiasjon." ;
    skos:exactMatch modelldcatno:Role ;
    skos:inScheme <https://data.norge.no/linkml/modelldcat-ap-no> .

<https://data.norge.no/linkml/modelldcat-ap-no/RootObjekttype> a owl:Class ;
    rdfs:label "RootObjekttype" ;
    rdfs:subClassOf <https://data.norge.no/linkml/modelldcat-ap-no/Modellelement> ;
    skos:definition "Ein rotobjekttype — toppnivå-klasse i informasjonsmodellen." ;
    skos:exactMatch modelldcatno:RootObjectType ;
    skos:inScheme <https://data.norge.no/linkml/modelldcat-ap-no> .

<https://data.norge.no/linkml/modelldcat-ap-no/Samling> a owl:Class ;
    rdfs:label "Samling" ;
    rdfs:subClassOf <https://data.norge.no/linkml/modelldcat-ap-no/Eigenskap> ;
    skos:definition "Ein samling — ein eigenskap som representerer ei uordna mengd av modellelement." ;
    skos:exactMatch modelldcatno:Collection ;
    skos:inScheme <https://data.norge.no/linkml/modelldcat-ap-no> .

<https://data.norge.no/linkml/modelldcat-ap-no/Sammensetning> a owl:Class ;
    rdfs:label "Sammensetning" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/modelldcat-ap-no/Modellelement> ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/inneholder> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/inneholder> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/inneholder> ],
        <https://data.norge.no/linkml/modelldcat-ap-no/Eigenskap> ;
    skos:definition "Ein sammensetning — ein sterk eigarelskapsrelasjon mellom modellelement." ;
    skos:exactMatch modelldcatno:Composition ;
    skos:inScheme <https://data.norge.no/linkml/modelldcat-ap-no> .

<https://data.norge.no/linkml/modelldcat-ap-no/Spesialisering> a owl:Class ;
    rdfs:label "Spesialisering" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/har_generelt_begrep> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/har_generelt_begrep> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/linkml/modelldcat-ap-no/Modellelement> ;
            owl:onProperty <https://data.norge.no/linkml/modelldcat-ap-no/har_generelt_begrep> ],
        <https://data.norge.no/linkml/modelldcat-ap-no/Eigenskap> ;
    skos:definition "Ein spesialisering — eit arveforhold frå eit spesielt til eit generelt modellelement." ;
    skos:exactMatch modelldcatno:Specialization ;
    skos:inScheme <https://data.norge.no/linkml/modelldcat-ap-no> .

<https://data.norge.no/linkml/common-ap-no/Begrepssamling> a owl:Class ;
    rdfs:label "Begrepssamling" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ] ;
    skos:definition "Ei SKOS-omgrepssamling (temavokabular)." ;
    skos:exactMatch skos:ConceptScheme ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/anbefalt_term> a owl:DatatypeProperty ;
    rdfs:label "anbefalt_term" ;
    rdfs:range rdf:langString ;
    skos:definition "Føretrukke term/namn for ressursen (skos:prefLabel)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/dekningsomraade> a owl:ObjectProperty ;
    rdfs:label "dekningsomraade" ;
    rdfs:range <https://data.norge.no/linkml/common-ap-no/Konsept> ;
    skos:definition "Geografisk dekningsområde (dct:spatial)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/nokkelord> a owl:DatatypeProperty ;
    rdfs:label "nokkelord" ;
    rdfs:range rdf:langString ;
    skos:definition "Nøkkelord som beskriv ressursen (dcat:keyword)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/common-ap-no/versjonsmerknad> a owl:DatatypeProperty ;
    rdfs:label "versjonsmerknad" ;
    rdfs:range rdf:langString ;
    skos:definition "Merknad om endringar i denne versjonen (adms:versionNotes)." ;
    skos:inScheme <https://data.norge.no/linkml/common-ap-no> .

<https://data.norge.no/linkml/modelldcat-ap-no/Dokument> a owl:Class ;
    rdfs:label "Dokument" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/tittel> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/format> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/spraak> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/format> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/format> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom dct:language ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/spraak> ],
        [ a owl:Restriction ;
            owl:allValuesFrom rdf:langString ;
            owl:onProperty <https://data.norge.no/linkml/common-ap-no/tittel> ] ;
    skos:definition "Eit dokument (foaf:Document)." ;
    skos:exactMatch foaf:Document ;
