@prefix cpsv: <http://purl.org/vocab/cpsv#> .
@prefix cpsvno: <https://data.norge.no/vocabulary/cpsvno#> .
@prefix cv: <http://data.europa.eu/m8g/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix eli: <http://data.europa.eu/eli/ontology#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix locn: <http://www.w3.org/ns/locn#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pav: <http://purl.org/pav/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

xsd:gYear a rdfs:Datatype .

xsd:nonNegativeInteger a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:onDatatype xsd:integer ;
            owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] .

<https://data.norge.no/ap-no/common-ap-no/Begrepssamling> a owl:Class ;
    rdfs:label "Begrepssamling" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ] ;
    skos:definition "Ei SKOS-omgrepssamling (temavokabular)." ;
    skos:exactMatch skos:ConceptScheme ;
    skos:inScheme <https://data.norge.no/ap-no/common-ap-no> .

<https://data.norge.no/ap-no/common-ap-no/Mediatype> a owl:Class ;
    rdfs:label "Mediatype" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ] ;
    skos:definition "Ein medietype eller filformat (dct:MediaTypeOrExtent)." ;
    skos:exactMatch dct:MediaTypeOrExtent ;
    skos:inScheme <https://data.norge.no/ap-no/common-ap-no> .

<https://data.norge.no/ap-no/common-ap-no/anbefalt_term> a owl:DatatypeProperty ;
    rdfs:label "anbefalt_term" ;
    rdfs:range rdf:langString ;
    skos:definition "Føretrukke term/namn for ressursen (skos:prefLabel)." ;
    skos:inScheme <https://data.norge.no/ap-no/common-ap-no> .

<https://data.norge.no/ap-no/common-ap-no/format> a owl:DatatypeProperty ;
    rdfs:label "format" ;
    rdfs:range xsd:string ;
    skos:definition "Filformat eller medietype (dct:format)." ;
    skos:inScheme <https://data.norge.no/ap-no/common-ap-no> .

<https://data.norge.no/ap-no/common-ap-no/har_merknad> a owl:DatatypeProperty ;
    rdfs:label "har_merknad" ;
    rdfs:range rdf:langString ;
    skos:definition "Fritekstmerknad (rdfs:comment)." ;
    skos:inScheme <https://data.norge.no/ap-no/common-ap-no> .

<https://data.norge.no/ap-no/common-ap-no/har_referanse> a owl:DatatypeProperty ;
    rdfs:label "har_referanse" ;
    rdfs:range xsd:anyURI ;
    skos:definition "Referanse til ekstern ressurs (rdfs:seeAlso)." ;
    skos:inScheme <https://data.norge.no/ap-no/common-ap-no> .

<https://data.norge.no/ap-no/common-ap-no/har_versjonsnummer> a owl:DatatypeProperty ;
    rdfs:label "har_versjonsnummer" ;
    rdfs:range xsd:string ;
    skos:definition "Versjonsnummer for ressursen (owl:versionInfo)." ;
    skos:inScheme <https://data.norge.no/ap-no/common-ap-no> .

<https://data.norge.no/ap-no/common-ap-no/utgivelsesdato> a owl:DatatypeProperty ;
    rdfs:label "utgivelsesdato" ;
    rdfs:range xsd:date ;
    skos:definition "Dato ressursen vart første gong publisert (dct:issued)." ;
    skos:inScheme <https://data.norge.no/ap-no/common-ap-no> .

<https://data.norge.no/ap-no/common-ap-no/versjonsmerknad> a owl:DatatypeProperty ;
    rdfs:label "versjonsmerknad" ;
    rdfs:range rdf:langString ;
    skos:definition "Merknad om endringar i denne versjonen (adms:versionNotes)." ;
    skos:inScheme <https://data.norge.no/ap-no/common-ap-no> .

<https://data.norge.no/ap-no/cpsv-ap-no.owl.ttl> a owl:Ontology ;
    rdfs:label "cpsv-ap-no" ;
    dct:title "CPSV-AP-NO" ;
    pav:version "1.0" ;
    skos:definition "Norsk applikasjonsprofil av CPSV (Core Public Service Vocabulary), modellert i LinkML med lenking framfor inlining. Basert på https://informasjonsforvaltning.github.io/cpsv-ap-no/" .

<https://data.norge.no/ap-no/cpsv-ap-no/Katalog> a owl:Class ;
    rdfs:label "Katalog" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ap-no/common-ap-no/Konsept> ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/dekningsomraade> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/ap-no/cpsv-ap-no/lisens> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ap-no/cpsv-ap-no/inneheld_hending> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:date ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/endringsdato> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/cpsv-ap-no/har_kontaktpunkt> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/cpsv-ap-no/inneheld_teneste> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/id> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/heimeside> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/tittel> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://data.norge.no/ap-no/common-ap-no/Konsept> ;
            owl:onProperty <https://data.norge.no/ap-no/cpsv-ap-no/oppdateringsfrekvens> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://data.norge.no/ap-no/common-ap-no/spraak> ],
        [ a owl:Restriction ;
