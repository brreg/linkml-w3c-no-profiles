@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix dqv: <http://www.w3.org/ns/dqv#> .
@prefix dqvno: <https://data.norge.no/vocabulary/dqvno#> .
@prefix ns1: <https://data.norge.no/linkml/dqv-ap-no-fixture/> .
@prefix oa: <http://www.w3.org/ns/oa#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://example.org/datasett/aapen-adresseregister> a dcat:Dataset ;
    dct:conformsTo <https://example.org/standardar/iso-19157> ;
    dct:description "Eit datasett med norske adresser tilgjengeleg for allmenta."^^rdf:langString ;
    dct:publisher <https://organization-catalog.fellesdatakatalog.digdir.no/organizations/991825827> ;
    dct:title "Ope adresseregister"^^rdf:langString ;
    dcat:contactPoint <https://example.org/kontaktpunkt/1> ;
    dcat:theme "http://publications.europa.eu/resource/authority/data-theme/REGI" ;
    dqv:hasQualityAnnotation <https://example.org/merknader/adresser-kompletheit-1> ;
    dqv:hasQualityMeasurement <https://example.org/maalingar/adresser-dekning-2024> .

dqvno:rateOfMissingValues a dqvno:SubDimension ;
    skos:broader dqvno:completeness ;
    skos:definition "Andelen manglande verdiar samanlikna med totalt forventa antal verdiar."^^rdf:langString ;
    skos:prefLabel "Andel manglande verdiar"^^rdf:langString .

<https://example.org/maal/dekning-prosent> a dqv:Metric ;
    skos:definition "Prosentandel av forventa objekt som faktisk er registrert i datasettet."^^rdf:langString ;
    skos:prefLabel "Dekningsprosent"^^rdf:langString ;
    dqv:expectedDataType "xsd:double"^^xsd:anyURI ;
    dqvno:inSubDimension dqvno:rateOfMissingValues .

<https://example.org/maalingar/adresser-dekning-2024> a dqv:QualityMeasurement ;
    dqv:isMeasurementOf <https://example.org/maal/dekning-prosent> ;
    dqv:value "98.7" .

<https://example.org/merknader/adresser-kompletheit-1> a dqv:QualityAnnotation ;
    rdfs:comment "Datasettet dekkjer om lag 98,7 % av registrerte adresser i Noreg."^^rdf:langString ;
    dqv:inDimension dqvno:completeness ;
    oa:hasBody <https://example.org/tekstdelar/adresser-vurdering-1> ;
    oa:motivatedBy "https://www.w3.org/ns/oa#assessing"^^xsd:anyURI .

<https://example.org/standardar/iso-19157> a dct:Standard ;
    dct:title "ISO 19157 - Geographic information - Data quality"^^rdf:langString ;
    rdfs:seeAlso "https://www.iso.org/standard/32575.html"^^xsd:anyURI ;
    owl:versionInfo "2013" ;
    dqv:inDimension dqvno:completeness .

<https://example.org/tekstdelar/adresser-vurdering-1> a oa:TextualBody ;
    dct:language "http://publications.europa.eu/resource/authority/language/NOB"^^dct:language ;
    rdfs:value "Datasettet har svært høg kompletheit basert på samanlikning mot matrikkelen." .

dqvno:completeness a dqv:Dimension ;
    skos:definition "I kva grad datasettet dekker alle forventa objekt og eigenskapar."^^rdf:langString ;
    skos:prefLabel "Kompletheit"^^rdf:langString .

[] a ns1:Container ;
    ns1:datasett <https://example.org/datasett/aapen-adresseregister> ;
    ns1:kvalitetsdeldimensjonar dqvno:rateOfMissingValues ;
    ns1:kvalitetsdimensjonar dqvno:completeness ;
    ns1:kvalitetsmaal <https://example.org/maal/dekning-prosent> ;
    ns1:kvalitetsmaalingar <https://example.org/maalingar/adresser-dekning-2024> ;
    ns1:kvalitetsmerknader <https://example.org/merknader/adresser-kompletheit-1> ;
    ns1:standardar <https://example.org/standardar/iso-19157> ;
    ns1:tekstdelar <https://example.org/tekstdelar/adresser-vurdering-1> .

